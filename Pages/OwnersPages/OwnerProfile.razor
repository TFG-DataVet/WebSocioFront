@page "/PerfilDueno/{Id}"
@inject NavigationManager Nav
@inject OwnerProfileViewModel VM
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true"
                 Style="margin-bottom:1rem;" Close="@VM.ClearErrorPublic" />
}

<!-- BREADCRUMB -->
<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6"
             Style="margin-bottom:1rem;">
    <RadzenLink Path="/Duenos" Text="Dueños" Style="color:#4facfe; font-size:13px;" />
    <RadzenText Text="/" Style="color:#ccc; font-size:13px;" />
    <RadzenText Text="@($"{VM.Owner.Name} {VM.Owner.LastName}")"
                Style="font-size:13px; color:#666;" />
</RadzenStack>

<RadzenCard Style="border-radius:14px; overflow:hidden; padding:0;">

    <!-- HERO HEADER -->
    <div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
                padding: 2rem 2rem 3.5rem; position:relative; overflow:hidden;">
        <div style="position:absolute; top:-40px; right:-40px; width:200px; height:200px;
                    background:rgba(255,255,255,0.08); border-radius:50%;"></div>
        <div style="position:absolute; bottom:-60px; left:30%; width:160px; height:160px;
                    background:rgba(255,255,255,0.05); border-radius:50%;"></div>

        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween"
                     Wrap="FlexWrap.Wrap"
                     Gap="15">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="20">
                <RadzenCard Style="width:80px; height:80px; border-radius:50%; background:rgba(255,255,255,0.25);
                                   border:3px solid white;
                                   display:flex; align-items:center; justify-content:center; font-size:36px; padding:0;">
                    👤
                </RadzenCard>
                <RadzenStack Gap="4">
                    <RadzenText Text="@($"{VM.Owner.Name} {VM.Owner.LastName}")"
                                Style="font-size:26px; font-weight:700; color:white; margin:0;" />
                    <RadzenText Text="@VM.Owner.Email"
                                Style="font-size:14px; color:rgba(255,255,255,0.85);" />
                    <RadzenBadge BadgeStyle="@(VM.Owner.StatusApp == StatusApp.Active ? BadgeStyle.Success : BadgeStyle.Danger)"
                                 Text="@VM.Owner.StatusApp.ToString()"
                                 Style="border-radius:8px; font-size:11px; width:fit-content;" />
                </RadzenStack>
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="8" Wrap="FlexWrap.Wrap">
                @if (!VM.IsEditing)
                {
                    <RadzenButton Text="Editar" Icon="edit"
                                  Style="background:white; color:#4facfe; font-weight:600; border-radius:9px;"
                                  Click="@(() => VM.IsEditing = true)" />
                }
                else
                {
                    <RadzenButton Text="Cancelar" Icon="close"
                                  ButtonStyle="ButtonStyle.Light"
                                  Style="border-radius:9px; background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.4);"
                                  Click="@VM.Cancel" />
                    <RadzenButton Text="Guardar" Icon="save"
                                  Style="background:white; color:#4facfe; font-weight:600; border-radius:9px;"
                                  Click="@OnSave" />
                }
                <RadzenButton Text="Eliminar" Icon="delete"
                              ButtonStyle="ButtonStyle.Danger"
                              Style="border-radius:9px; background:rgba(231,74,59,0.85); border:none;"
                              Click="@OnDelete" />
            </RadzenStack>
        </RadzenStack>
    </div>

    <div style="padding:2rem;">

        <!-- INFORMACIÓN PERSONAL -->
        <RadzenText Text="Información personal"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />

        <RadzenRow Gap="20" Style="margin-bottom:2rem;">
            <RadzenColumn Size="12" SizeMD="6">@Campo("Nombre",        VM.Owner.Name,                v => VM.Owner.Name                = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Apellido",      VM.Owner.LastName,             v => VM.Owner.LastName             = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Identificación",VM.Owner.IdentificationNumber, v => VM.Owner.IdentificationNumber = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Email",         VM.Owner.Email,                v => VM.Owner.Email                = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Teléfono",      VM.Owner.Phone,                v => VM.Owner.Phone                = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Comentarios",   VM.Owner.Coments,              v => VM.Owner.Coments              = v)</RadzenColumn>
        </RadzenRow>

        <RadzenDivider Style="margin:1.5rem 0;" />

        <!-- DIRECCIÓN -->
        <RadzenText Text="Dirección"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />

        <RadzenRow Gap="20" Style="margin-bottom:2rem;">
            <RadzenColumn Size="12" SizeMD="6">@Campo("Calle",  VM.Owner.Street,     v => VM.Owner.Street     = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">@Campo("Ciudad", VM.Owner.City,       v => VM.Owner.City       = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="2">@Campo("C.P.",   VM.Owner.PostalCode, v => VM.Owner.PostalCode = v)</RadzenColumn>
        </RadzenRow>

        <RadzenDivider Style="margin:1.5rem 0;" />

        <!-- FECHAS SISTEMA -->
        <RadzenText Text="Registro del sistema"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />
        <RadzenRow Gap="20" Style="margin-bottom:2rem;">
            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Creado el", VM.Owner.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"), null)
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Última actualización", VM.Owner.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm"), null)
            </RadzenColumn>
        </RadzenRow>

        <RadzenDivider Style="margin:1.5rem 0;" />

        <!-- MASCOTAS -->
        <RadzenText Text="Mascotas asociadas"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />

        @if (VM.Owner.Pet != null && VM.Owner.Pet.Any())
        {
            <RadzenRow Gap="15">
                @foreach (var mascota in VM.Owner.Pet)
                {
                    <RadzenColumn Size="12" SizeMD="4" SizeLG="3">
                        <RadzenCard Style="border-radius:12px; cursor:pointer;"
                                    Click="@(() => Nav.NavigateTo($"/PerfilMascota/{mascota.Id}"))">
                            <RadzenStack AlignItems="AlignItems.Center" Gap="8" Style="padding:0.5rem;">
                                <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png"
                                              Size="55px" />
                                <RadzenText Text="@mascota.Name" Style="font-weight:600; font-size:15px;" />
                                <RadzenText Text="@($"{mascota.Specie} · {mascota.Breed}")"
                                            Style="font-size:12px; color:#888; text-align:center;" />
                                <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@($"{mascota.Age} años")"
                                             Style="border-radius:6px; font-size:11px;" />
                            </RadzenStack>
                        </RadzenCard>
                    </RadzenColumn>
                }
                <RadzenColumn Size="12" SizeMD="4" SizeLG="3">
                    <RadzenCard Style="border-radius:12px; cursor:pointer; border:2px dashed #ddd;
                                       background:#fafafa; min-height:140px;"
                                Click="@(() => Nav.NavigateTo("/create-pet"))">
                        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                                     Gap="6" Style="height:100%; min-height:130px;">
                            <RadzenIcon Icon="add_circle" Style="font-size:32px; color:#ccc;" />
                            <RadzenText Text="Agregar mascota" Style="font-size:13px; color:#aaa;" />
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>
        }
        else
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="10"
                         Style="padding:2rem; background:#fafafa; border-radius:10px; border:2px dashed #eee;">
                <RadzenText Text="🐾" Style="font-size:36px;" />
                <RadzenText Text="Sin mascotas registradas" Style="color:#aaa; font-style:italic;" />
                <RadzenButton Text="Registrar mascota" Icon="add" ButtonStyle="ButtonStyle.Primary"
                              Style="border-radius:8px; margin-top:0.5rem;"
                              Click="@(() => Nav.NavigateTo("/create-pet"))" />
            </RadzenStack>
        }

        <RadzenDivider Style="margin:1.5rem 0;" />

        <!-- HISTORIAL -->
        <RadzenText Text="Historial de actividad"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />

        @if (VM.Owner.Historic != null && VM.Owner.Historic.Any())
        {
            <RadzenDataList Data="@VM.Owner.Historic" TItem="LogEntry">
                <Template Context="log">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                 Gap="12" Style="padding:0.6rem 0; border-bottom:1px solid #f0f0f0;">
                        <RadzenIcon Icon="history" Style="font-size:18px; color:#4facfe;" />
                        <RadzenStack Gap="0">
                            <RadzenText Text="@log.Description" Style="font-size:14px;" />
                            <RadzenText Text="@log.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")"
                                        Style="font-size:12px; color:#aaa;" />
                        </RadzenStack>
                    </RadzenStack>
                </Template>
            </RadzenDataList>
        }
        else
        {
            <RadzenText Text="Sin historial registrado." Style="font-style:italic; color:#aaa;" />
        }

    </div>
</RadzenCard>

@code {
    [Parameter] public string Id { get; set; } = "";

    protected override async Task OnInitializedAsync() => await VM.LoadAsync(Id);

    async Task OnSave()
    {
        await VM.SaveAsync();
        if (!VM.HasError)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary  = "Guardado",
                Detail   = "Los cambios se guardaron correctamente.",
                Duration = 3000
            });
        }
    }

    async Task OnDelete()
    {
        var confirmed = await DialogService.Confirm(
            $"¿Eliminar a {VM.Owner.Name} {VM.Owner.LastName}? Esta acción no se puede deshacer.",
            "Confirmar eliminación",
            new ConfirmOptions { OkButtonText = "Eliminar", CancelButtonText = "Cancelar" });

        if (confirmed != true) return;

        await VM.DeleteAsync(Id);

        if (VM.HasError)
        {
            // El error ya se muestra en el alert de arriba
            return;
        }

        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Success,
            Summary  = "Eliminado",
            Detail   = "El dueño fue eliminado correctamente.",
            Duration = 3000
        });

        Nav.NavigateTo("/Duenos");
    }

    RenderFragment Campo(string label, string? valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="4">
            <RadzenLabel Text="@label" Style="font-size:12px; font-weight:600; color:#999;" />
            @if (!VM.IsEditing)
            {
                <RadzenText Text="@(valor ?? "—")" Style="font-size:15px; color:#333;" />
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e?.ToString() ?? ""))"
                               Style="width:100%; border-radius:8px;" />
            }
            else
            {
                <RadzenText Text="@(valor ?? "—")" Style="font-size:15px; color:#666;" />
            }
        </RadzenStack>;
    };
}
