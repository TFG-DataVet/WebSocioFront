@page "/Productos"
@using SocioWeb.ViewModels
@inject NavigationManager Nav

<RadzenStack Orientation="Orientation.Horizontal"
             AlignItems="AlignItems.Center"
             Gap="10"
             Style="padding:10px 20px">

    <RadzenText Text="Productos" TextStyle="TextStyle.H5"/>

    <RadzenDatePicker @bind-Value="vm.DateSince" Placeholder="Desde" Style="width:160px"/>
    <RadzenDatePicker @bind-Value="vm.DateTo" Placeholder="Hasta" Style="width:160px"/>
    <RadzenTextBox @bind-Value="vm.CategoryFilter" Placeholder="Categoría" Style="width:150px"/>
    <RadzenTextBox @bind-Value="vm.BrandFilter" Placeholder="Marca" Style="width:150px"/>
    <RadzenNumeric @bind-Value="vm.MinimumStock" Placeholder="Stock mín." Style="width:120px"/>

    <RadzenButton Icon="filter_alt"
                  Text="Filtrar"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="@vm.ApplyFilters"/>
</RadzenStack>

<RadzenRow>
    <RadzenColumn Size="12">
        @foreach (var producto in vm.FilteredProducts)
        {
            <RadzenCard Style="margin-bottom:30px; border-radius:16px; box-shadow:0 4px 20px rgba(0,0,0,0.1); overflow:hidden; cursor:pointer;"
                        Click="@(() => Nav.NavigateTo($"/PerfilProducto/{producto.Id}"))">

                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween"
                             Style="padding:20px; background:linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color:white;">

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="15">
                        <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/679/679720.png" Size="70px" Style="border:3px solid white;"/>
                        <RadzenStack Gap="2">
                            <RadzenLink Path="@($"/PerfilProducto/{producto.Id}")" Style="text-decoration:none;">
                                <RadzenText Text="@producto.Name" Style="font-size:22px; font-weight:600; color:white;"/>
                            </RadzenLink>
                            <RadzenText Text="@producto.Category" Style="opacity:0.9; font-size:13px; color:white;"/>
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenText Text="@($"{producto.Price:C}")" Style="font-size:20px; font-weight:600;"/>
                </RadzenStack>

                <RadzenStack Style="padding:20px;">
                    <RadzenRow>
                        <RadzenColumn Size="6">
                            <RadzenStack Gap="6">
                                <RadzenLabel Text="🏷 Marca:" Style="font-weight:600;"/>
                                <RadzenText Text="@producto.Brand"/>
                                <RadzenLabel Text="📦 Stock:" Style="font-weight:600;"/>
                                <RadzenText Text="@producto.Stock.ToString()"/>
                            </RadzenStack>
                        </RadzenColumn>

                        <RadzenColumn Size="6">
                            <RadzenStack Gap="6">
                                <RadzenLabel Text="📅 Alta:" Style="font-weight:600;"/>
                                <RadzenText Text="@producto.CreatedAt.ToShortDateString()"/>
                                <RadzenLabel Text="📝 Descripción:" Style="font-weight:600;"/>
                                <RadzenText Text="@producto.Description"/>
                            </RadzenStack>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>

            </RadzenCard>
        }
    </RadzenColumn>
</RadzenRow>

@code {
    private ProductVM vm = new();

    protected override void OnInitialized()
    {
        vm.Load();
    }
}