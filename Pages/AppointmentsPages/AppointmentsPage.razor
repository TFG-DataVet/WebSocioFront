@page "/Citas"
@using SocioWeb.Entities.Models.Appointments
@using SocioWeb.ViewModels.Appointments
@inject NavigationManager Nav
@inject AppointmentListViewModel VM
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                       Style="margin-bottom:1rem;" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true" />
}

<PageTitle>Citas Veterinarias</PageTitle>

<!-- HEADER -->
<RadzenCard Style="
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(102,126,234,0.35);
    margin-bottom: 1.5rem;
    padding: 1.5rem 2rem;">

    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Wrap="FlexWrap.Wrap"
                 Gap="10">

        <RadzenStack Gap="2">
            <RadzenText Text="Gestión de Citas"
                        Style="font-size:28px; font-weight:700;" />
            <RadzenText Text="@($"{VM.FilteredAppointments.Count} registros encontrados")"
                        Style="font-size:18px; opacity:0.85;" />
        </RadzenStack>

        <RadzenButton Text="Nueva Cita"
                      Icon="event"
                      Style="background:white; color:#667eea; font-weight:600; border-radius:10px;"
                      Click="@(() => Nav.NavigateTo("/CreateAppointment"))" />
    </RadzenStack>
</RadzenCard>

<!-- FILTROS -->
<RadzenCard Style="border-radius:12px; margin-bottom:1.5rem; padding:1.2rem 1.5rem;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.End"
                 Wrap="FlexWrap.Wrap"
                 Gap="12">

        <RadzenStack Gap="4">
            <RadzenLabel Text="Fecha" Style="font-size:16px; font-weight:600;" />
            <RadzenDatePicker TValue="DateOnly?" @bind-Value="VM.DateFilter"
                              DateFormat="dd/MM/yyyy" Style="width:155px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Estado" Style="font-size:16px; font-weight:600;" />
            <RadzenDropDown TValue="AppointmentStatus?"
                            Data="@_statuses"
                            @bind-Value="VM.StatusFilter"
                            Placeholder="Todos"
                            Style="width:180px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Tipo" Style="font-size:16px; font-weight:600;" />
            <RadzenDropDown TValue="AppointmentType?"
                            Data="@_types"
                            @bind-Value="VM.TypeFilter"
                            Placeholder="Todos"
                            Style="width:140px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Búsqueda" Style="font-size:16px; font-weight:600;" />
            <RadzenTextBox @bind-Value="VM.SearchFilter" Placeholder="Propietario o mascota…"
                           Style="width:200px" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8">
            <RadzenButton Icon="filter_alt" Text="Filtrar"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@(async () => { await VM.LoadAsync(); VM.ApplyLocalFilter(); })" />
            <RadzenButton Icon="clear" Text="Limpiar"
                          ButtonStyle="ButtonStyle.Light"
                          Click="@(async () => { VM.ClearFilters(); await VM.LoadAsync(); })" />
        </RadzenStack>
    </RadzenStack>
</RadzenCard>

<!-- TABLA -->
<RadzenCard Style="border-radius:12px; padding:0; overflow:hidden;">
    <RadzenDataGrid Data="@VM.FilteredAppointments"
                    TItem="Appointment"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="10"
                    ShowPagingSummary="true"
                    PagingSummaryFormat="Página {0} de {1} — Total: {2}"
                    EmptyText="No se encontraron citas."
                    Style="border:none;">

        <Columns>

            <!-- Mascota / Propietario -->
            <RadzenDataGridColumn TItem="Appointment" Title="Mascota" Width="200px">
                <Template Context="cita">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10" AlignItems="AlignItems.Center">
                        <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png" Size="38" />
                        <RadzenStack Gap="0">
                            <RadzenText Text="@(cita.Pet?.Name ?? "—")" Style="font-weight:600;" />
                            <RadzenText Text="@(cita.OwnerName ?? "—")" Style="font-size:12px; color:#888;" />
                        </RadzenStack>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <!-- Estado -->
            <RadzenDataGridColumn TItem="Appointment" Title="Estado" Width="160px">
                <Template Context="cita">
                    <span style="padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600;
                                 background:@StatusColor(cita.Status); color:white;">
                        @cita.Status.ToString().Replace("_", " ")
                    </span>
                </Template>
            </RadzenDataGridColumn>

            <!-- Tipo -->
            <RadzenDataGridColumn TItem="Appointment" Title="Tipo" Width="110px">
                <Template Context="cita">
                    <RadzenText Text="@cita.Type.ToString()" Style="font-size:13px;" />
                </Template>
            </RadzenDataGridColumn>

            <!-- Fecha -->
            <RadzenDataGridColumn TItem="Appointment" Title="Fecha y Hora" Width="160px">
                <Template Context="cita">
                    <RadzenText Text="@cita.ScheduledAt.ToString("dd/MM/yyyy HH:mm")" />
                </Template>
            </RadzenDataGridColumn>

            <!-- Contacto -->
            <RadzenDataGridColumn TItem="Appointment" Title="Teléfono" Width="130px">
                <Template Context="cita">
                    <RadzenText Text="@(cita.OwnerPhone ?? "—")" />
                </Template>
            </RadzenDataGridColumn>

            <!-- Notas -->
            <RadzenDataGridColumn TItem="Appointment" Title="Notas" Width="200px">
                <Template Context="cita">
                    <RadzenText Text="@(cita.Notes ?? "—")" Style="font-size:13px; color:#666;" />
                </Template>
            </RadzenDataGridColumn>

            <!-- Acciones -->
            <RadzenDataGridColumn TItem="Appointment" Title="Acciones" Width="120px" Sortable="false">
                <Template Context="cita">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6">
                        <RadzenButton Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small"
                                      Click="@(() => Nav.NavigateTo($"/AppointmentProfile/{cita.Id}"))" />
                        <RadzenButton Icon="cancel"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Small"
                                      Disabled="@(cita.Status == AppointmentStatus.CANCELADA || cita.Status == AppointmentStatus.FINALIZADA)"
                                      Click="@(async () => await ConfirmCancel(cita))" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {

    static readonly AppointmentStatus?[] _statuses = new AppointmentStatus?[]
    {
        null,
        AppointmentStatus.RESERVADA,
        AppointmentStatus.CLIENTE_LLEGADO,
        AppointmentStatus.PROXIMO_A_ATENDER,
        AppointmentStatus.EN_CONSULTA,
        AppointmentStatus.FINALIZADA,
        AppointmentStatus.REQUIERE_SEGUIMIENTO,
        AppointmentStatus.CANCELADA
    };

    static readonly AppointmentType?[] _types = new AppointmentType?[]
    {
        null,
        AppointmentType.RUTINA,
        AppointmentType.EXAMEN,
        AppointmentType.VACUNAS,
        AppointmentType.EMERGENCIA,
        AppointmentType.BAÑO,
        AppointmentType.CIRUGIA,
        AppointmentType.OTRO
    };

    protected override async Task OnInitializedAsync() => await VM.LoadAsync();

    static string StatusColor(AppointmentStatus s) => s switch
    {
        AppointmentStatus.RESERVADA           => "#4e73df",
        AppointmentStatus.CLIENTE_LLEGADO     => "#1cc88a",
        AppointmentStatus.PROXIMO_A_ATENDER   => "#36b9cc",
        AppointmentStatus.EN_CONSULTA         => "#f6c23e",
        AppointmentStatus.FINALIZADA          => "#858796",
        AppointmentStatus.REQUIERE_SEGUIMIENTO=> "#e74a3b",
        AppointmentStatus.CANCELADA           => "#e74a3b",
        _                                     => "#aaa"
    };

    async Task ConfirmCancel(Appointment cita)
    {
        var result = await DialogService.Confirm(
            $"¿Cancelar la cita de {cita.Pet?.Name ?? cita.OwnerName ?? "esta mascota"}?",
            "Confirmar cancelación",
            new ConfirmOptions { OkButtonText = "Cancelar cita", CancelButtonText = "Volver" });

        if (result == true)
        {
            await VM.CancelAsync(cita.Id);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary  = "Cita cancelada",
                Detail   = "La cita fue cancelada correctamente.",
                Duration = 3000
            });
        }
    }
}
