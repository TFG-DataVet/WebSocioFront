@page "/MedicalRegister"
@inject MedicalRegisterViewModel VM

<RadzenRow Style="height:5%" AlignItems="AlignItems.Center">
    <RadzenColumn Size="12" Style="background:#f5f5f5; padding:5px 0;">
        <RadzenStack Orientation="Orientation.Horizontal"
                     JustifyContent="JustifyContent.SpaceAround"
                     AlignItems="AlignItems.Center"
                     Gap="4">

            <RadzenButton Icon="medical_services" Text="Consulta"
                          Click="() => VM.SelectCase(MedicalCase.Consultation)"
                          Style="min-width:240px;"/>
            <RadzenButton Icon="vaccines"         Text="Vacuna"
                          Click="() => VM.SelectCase(MedicalCase.Vaccine)"
                          Style="min-width:240px;"/>
            <RadzenButton Icon="healing"          Text="Tratamiento"
                          Click="() => VM.SelectCase(MedicalCase.Treatment)"
                          Style="min-width:240px;"/>
            <RadzenButton Icon="content_cut"      Text="Cirugía"
                          Click="() => VM.SelectCase(MedicalCase.Surgery)"
                          Style="min-width:240px;"/>
            <RadzenButton Icon="monitor_weight"   Text="Peso"
                          Click="() => VM.SelectCase(MedicalCase.Weight)"
                          Style="min-width:240px;"/>
            <RadzenButton Icon="fact_check"       Text="Diagnóstico"
                          Click="() => VM.SelectCase(MedicalCase.Diagnosis)"
                          Style="min-width:240px;"/>
            <RadzenButton Icon="report_problem"   Text="Alergia"
                          Click="() => VM.SelectCase(MedicalCase.Allergy)"
                          Style="min-width:240px;"/>
            <RadzenButton Icon="description"      Text="Documento"
                          Click="() => VM.SelectCase(MedicalCase.Document)"
                          Style="min-width:240px;"/>

        </RadzenStack>
    </RadzenColumn>
</RadzenRow>

<RadzenColumn Size="12" Style="padding:10px">

    <!-- CONSULTA SIEMPRE VISIBLE -->
    <RadzenCard Style="width:100%; margin-bottom:20px;">
        <RadzenText Text="Registro de Consulta"
                    TextStyle="TextStyle.H6"
                    Style="margin-bottom:15px"/>
        @ConsultationForm()
    </RadzenCard>

    <!-- FORMULARIO SELECCIONADO -->
    @if (VM.SelectedCase != MedicalCase.Consultation)
    {
        <RadzenCard Style="width:100%;">
            <RadzenText Text="@VM.Title"
                        TextStyle="TextStyle.H6"
                        Style="margin-bottom:15px"/>
            @switch (VM.SelectedCase)
            {
                case MedicalCase.Vaccine:    @VaccineForm()    break;
                case MedicalCase.Treatment:  @TreatmentForm()  break;
                case MedicalCase.Surgery:    @SurgeryForm()    break;
                case MedicalCase.Weight:     @WeightForm()     break;
                case MedicalCase.Diagnosis:  @DiagnosisForm()  break;
                case MedicalCase.Allergy:    @AllergyForm()    break;
                case MedicalCase.Document:   @DocumentForm()   break;
            }
        </RadzenCard>
    }

    <!-- BOTÓN GUARDAR -->
    <RadzenRow Style="margin-top:30px;">
        <RadzenColumn Size="12" Style="text-align:right;">
            <RadzenButton Text="Guardar"
                          Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@VM.SaveCurrentCase"
                          Style="min-width:150px;"/>
        </RadzenColumn>
    </RadzenRow>

</RadzenColumn>

@code {
    // Los RenderFragments se quedan en la vista porque son helpers visuales
}

@functions {

    RenderFragment ConsultationForm() => @<RadzenTemplateForm TItem="Consultation" Data="@VM.Consultation">
        <RadzenFieldset Text="Datos de la Consulta" Style="padding:15px;">
            <RadzenTextBox  @bind-Value="VM.Consultation.Reason"      Placeholder="Motivo de la consulta"          Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea @bind-Value="VM.Consultation.Symptoms"    Placeholder="Síntomas observados"            Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea @bind-Value="VM.Consultation.PhysicalExam" Placeholder="Examen físico"                 Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea @bind-Value="VM.Consultation.Notes"       Placeholder="Observaciones del veterinario"  Style="width:100%; margin-bottom:15px;"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;

    RenderFragment VaccineForm() => @<RadzenTemplateForm TItem="Vaccine" Data="@VM.Vaccine">
        <RadzenFieldset Text="Vacunación" Style="padding:15px;">
            <RadzenTextBox   @bind-Value="VM.Vaccine.VaccineName"   Placeholder="Nombre de la vacuna"  Style="width:100%; margin-bottom:15px;"/>
            <RadzenDatePicker TValue="DateTime?" @bind-Value="VM.Vaccine.ApplicationDate" Placeholder="Fecha de aplicación" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDatePicker TValue="DateTime?" @bind-Value="VM.Vaccine.NextDoseDate"    Placeholder="Próxima dosis"       Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextBox   @bind-Value="VM.Vaccine.BatchNumber"   Placeholder="Número de lote"       Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextBox   @bind-Value="VM.Vaccine.Manufacturer"  Placeholder="Fabricante"           Style="width:100%; margin-bottom:15px;"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;

    RenderFragment TreatmentForm() => @<RadzenTemplateForm TItem="Treatment" Data="@VM.Treatment">
        <RadzenFieldset Text="Tratamiento" Style="padding:15px;">
            <RadzenTextBox   @bind-Value="VM.Treatment.TreatmentName" Placeholder="Nombre del tratamiento" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDatePicker TValue="DateTime?" @bind-Value="VM.Treatment.StartDate" Placeholder="Inicio del tratamiento" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDatePicker TValue="DateTime?" @bind-Value="VM.Treatment.EndDate"   Placeholder="Fin del tratamiento"    Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea  @bind-Value="VM.Treatment.Instructions"  Placeholder="Indicaciones"             Style="width:100%; margin-bottom:15px;"/>
            <RadzenCheckBox  TValue="bool" Value="VM.Treatment.FollowUpRequired"
                             Change="@((bool v) => VM.Treatment.FollowUpRequired = v)"/>
            <RadzenLabel Text="¿Requiere seguimiento?" Style="margin-left:5px; margin-bottom:15px;"/>

            <RadzenFieldset Text="Medicamentos" Style="padding:10px;">
                @foreach (var med in VM.Treatment.Medications)
                {
                    <RadzenFieldset Text="Medicamento" Style="margin-bottom:15px; padding:10px;">
                        <RadzenTextBox  @bind-Value="med.Name"      Placeholder="Medicamento"    Style="width:100%; margin-bottom:10px;"/>
                        <RadzenTextBox  @bind-Value="med.Dosage"    Placeholder="Dosis"          Style="width:100%; margin-bottom:10px;"/>
                        <RadzenTextBox  @bind-Value="med.Frequency" Placeholder="Frecuencia"     Style="width:100%; margin-bottom:10px;"/>
                        <RadzenNumeric TValue="int?" @bind-Value="med.DurationInDays" Placeholder="Duración (días)" Style="width:100%; margin-bottom:10px;"/>
                        <RadzenTextArea @bind-Value="med.Notes"     Placeholder="Notas"          Style="width:100%; margin-bottom:10px;"/>
                    </RadzenFieldset>
                }
                <RadzenButton Text="Agregar medicamento" Icon="add"
                              Click="@VM.AddMedication"
                              Style="margin-top:10px; margin-bottom:15px;"/>
            </RadzenFieldset>
        </RadzenFieldset>
    </RadzenTemplateForm>;

    RenderFragment SurgeryForm() => @<RadzenTemplateForm TItem="Surgery" Data="@VM.Surgery">
        <RadzenFieldset Text="Cirugía" Style="padding:15px;">
            <RadzenTextBox @bind-Value="VM.Surgery.SurgeryName" Placeholder="Nombre de la cirugía" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDropDown TValue="SurgeryType"
                            @bind-Value="VM.Surgery.SurgeryType"
                            Data="@(Enum.GetNames(typeof(SurgeryType)))"
                            Placeholder="Tipo de cirugía"
                            Style="width:100%; margin-bottom:15px;"
                            Change="@(args => VM.Surgery.SurgeryType = Enum.Parse<SurgeryType>(args.ToString()))"/>
            <RadzenDatePicker TValue="DateTime?" @bind-Value="VM.Surgery.SurgeryDate" Placeholder="Fecha de cirugía" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDropDown TValue="SurgeryOutcome"
                            @bind-Value="VM.Surgery.Outcome"
                            Data="@(Enum.GetNames(typeof(SurgeryOutcome)))"
                            Placeholder="Resultado"
                            Style="width:100%; margin-bottom:15px;"
                            Change="@(args => VM.Surgery.Outcome = Enum.Parse<SurgeryOutcome>(args.ToString()))"/>
            <RadzenTextBox @bind-Value="VM.Surgery.AnesthesiaType" Placeholder="Tipo de anestesia" Style="width:100%; margin-bottom:15px;"/>
            <RadzenCheckBox TValue="bool" Value="VM.Surgery.HospitalizationRequired"
                            Change="@((bool v) => VM.Surgery.HospitalizationRequired = v)"/>
            <RadzenLabel Text="¿Requiere hospitalización?" Style="margin-left:5px; margin-bottom:10px;"/>
            <RadzenNumeric TValue="int?" @bind-Value="VM.Surgery.HospitalizationDays"
                           Placeholder="Días de hospitalización"
                           Style="width:100%; margin-bottom:15px;"
                           Disabled="@(!VM.Surgery.HospitalizationRequired)"/>
            <RadzenCheckBox TValue="bool" Value="VM.Surgery.FollowUpRequired"
                            Change="@((bool v) => VM.Surgery.FollowUpRequired = v)"/>
            <RadzenLabel Text="¿Requiere seguimiento?" Style="margin-left:5px; margin-bottom:10px;"/>
            <RadzenDatePicker TValue="DateTime?" @bind-Value="VM.Surgery.FollowUpDate"
                              Placeholder="Fecha de seguimiento"
                              Style="width:100%; margin-bottom:15px;"
                              Disabled="@(!VM.Surgery.FollowUpRequired)"/>

            <RadzenFieldset Text="Procedimientos realizados" Style="padding:10px;">
                @foreach (var proc in VM.Surgery.Procedures)
                {
                    <RadzenFieldset Text="Procedimiento" Style="margin-bottom:10px; padding:10px;">
                        <RadzenTextBox @bind-Value="proc.name" Placeholder="Nombre del procedimiento" Style="width:100%; margin-bottom:10px;"/>
                    </RadzenFieldset>
                }
                <RadzenButton Text="Agregar procedimiento" Icon="add"
                              Click="@VM.AddProcedure"
                              Style="margin-top:10px; margin-bottom:15px;"/>
            </RadzenFieldset>

            <RadzenFieldset Text="Medicamentos postoperatorios" Style="padding:10px;">
                @foreach (var med in VM.Surgery.PostOpMedications)
                {
                    <RadzenFieldset Text="Medicamento" Style="margin-bottom:10px; padding:10px;">
                        <RadzenTextBox  @bind-Value="med.Name"      Placeholder="Nombre"         Style="width:100%; margin-bottom:10px;"/>
                        <RadzenTextBox  @bind-Value="med.Dosage"    Placeholder="Dosis"          Style="width:100%; margin-bottom:10px;"/>
                        <RadzenTextBox  @bind-Value="med.Frequency" Placeholder="Frecuencia"     Style="width:100%; margin-bottom:10px;"/>
                        <RadzenNumeric TValue="int?" @bind-Value="med.DurationInDays" Placeholder="Duración (días)" Style="width:100%; margin-bottom:10px;"/>
                        <RadzenTextArea @bind-Value="med.Notes"     Placeholder="Notas"          Style="width:100%; margin-bottom:10px;"/>
                    </RadzenFieldset>
                }
                <RadzenButton Text="Agregar medicamento" Icon="add"
                              Click="@VM.AddPostOpMedication"
                              Style="margin-top:10px; margin-bottom:15px;"/>
            </RadzenFieldset>
        </RadzenFieldset>
    </RadzenTemplateForm>;

    RenderFragment WeightForm() => @<RadzenTemplateForm TItem="WeightRecord" Data="@VM.Weight">
        <RadzenFieldset Text="Control de Peso" Style="padding:15px;">
            <RadzenNumeric TValue="decimal" @bind-Value="VM.Weight.WeightKg" Placeholder="Peso (kg)"         Style="width:100%; margin-bottom:15px;"/>
            <RadzenDatePicker TValue="DateTime?" @bind-Value="VM.Weight.Date"    Placeholder="Fecha de medición" Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea  @bind-Value="VM.Weight.Notes"                    Placeholder="Observaciones"     Style="width:100%; margin-bottom:15px;"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;

    RenderFragment DiagnosisForm() => @<RadzenTemplateForm TItem="Diagnosis" Data="@VM.Diagnosis">
        <RadzenFieldset Text="Diagnóstico" Style="padding:15px;">
            <RadzenTextBox @bind-Value="VM.Diagnosis.DiagnosisName" Placeholder="Nombre del diagnóstico" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDropDown TValue="DiagnosisCategory"
                            @bind-Value="VM.Diagnosis.Category"
                            Data="@(Enum.GetNames(typeof(DiagnosisCategory)))"
                            Placeholder="Categoría"
                            Style="width:100%; margin-bottom:15px;"
                            Change="@(args => VM.Diagnosis.Category = Enum.Parse<DiagnosisCategory>(args.ToString()))"/>
            <RadzenTextArea @bind-Value="VM.Diagnosis.Description" Placeholder="Descripción" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDropDown TValue="DiagnosisSeverity"
                            @bind-Value="VM.Diagnosis.Severity"
                            Data="@(Enum.GetNames(typeof(DiagnosisSeverity)))"
                            Placeholder="Severidad"
                            Style="width:100%; margin-bottom:15px;"
                            Change="@(args => VM.Diagnosis.Severity = Enum.Parse<DiagnosisSeverity>(args.ToString()))"/>
            <RadzenDatePicker @bind-Value="VM.Diagnosis.DiagnosedAt" DateFormat="dd/MM/yyyy" Placeholder="Fecha de diagnóstico" Style="width:100%; margin-bottom:15px;"/>
            <RadzenCheckBox @bind-Value="VM.Diagnosis.Chronic"/>
            <RadzenLabel Text="Crónico"     Style="margin-left:5px; margin-bottom:15px;"/>
            <RadzenCheckBox @bind-Value="VM.Diagnosis.Contagious"/>
            <RadzenLabel Text="Contagioso"  Style="margin-left:5px; margin-bottom:15px;"/>
            <RadzenTextArea @bind-Value="VM.SymptomsText"        Placeholder="Síntomas (separados por comas)"         Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea @bind-Value="VM.RecommendationsText" Placeholder="Recomendaciones (separadas por comas)"  Style="width:100%; margin-bottom:15px;"/>
            <RadzenCheckBox @bind-Value="VM.Diagnosis.FollowUpRequired"/>
            <RadzenLabel Text="Requiere seguimiento" Style="margin-left:5px; margin-bottom:15px;"/>
            <RadzenDatePicker @bind-Value="VM.Diagnosis.FollowUpDate"
                              DateFormat="dd/MM/yyyy"
                              Placeholder="Fecha de seguimiento"
                              Style="width:100%; margin-bottom:15px;"
                              Disabled="@(!VM.Diagnosis.FollowUpRequired)"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;

    RenderFragment AllergyForm() => @<RadzenTemplateForm TItem="Allergy" Data="@VM.Allergy">
        <RadzenFieldset Text="Alergias" Style="padding:15px;">
            <RadzenTextBox @bind-Value="VM.Allergy.Allergen" Placeholder="Alérgeno" Style="width:100%; margin-bottom:15px;"/>
            <RadzenDropDown TValue="AllergyType"
                            @bind-Value="VM.Allergy.Type"
                            Data="@(Enum.GetNames(typeof(AllergyType)))"
                            Placeholder="Tipo de alergia"
                            Style="width:100%; margin-bottom:15px;"
                            Change="@(args => VM.Allergy.Type = Enum.Parse<AllergyType>(args.ToString()))"/>
            <RadzenDropDown TValue="AllergySeverity"
                            @bind-Value="VM.Allergy.Severity"
                            Data="@(Enum.GetNames(typeof(AllergySeverity)))"
                            Placeholder="Severidad"
                            Style="width:100%; margin-bottom:15px;"
                            Change="@(args => VM.Allergy.Severity = Enum.Parse<AllergySeverity>(args.ToString()))"/>
            <RadzenTextArea @bind-Value="VM.ReactionsText" Placeholder="Reacciones (separadas por comas)" Style="width:100%; margin-bottom:15px;"/>
            <RadzenCheckBox @bind-Value="VM.Allergy.LifeThreatening"/>
            <RadzenLabel Text="Potencialmente mortal" Style="margin-left:5px; margin-bottom:15px;"/>
            <RadzenDatePicker @bind-Value="VM.Allergy.IdentifiedAt" DateFormat="dd/MM/yyyy" Placeholder="Fecha de identificación" Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea @bind-Value="VM.Allergy.Notes" Placeholder="Notas adicionales" Style="width:100%; margin-bottom:15px;"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;

    RenderFragment DocumentForm() => @<RadzenTemplateForm TItem="DocumentRecord" Data="@VM.Document">
        <RadzenFieldset Text="Documentos" Style="padding:15px;">
            <RadzenTextBox    @bind-Value="VM.Document.DocumentName"  Placeholder="Nombre del documento"    Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextBox    @bind-Value="VM.Document.DocumentType"  Placeholder="Tipo de documento"       Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextBox    @bind-Value="VM.Document.MimeType"      Placeholder="Tipo MIME"               Style="width:100%; margin-bottom:15px;"/>
            <RadzenDatePicker @bind-Value="VM.Document.UploadedAt"    DateFormat="dd/MM/yyyy"               Placeholder="Fecha de subida"          Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextBox    @bind-Value="VM.Document.UploadedBy"    Placeholder="Subido por"              Style="width:100%; margin-bottom:15px;"/>
            <RadzenTextArea   @bind-Value="VM.Document.Description"   Placeholder="Descripción"             Style="width:100%; margin-bottom:15px;"/>
            <RadzenNumeric    @bind-Value="VM.Document.FileSizeInBytes" Placeholder="Tamaño (bytes)"        Style="width:100%; margin-bottom:15px;"/>
            <RadzenCheckBox   @bind-Value="VM.Document.Confidential"/>
            <RadzenLabel Text="Confidencial" Style="margin-left:5px; margin-bottom:15px;"/>
            <RadzenTextBox    @bind-Value="VM.Document.Checksum"      Placeholder="Checksum"                Style="width:100%; margin-bottom:15px;"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;
}