@page "/PerfilMascota/{Id}"
@inject NavigationManager Nav
@inject PetProfileViewModel VM
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"/>
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true"
                 Style="margin-bottom:1rem;" Close="@VM.ClearErrorPublic" />
}

<RadzenCard Style="border-radius:14px; overflow:hidden; padding:0;">
    <div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
                padding: 2rem 2rem 3.5rem; position:relative; overflow:hidden;">
        <div style="position:absolute; top:-40px; right:-40px; width:200px; height:200px;
                    background:rgba(255,255,255,0.08); border-radius:50%;"></div>

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="20">
            <RadzenCard Style="width:80px; height:80px; border-radius:50%; background:rgba(255,255,255,0.25);
                               border:3px solid white; display:flex; align-items:center; justify-content:center; font-size:36px;">
                🐾
            </RadzenCard>
            <RadzenStack Gap="4">
                <RadzenText Text="@VM.Pet.Name"
                            Style="font-size:26px; font-weight:700; color:white; margin:0;" />
                <RadzenText Text="@($"{VM.Pet.Specie} · {VM.Pet.Breed}")"
                            Style="font-size:14px; color:rgba(255,255,255,0.85);" />
            </RadzenStack>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8" Wrap="FlexWrap.Wrap" Style="margin-top:15px;">
            @if (!VM.IsEditing)
            {
                <RadzenButton Text="Editar perfil" Icon="edit"
                              Style="background:white; color:#4facfe; font-weight:600; border-radius:9px;"
                              Click="@(() => VM.IsEditing = true)" />
            }
            else
            {
                <RadzenButton Text="Cancelar" Icon="close" ButtonStyle="ButtonStyle.Light"
                              Style="border-radius:9px; background:rgba(255,255,255,0.2); color:white;"
                              Click="@VM.Cancel" />
                <RadzenButton Text="Guardar" Icon="save"
                              Style="background:white; color:#4facfe; font-weight:600; border-radius:9px;"
                              Click="@OnSave" />
            }
            <RadzenButton Text="Ver dueño" Icon="account_box"
                          Style="border-radius:9px; background:#4b3e48; color:white;"
                          Click="@(() => Nav.NavigateTo($"/PerfilDueno/{VM.Pet.Owner?.OwnerId}"))" />
        </RadzenStack>
    </div>

    <div style="padding:2rem;">

        <!-- INFORMACIÓN BÁSICA -->
        <RadzenText Text="Información de la mascota"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />

        <RadzenRow Gap="20" Style="margin-bottom:2rem;">
            <RadzenColumn Size="12" SizeMD="6">@Campo("Nombre", VM.Pet.Name, v => VM.Pet.Name = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Especie", VM.Pet.Specie, v => VM.Pet.Specie = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Raza", VM.Pet.Breed, v => VM.Pet.Breed = v)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenStack Gap="5">
                    <RadzenText Text="Sexo" Style="color:#777;"/>
                    @if (!VM.IsEditing)
                    {
                        <RadzenText Text="@VM.Pet.Sex.ToString()" Style="font-size:18px; color:#333;"/>
                    }
                    else
                    {
                        <RadzenDropDown TValue="Sex"
                                        Data="@(Enum.GetValues(typeof(Sex)))"
                                        @bind-Value="VM.Pet.Sex"
                                        Style="width:100%; border-radius:10px;" />
                    }
                </RadzenStack>
            </RadzenColumn>

            
            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Fecha nacimiento", VM.Pet.BirthDate ?? "—", null)
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Número chip", VM.Pet.Chip, v => VM.Pet.Chip = v)
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Edad", VM.Pet.Age > 0 ? $"{VM.Pet.Age} años" : "—", null)
            </RadzenColumn>
        </RadzenRow>

        <RadzenDivider Style="margin:1.5rem 0;" />

        <!-- DUEÑO -->
        <RadzenText Text="Dueño"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />
        <RadzenRow Gap="20" Style="margin-bottom:2rem;">
            <RadzenColumn Size="12" SizeMD="6">@Campo("Nombre", VM.Pet.Owner?.FullName, null)</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">@Campo("Teléfono", VM.Pet.Owner?.Phone, null)</RadzenColumn>
        </RadzenRow>

        <RadzenDivider Style="margin:1.5rem 0;" />

        <!-- FECHAS DEL SISTEMA -->
        <RadzenText Text="Registro del sistema"
                    Style="color:#4b3e48; font-size:18px; font-weight:600; margin-bottom:1.2rem;" />
        <RadzenRow Gap="20">
            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Última actualización",
                    VM.Pet.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—", null)
            </RadzenColumn>
        </RadzenRow>

    </div>
</RadzenCard>

@code {
    [Parameter] public string Id { get; set; } = "";

    protected override async Task OnInitializedAsync() => await VM.LoadAsync(Id);

    async Task OnSave()
    {
        await VM.SaveAsync();
        if (!VM.HasError)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary  = "Guardado",
                Detail   = "Los cambios se guardaron correctamente.",
                Duration = 3000
            });
            VM.IsEditing = false;
        }
    }

    RenderFragment Campo(string label, string? valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="4">
            <RadzenLabel Text="@label" Style="font-size:12px; font-weight:600; color:#999;" />
            @if (!VM.IsEditing || onChange is null)
            {
                <RadzenText Text="@(valor ?? "—")" Style="font-size:15px; color:#333;" />
            }
            else
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e?.ToString() ?? ""))"
                               Style="width:100%; border-radius:8px;" />
            }
        </RadzenStack>;
    };
}