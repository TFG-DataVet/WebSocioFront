@page "/EditCalendarAppointmen"

@inject DialogService DialogService

@* Diálogo para ajustar el slot de tiempo de una cita ya existente *@

<RadzenTemplateForm TItem="EditSlot" Data="@_slot" Submit="@OnSubmit">
    <RadzenStack Gap="1rem">

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            <RadzenLabel Text="Inicio" Style="width:6rem;" />
            <RadzenDatePicker @bind-Value="_slot.Start" Name="Start" ShowTime="true" Style="width:12rem." />
            <RadzenRequiredValidator Component="Start" Text="La fecha de inicio es obligatoria" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            <RadzenLabel Text="Fin" Style="width:6rem;" />
            <RadzenDatePicker @bind-Value="_slot.End" Name="End" ShowTime="true" Style="width:12rem." />
            <RadzenRequiredValidator Component="End" Text="La fecha de fin es obligatoria" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" />
        </RadzenStack>

    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public Appointment? Appointment { get; set; }

    EditSlot _slot = new();

    protected override void OnParametersSet()
    {
        if (Appointment is not null)
        {
            _slot.Start = Appointment.ScheduledAt;
            _slot.End   = Appointment.ScheduledAt.AddMinutes(30);
        }
    }

    void OnSubmit(EditSlot slot) => DialogService.Close(slot);

    public class EditSlot
    {
        public DateTime Start { get; set; }
        public DateTime End   { get; set; }
    }
}
