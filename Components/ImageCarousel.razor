@namespace SocioWeb.Components
@implements IDisposable

<div class="carousel-container">
    <div class="carousel-track"
         style="transform: translateX(calc(-1 * @_currentIndex * 100%))">
        @foreach (var image in Images ?? new List<string>())
        {
            <div class="carousel-slide">
                <img src="@image" alt="" class="carousel-image" />
            </div>
        }
    </div>

    @if ((Images?.Count ?? 0) > 1)
    {
        <button class="carousel-btn carousel-btn-prev" @onclick="PreviousSlide">&#10094;</button>
        <button class="carousel-btn carousel-btn-next" @onclick="NextSlide">&#10095;</button>

        <div class="carousel-indicators">
            @for (int i = 0; i < Images!.Count; i++)
            {
                var index = i;
                <button class="carousel-dot @(_currentIndex == index ? "active" : "")"
                        @onclick="() => GoToSlide(index)">
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<string>? Images { get; set; }
    [Parameter] public int AutoPlayIntervalMs { get; set; } = 5000;
    [Parameter] public bool AutoPlay { get; set; } = true;

    private int _currentIndex;
    private Timer? _timer;

    protected override void OnInitialized()
    {
        if (AutoPlay && (Images?.Count ?? 0) > 1)
            StartTimer();
    }

    private void NextSlide()
    {
        if (Images == null || Images.Count == 0) return;
        _currentIndex = (_currentIndex + 1) % Images.Count;
    }

    private void PreviousSlide()
    {
        if (Images == null || Images.Count == 0) return;
        _currentIndex = (_currentIndex - 1 + Images.Count) % Images.Count;
    }

    private void GoToSlide(int index)
    {
        _currentIndex = index;
        RestartTimer();
    }

    private void StartTimer()
    {
        _timer = new Timer(_ => InvokeAsync(() =>
        {
            NextSlide();
            StateHasChanged();
        }), null, AutoPlayIntervalMs, AutoPlayIntervalMs);
    }

    private void RestartTimer()
    {
        _timer?.Dispose();
        _timer = null;
        if (AutoPlay && (Images?.Count ?? 0) > 1)
            StartTimer();
    }

    public void Dispose() => _timer?.Dispose();
}
