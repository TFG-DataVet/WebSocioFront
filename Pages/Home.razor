@page "/"

<PageTitle>Home</PageTitle>

<!-- BIENVENIDA -->
<RadzenCard Style="
    background:#4e73df;
    color:white;
    border-radius:12px;
    box-shadow:0 2px 6px rgba(0,0,0,0.1);
    margin-bottom:1rem;">

    <RadzenStack Gap="5">
        <RadzenText Text="@($"Bienvenido {VeterinarioNombre}")"
                    Style="font-size:18px; opacity:0.9;"/>
        <RadzenText Text="@ClinicaNombre"
                    Style="font-size:28px; font-weight:700;"/>
    </RadzenStack>

</RadzenCard>

<!-- PANEL DE INFORMACIÓN RÁPIDA -->
<RadzenRow Style="margin-bottom:1rem;">

    <RadzenColumn Size="3">
        <RadzenLink Path="/create-pet" Style="text-decoration:none;">
            <RadzenCard Style="text-align:center; background:#36b9cc; color:white; cursor:pointer;">
                <RadzenStack AlignItems="AlignItems.Center" Gap="5">
                    <RadzenText Text="👨‍👩‍🐾‍👦" Style="font-size:26px;"/>
                    <RadzenText Text="Nueva mascota" Style="font-weight:600;"/>
                    <RadzenText Text="+" Style="font-size:32px; font-weight:700;"/>
                </RadzenStack>
            </RadzenCard>
        </RadzenLink>
    </RadzenColumn>

    <RadzenColumn Size="3">
        <RadzenLink Path="/DuenoFormulario" Style="text-decoration:none;">
            <RadzenCard Style="text-align:center; background:#36b9cc; color:white; cursor:pointer;">
                <RadzenStack AlignItems="AlignItems.Center" Gap="5">
                    <RadzenText Text="👨‍👩‍👧‍👦" Style="font-size:26px;"/>
                    <RadzenText Text="Nuevo dueño" Style="font-weight:600;"/>
                    <RadzenText Text="+" Style="font-size:32px; font-weight:700;"/>
                </RadzenStack>
            </RadzenCard>
        </RadzenLink>
    </RadzenColumn>

    <RadzenColumn Size="3">
        <RadzenCard Style="text-align:center; background:#f6c23e; color:white;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="5">
                <RadzenText Text="📅" Style="font-size:26px;"/>
                <RadzenText Text="Citas para hoy" Style="font-weight:600;"/>
                <RadzenText Text=@CitasHoy.ToString()
                            Style="font-size:32px; font-weight:700;"/>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="3">
        <RadzenCard Style="text-align:center; background:#e74a3b; color:white;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="5">
                <RadzenText Text="💊" Style="font-size:26px;"/>
                <RadzenText Text="Productos en stock" Style="font-weight:600;"/>
                <RadzenText Text=@ProductosStock.ToString()
                            Style="font-size:32px; font-weight:700;"/>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

<!-- CALENDARIO DIARIO -->
<RadzenCard Style="
    border-radius:12px;
    box-shadow:0 2px 6px rgba(0,0,0,0.1);
    margin-bottom:1rem;">

    <RadzenText Text="@($"Calendario de hoy ({DateTime.Now:dd/MM/yyyy})")"
                Style="font-size:20px; font-weight:600; margin-bottom:10px;"/>

    <RadzenDataGrid Data="@HorasDelDia"
                    TItem="HoraDelDia"
                    ShowPaging="false"
                    ShowPagingSummary="false"
                    ShowFilterRow="false"
                    Style="width:100%;">
        <Columns>
            <RadzenDataGridColumn TItem="HoraDelDia"
                                  Property="Hora"
                                  Title="Hora"
                                  Width="100px"/>
            <RadzenDataGridColumn TItem="HoraDelDia"
                                  Property="Evento"
                                  Title="Evento"/>
        </Columns>
    </RadzenDataGrid>

</RadzenCard>

<!-- AVISOS RECIENTES -->
<RadzenCard Style="
    border-radius:12px;
    box-shadow:0 2px 6px rgba(0,0,0,0.1);">

    <RadzenText Text="Avisos recientes"
                Style="font-size:20px; font-weight:600; margin-bottom:10px;"/>

    <RadzenListView Data="@AvisosRecientes" TItem="string">
        <Template Context="aviso">
            <RadzenText Text="@($"• {AvisosRecientes}")"/>
        </Template>
    </RadzenListView>

</RadzenCard>

@code {
    
    string VeterinarioNombre = "Dr. Pérez";
    string ClinicaNombre = "Clínica PetCare";

    int TotalMascotas = 128;
    int TotalDuenos = 87;
    int CitasHoy = 12;
    int ProductosStock = 54;

    public class HoraDelDia
    {
        public string Hora { get; set; }
        public string Evento { get; set; }
    }

    List<HoraDelDia> HorasDelDia = new();

    List<string> AvisosRecientes = new()
    {
        "💉 Nueva vacuna disponible contra la rabia.",
        "🕐 Horario extendido los sábados hasta las 6 p.m.",
        "🎉 Promoción: 20% en baños medicados durante noviembre."
    };

    protected override void OnInitialized()
    {
        for (int h = 8; h <= 20; h++)
        {
            HorasDelDia.Add(new HoraDelDia
            {
                Hora = $"{h}:00",
                Evento = ""
            });
        }
    }
}



