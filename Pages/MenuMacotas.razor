@page "/MenuMacotas"
<RadzenBody>
<RadzenColumn Size="12" SizeMD="4">
    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Mascotas</RadzenText>
    <RadzenTextBox @bind-Value="searchText" Placeholder="Buscar..." Style="width: 100%" />

    @if (!string.IsNullOrEmpty(searchText) && 
         searchText.Contains("rocky", StringComparison.OrdinalIgnoreCase))
    {
        <!-- TARJETA DEL DUEÑO -->
        <RadzenCard Style="margin-top:20px; border-radius:16px; 
                          box-shadow:0 4px 20px rgba(0,0,0,0.1); 
                          overflow:hidden; 
                          background:linear-gradient(135deg, #f9fafb 0%, #eef3f9 100%);">

            <div style="display:flex; align-items:center; padding:20px; 
                        background:linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); 
                        color:white;">

                <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/616/616408.png"
                              Size="70px"
                              Style="margin-right:15px; border:3px solid white;" />

                <div>

                    <RadzenLink Path="/PerfilDueno"
                                Style="text-decoration:none; color:white;">
                        <span style="font-size:22px; font-weight:600;">Manolo</span>
                    </RadzenLink>

                    <RadzenText Text="Cliente desde 2021"
                                Style="opacity:0.9; font-size:13px; display:block;" />
                </div>
            </div>

            <!-- TARJETA DE MASCOTA -->
            <RadzenCard Style="margin-top:20px; border-radius:16px; 
                               box-shadow:0 4px 20px rgba(0,0,0,0.1); overflow:hidden; 
                               background:linear-gradient(135deg, #f9fafb 0%, #eef3f9 100%);">

                <div style="display:flex; align-items:center; padding:20px; 
                            background:linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%); 
                            color:white;">
                    
                    <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png" 
                                  Size="70px" 
                                  Style="margin-right:15px; border:3px solid white;" />
                    
                    <div>

                        <RadzenLink Path="/PerfilMascota"
                                    Style="text-decoration:none; color:white;">
                            <span style="font-size:22px; font-weight:600;">Rocky</span>
                        </RadzenLink>

                        <RadzenText Text="Cliente desde 2021"
                                    Style="opacity:0.9; font-size:13px; display:block;" />
                    </div>
                </div>

                <div style="padding:20px;">
                    <RadzenRow>
                        <RadzenColumn Size="6">
                            <RadzenLabel Text="🐾 Especie:" Style="color:#007bff; font-weight:600;" />
                            <RadzenText Text=" Perro" Style="margin-left:5px; color:#333;" />
                            <br />

                            <RadzenLabel Text="🐶 Raza:" Style="color:#007bff; font-weight:600;" />
                            <RadzenText Text=" Labrador" Style="margin-left:5px; color:#333;" />
                        </RadzenColumn>

                        <RadzenColumn Size="6">
                            <RadzenLabel Text="🎂 Edad:" Style="color:#007bff; font-weight:600;" />
                            <RadzenText Text=" 3 años" Style="margin-left:5px; color:#333;" />
                            <br />

                            <RadzenLabel Text="❤️ Notas de salud:" Style="color:#007bff; font-weight:600;" />
                            <RadzenText Text=" Vacunas al día, muy activo." 
                                        Style="margin-left:5px; color:#333;" />
                        </RadzenColumn>
                    </RadzenRow>
                </div>
            </RadzenCard>

        </RadzenCard>
    }

</RadzenColumn>
</RadzenBody>

@code {
    string searchText = "";

    Mascota mascota = new Mascota();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }
}
