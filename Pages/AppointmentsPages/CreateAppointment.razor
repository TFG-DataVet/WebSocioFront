@page "/CreateAppointment"
@using SocioWeb.ViewModels.Appointments

@inject NavigationManager Nav
@inject CreateAppointmentViewModel VM

@if (VM.IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" />
}

<RadzenCard Style="border-radius:14px; overflow:hidden;width:100%; margin:auto;">

    <!-- HEADER BONITO -->
    <div style="background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%);
                padding:2rem; color:white;">

        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween">

            <RadzenStack Orientation="Orientation.Horizontal" Gap="15" AlignItems="AlignItems.Center">
                
                <RadzenCard Style="width:70px; height:70px; border-radius:50%;
                                   background:rgba(255,255,255,0.25);
                                   display:flex; align-items:center; justify-content:center;
                                   font-size:32px;">
                    🐶
                </RadzenCard>

                <RadzenStack Gap="2">
                    <RadzenText Text="Nueva cita veterinaria"
                                Style="font-size:22px; font-weight:700;" />
                    <RadzenText Text="Completa la información de la cita"
                                Style="font-size:13px; opacity:0.85;" />
                </RadzenStack>

            </RadzenStack>

            <RadzenButton Icon="close"
                          ButtonStyle="ButtonStyle.Light"
                          Style="border-radius:10px;"
                          Click="@(() => Nav.NavigateTo("/Citas"))" />
        </RadzenStack>
    </div>

    <!-- CONTENIDO -->
    <div style="padding:2rem;">

        <RadzenText Text="Información de la cita"
                    Style=" font-size:18px; font-weight:600; margin-bottom:1.5rem;" />

        <RadzenRow Gap="20">

            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Mascota", VM.Appointment.PetName, v => VM.Appointment.PetName = v)
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Dueño", VM.Appointment.OwnerName, v => VM.Appointment.OwnerName = v)
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                @Campo("Teléfono", VM.Appointment.Phone, v => VM.Appointment.Phone = v)
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenStack Gap="5">
                    <RadzenText Text="Estado" />

                    <RadzenDropDown Data="@states"
                                    @bind-Value="VM.Appointment.Status"
                                    Style="width:100%; border-radius:10px;" />
                </RadzenStack>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenStack Gap="5">
                    <RadzenText Text="Fecha y hora" />

                    <RadzenDatePicker @bind-Value="VM.Appointment.Date"
                                      ShowTime="true"
                                      Style="width:100%; border-radius:10px;" />
                </RadzenStack>
            </RadzenColumn>

            <RadzenColumn Size="12">
                @Campo("Motivo", VM.Appointment.Reason, v => VM.Appointment.Reason = v)
            </RadzenColumn>

        </RadzenRow>

        <!-- BOTÓN -->
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:2rem;">
            <RadzenButton Text="Crear cita"
                          Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="background:#f7971e; border:none; border-radius:10px;"
                          Click="@OnSave" />
        </RadzenStack>

    </div>
</RadzenCard>

@code {

    List<string> states = new() { "Pendiente", "Confirmada", "Cancelada" };

    async Task OnSave()
    {
        await VM.SaveAsync();

        if (!VM.HasError)
            Nav.NavigateTo("/Calendario");
    }

    RenderFragment Campo(string label, string? valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;" />

            <RadzenTextBox Value="@valor"
                           Change="@(e => onChange?.Invoke(e?.ToString() ?? ""))"
                           Style="width:100%; border-radius:10px;" />
        </RadzenStack>;
    };
}