@page "/PerfilMascota"
@using global::SocioWeb.Domain.Entities

@inject NavigationManager Nav

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0">
            <RadzenSidebarToggle Click="@(() => sidebar1Expanded = !sidebar1Expanded)" />
            <RadzenText> Header </RadzenText>
        </RadzenStack>
    </RadzenHeader>

    <RadzenSidebar @bind-Expanded="@sidebar1Expanded">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Home" Icon="home" Path="/home" />
            <RadzenPanelMenuItem Text="Dueños" Icon="account_box" Path="/duenos" />
            <RadzenPanelMenuItem Text="Mascotas" Icon="pets" Path="/mascotas" />
            <RadzenPanelMenuItem Text="Citas" Icon="event_note" Path="/citas" />
            <RadzenPanelMenuItem Text="Productos" Icon="store" Path="/productos" />
            <RadzenPanelMenuItem Text="Calendario" Icon="event" Path="/calendario" />
        </RadzenPanelMenu>
    </RadzenSidebar>

    <RadzenBody>
        <RadzenCard>

            <!-- Cabecera -->
            <div style="display:flex; gap:25px; align-items:center; margin-bottom:30px;">
                <div style="
                    width:120px; height:120px; border-radius:50%;
                    background:#d9d9d9; display:flex; align-items:center;
                    justify-content:center; font-size:50px; color:#6c6c6c;">
                    🐾
                </div>

                <div>
                    <h2 style="margin:0; color:#333;">@mascota.Nombre</h2>
                    <h4 style="margin:5px 0; color:#777;">Mascota registrada</h4>

                    @if (!isEditing)
                    {
                        <RadzenButton Text="Editar perfil" Icon="edit"
                                      Style="margin-right:10px; border-radius:10px;"
                                      Click="@(() => isEditing = true)" />
                    }
                    else
                    {
                        <RadzenButton Text="Cancelar" Icon="close"
                                      Style="margin-right:10px; border-radius:10px;"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Click="@Cancelar" />
                    }

                    <RadzenButton Text="Ver dueño" Icon="account_box"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Style="border-radius:10px; background:#4b3e48; color:white;"
                                  Click="@VerDueno" />
                </div>
            </div>

            <!-- Info mascota -->
            <h3 style="color:#4b3e48; margin-bottom:20px;">Información de la mascota</h3>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:25px; padding:10px;">

                @Campo("Nombre", mascota.Nombre, v => mascota.Nombre = v)
                @Campo("Especie", mascota.Especie, v => mascota.Especie = v)
                @Campo("Raza", mascota.Raza, v => mascota.Raza = v)
                <select @bind="mascota.Sexo" class="form-select">
                    @foreach (var sexo in Enum.GetValues(typeof(Sexo)))
                    {
                        <option value="@sexo">@sexo</option>
                    }
                </select>


                @Campo("Fecha nacimiento", mascota.FechaDeNacimiento.ToShortDateString(),
                       v => mascota.FechaDeNacimiento = DateTime.Parse(v))
                
                @Campo("Peso (kg)", mascota.Peso.ToString(), 
                       v => mascota.Peso = int.Parse(v))
                @Campo("Número chip", mascota.ChipIdentificatorio, v => mascota.ChipIdentificatorio = v)
                @Campo("Operaciones", mascota.CualesOperaciones, v => mascota.CualesOperaciones = v)
                @Campo("Enfermedades", mascota.CualesEnfermedades, v => mascota.CualesEnfermedades = v)
                @Campo("Vacunas", mascota.CualesVacunas, v => mascota.CualesVacunas = v)
            </div>

            <hr style="margin:30px 0;" />

            <!-- Auditoría -->
            <h3 style="color:#4b3e48; margin-bottom:20px;">Registro del sistema</h3>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:25px;">
                @Campo("Creado el", mascota.CreatedAt.ToLocalTime().ToString(), null)
                @Campo("Última actualización", mascota.UpdatedAt?.ToLocalTime().ToString(), null)
            </div>

            @if (isEditing)
            {
                <div style="margin-top:30px; text-align:right;">
                    <RadzenButton Text="Guardar cambios"
                                  Icon="save"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Style="background:#4b3e48; color:white; border-radius:10px;"
                                  Click="@Guardar" />
                </div>
            }

        </RadzenCard>
    </RadzenBody>
</RadzenLayout>

@code {
    bool sidebar1Expanded = true;
    bool isEditing = false;

    Mascota mascota = new()
    {
        Nombre = "Toby",
        Especie = "Perro",
        Raza = "Labrador",
        Sexo = Sexo.Macho,
        FechaDeNacimiento = new DateTime(2021, 05, 20),
        Peso = 24,
        ChipIdentificatorio = "CHIP123456789",
        CualesEnfermedades = "",
        CualesOperaciones = "",
        CualesVacunas = "",
        CreatedAt = DateTime.UtcNow,
        UpdatedAt = DateTime.UtcNow
    };

    void VerDueno()
    {
        Nav.NavigateTo("/PerfilDueno");
    }

    void Guardar()
    {
        mascota.UpdatedAt = DateTime.UtcNow;
        isEditing = false;
    }

    void Cancelar()
    {
        isEditing = false;
    }

    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <div>
            <label style="color:#777;">@label</label>

            @if (!isEditing)
            {
                <div style="font-size:18px; color:#333;">
                    @valor
                    <RadzenIcon Icon="edit" Style="font-size:18px; color:#aaa; margin-left:8px;" />
                </div>
            }
            else
            {
                if (onChange != null)
                {
                    <RadzenTextBox Value="@valor"
                                   Change="@(e => onChange(e.ToString()))"
                                   Style="width:100%; background:white; border-radius:10px;" />
                }
                else
                {
                    <div style="font-size:18px; color:#333;">@valor</div>
                }
            }
        </div>;
    };
}
