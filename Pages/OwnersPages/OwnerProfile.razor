@page "/PerfilDueno/{Id}"
@inject NavigationManager Nav
@inject OwnerProfileViewModel VM

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"/>
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage"/>
}

<RadzenCard>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="25"
                 AlignItems="AlignItems.Center" Style="margin-bottom:30px;">

        <RadzenCard Style="width:120px; height:120px; border-radius:50%; background:#d9d9d9;
                           display:flex; align-items:center; justify-content:center; font-size:50px;">
            🐶
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@($"{VM.Owner.Name} {VM.Owner.LastName}")"
                        Style="font-size:24px; font-weight:600; color:#333;"/>
            <RadzenText Text="Dueño registrado" Style="color:#777;"/>

            @if (!VM.IsEditing)
            {
                <RadzenButton Text="Editar perfil" Icon="edit"
                              Style="border-radius:10px;"
                              Click="@(() => VM.IsEditing = true)"/>
            }
            else
            {
                <RadzenButton Text="Cancelar" Icon="close"
                              ButtonStyle="ButtonStyle.Danger"
                              Style="border-radius:10px;"
                              Click="@VM.Cancel"/>
            }
        </RadzenStack>
    </RadzenStack>

    <RadzenText Text="Información personal"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre",                 VM.Owner.Name,                 v => VM.Owner.Name                 = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Apellido",               VM.Owner.LastName,              v => VM.Owner.LastName              = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Número Identificación",  VM.Owner.IdentificationNumber,  v => VM.Owner.IdentificationNumber  = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Email",                  VM.Owner.Email,                 v => VM.Owner.Email                 = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Teléfono",               VM.Owner.Phone,                 v => VM.Owner.Phone                 = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Calle",                  VM.Owner.Street,                v => VM.Owner.Street                = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Código Postal",          VM.Owner.PostalCode,            v => VM.Owner.PostalCode            = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Ciudad",                 VM.Owner.City,                  v => VM.Owner.City                  = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Estado de la app",       VM.Owner.StatusApp.ToString(),  null)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Comentarios",            VM.Owner.Coments,               v => VM.Owner.Coments               = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <RadzenText Text="Registro del sistema"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>
    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Creado el",            VM.Owner.CreatedAt.ToLocalTime().ToString(),   null)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Última actualización", VM.Owner.UpdatedAt?.ToLocalTime().ToString(),  null)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <RadzenText Text="Mascotas"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    @if (VM.Owner.Pet != null && VM.Owner.Pet.Any())
    {
        <RadzenCarousel Style="height:250px;">
            @foreach (var mascota in VM.Owner.Pet)
            {
                <RadzenCard Style="width:220px; margin:10px; cursor:pointer;"
                            Click="@(() => Nav.NavigateTo($"/PerfilMascota/{mascota.Id}"))">
                    <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png"
                                  Size="60px" Style="margin-bottom:10px;"/>
                    <RadzenText Text="@mascota.Name" Style="font-weight:600;"/>
                    <RadzenText Text="@($"Especie: {mascota.Specie}")" Style="font-size:12px; opacity:0.8;"/>
                    <RadzenText Text="@($"Raza: {mascota.Breed}")"     Style="font-size:12px; opacity:0.8;"/>
                    <RadzenText Text="@($"{mascota.Age} años")"        Style="font-size:12px; opacity:0.8;"/>
                </RadzenCard>
            }
        </RadzenCarousel>
    }
    else
    {
        <RadzenText Text="Sin mascotas registradas" Style="font-style:italic; color:#777;"/>
    }

    <RadzenDivider Style="margin:30px 0;"/>

    <RadzenText Text="Historial"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    @if (VM.Owner.Historic != null && VM.Owner.Historic.Any())
    {
        <RadzenDataList Data="@VM.Owner.Historic" TItem="LogEntry">
            <Template Context="log">
                <RadzenCard Style="margin-bottom:10px;">
                    <RadzenText Text="@($"{log.Date.ToLocalTime():g} - {log.Description}")"/>
                </RadzenCard>
            </Template>
        </RadzenDataList>
    }
    else
    {
        <RadzenText Text="Sin historial registrado" Style="font-style:italic; color:#777;"/>
    }

    @if (VM.IsEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios" Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="background:#4b3e48; color:white; border-radius:10px;"
                          Click="@(async () => await VM.SaveAsync())"/>
        </RadzenStack>
    }

</RadzenCard>

@code {
    [Parameter] public string Id { get; set; } = "";

    protected override async Task OnInitializedAsync() => await VM.LoadAsync(Id);
    
    RenderFragment Campo(string label, string? valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;"/>
            @if (!VM.IsEditing)
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))"
                               Style="width:100%; background:white; border-radius:10px;"/>
            }
            else
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
            }
        </RadzenStack>;
    };
}