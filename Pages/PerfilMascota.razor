@page "/PerfilMascota/{Id}"
@inject NavigationManager Nav

<RadzenLayout>
    <RadzenBody>
        <RadzenCard>

            <!-- CABECERA -->
            <RadzenStack Orientation="Orientation.Horizontal" Gap="25" AlignItems="AlignItems.Center" Style="margin-bottom:30px;">

                <RadzenCard Style="width:120px; height:120px; border-radius:50%; background:#d9d9d9; display:flex; align-items:center; justify-content:center; font-size:50px; color:#6c6c6c;">
                    🐾
                </RadzenCard>

                <RadzenStack Gap="5">
                    <RadzenText Text="@mascota.Nombre" Style="font-size:24px; font-weight:600; color:#333;" />
                    <RadzenText Text="Mascota registrada" Style="color:#777;" />

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10">
                        @if (!isEditing)
                        {
                            <RadzenButton Text="Editar perfil" Icon="edit" Style="border-radius:10px;" Click="@(() => isEditing = true)" />
                        }
                        else
                        {
                            <RadzenButton Text="Cancelar" Icon="close" ButtonStyle="ButtonStyle.Danger" Style="border-radius:10px;" Click="@Cancelar" />
                        }

                        <RadzenButton Text="Ver dueño" Icon="account_box" ButtonStyle="ButtonStyle.Primary" Style="border-radius:10px; background:#4b3e48; color:white;" Click="@VerDueno" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenStack>

            <!-- INFORMACIÓN GENERAL -->
            <RadzenText Text="Información de la mascota" Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;" />

            <RadzenRow Gap="25">
                <RadzenColumn Size="6">@Campo("Nombre", mascota.Nombre, v => mascota.Nombre = v)</RadzenColumn>
                <RadzenColumn Size="6">@Campo("Especie", mascota.Especie, v => mascota.Especie = v)</RadzenColumn>
                <RadzenColumn Size="6">@Campo("Raza", mascota.Raza, v => mascota.Raza = v)</RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenStack Gap="5">
                        <RadzenText Text="Sexo" Style="color:#777;" />
                        @if (!isEditing)
                        {
                            <RadzenText Text="@mascota.Sexo.ToString()" Style="font-size:18px; color:#333;" />
                        }
                        else
                        {
                            <RadzenDropDown TValue="Sexo" Data="@(Enum.GetValues(typeof(Sexo)))" @bind-Value="mascota.Sexo" Style="width:100%; border-radius:10px;" />
                        }
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6">@Campo("Fecha nacimiento", mascota.FechaDeNacimiento.ToShortDateString(), v => mascota.FechaDeNacimiento = DateTime.Parse(v))</RadzenColumn>
                <RadzenColumn Size="6">@Campo("Peso (kg)", mascota.Peso.ToString(), v => mascota.Peso = int.Parse(v))</RadzenColumn>
                <RadzenColumn Size="6">@Campo("Número chip", mascota.ChipIdentificatorio, v => mascota.ChipIdentificatorio = v)</RadzenColumn>
            </RadzenRow>

            
            <!-- AUDITORÍA -->
            <RadzenDivider Style="margin:30px 0;" />
            <RadzenText Text="Registro del sistema" Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;" />
            <RadzenRow Gap="25">
                <RadzenColumn Size="6">@Campo("Creado el", mascota.CreatedAt.ToLocalTime().ToString(), null)</RadzenColumn>
                <RadzenColumn Size="6">@Campo("Última actualización", mascota.UpdatedAt?.ToLocalTime().ToString(), null)</RadzenColumn>
            </RadzenRow>
            
           <!-- HISTORIAL MÉDICO FORMAL -->
<RadzenDivider Style="margin:30px 0;" />

<RadzenCard Style="margin-top:20px; background:#f9f9f9; border-radius:12px; padding:20px;">

    <!-- Título y botones -->
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <RadzenText Text="Historial médico" Style="font-size:18px; font-weight:600; color:#4b3e48;" />

        @if (!isEditingHistorial)
        {
            <RadzenButton Text="Editar historial" Icon="edit" ButtonStyle="ButtonStyle.Primary" Style="border-radius:10px;" Click="@(() => isEditingHistorial = true)" />
        }
        else
        {
            <RadzenStack Orientation="Orientation.Horizontal" Gap="10">
                <RadzenButton Text="Guardar" Icon="save" ButtonStyle="ButtonStyle.Primary" Style="background:#4b3e48; color:white; border-radius:10px;" Click="@GuardarHistorial" />
                <RadzenButton Text="Cancelar" Icon="close" ButtonStyle="ButtonStyle.Danger" Style="border-radius:10px;" Click="@(() => isEditingHistorial = false)" />
            </RadzenStack>
        }
    </RadzenStack>

    <!-- Formulario vertical -->
    <RadzenStack Gap="20" Style="margin-top:15px;">

        <!-- Operaciones -->
        <RadzenStack Gap="5">
            <RadzenText Text="Operaciones" Style="font-weight:600; color:#4b3e48;" />
            <div style="max-height:120px; overflow-y:auto; border:1px solid #ccc; padding:5px; border-radius:5px;">
                @if (isEditingHistorial)
                {
                    <RadzenTextBox @bind-Value="mascota.CualesOperaciones" Style="width:100%; border:none; padding:2px;" Placeholder="Agregar operaciones..." />
                }
                else
                {
                    @foreach (var log in (mascota.CualesOperaciones?.Split('\n') ?? new string[0]))
                    {
                        <div style="margin-bottom:4px;">• @log</div>
                    }
                }
            </div>
        </RadzenStack>

        <RadzenDivider />

        <!-- Enfermedades -->
        <RadzenStack Gap="5">
            <RadzenText Text="Enfermedades" Style="font-weight:600; color:#4b3e48;" />
            <div style="max-height:120px; overflow-y:auto; border:1px solid #ccc; padding:5px; border-radius:5px;">
                @if (isEditingHistorial)
                {
                    <RadzenTextBox @bind-Value="mascota.CualesEnfermedades" Style="width:100%; border:none; padding:2px;" Placeholder="Agregar enfermedades..." />
                }
                else
                {
                    @foreach (var log in (mascota.CualesEnfermedades?.Split('\n') ?? new string[0]))
                    {
                        <div style="margin-bottom:4px;">• @log</div>
                    }
                }
            </div>
        </RadzenStack>

        <RadzenDivider />

        <!-- Vacunas -->
        <RadzenStack Gap="5">
            <RadzenText Text="Vacunas" Style="font-weight:600; color:#4b3e48;" />
            <div style="max-height:120px; overflow-y:auto; border:1px solid #ccc; padding:5px; border-radius:5px;">
                @if (isEditingHistorial)
                {
                    <RadzenTextBox @bind-Value="mascota.CualesVacunas" Style="width:100%; border:none; padding:2px;" Placeholder="Agregar vacunas..." />
                }
                else
                {
                    @foreach (var log in (mascota.CualesVacunas?.Split('\n') ?? new string[0]))
                    {
                        <div style="margin-bottom:4px;">• @log</div>
                    }
                }
            </div>
        </RadzenStack>

    </RadzenStack>
</RadzenCard>



            @if (isEditing)
            {
                <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
                    <RadzenButton Text="Guardar cambios" Icon="save" ButtonStyle="ButtonStyle.Primary" Style="background:#4b3e48; color:white; border-radius:10px;" Click="@Guardar" />
                </RadzenStack>
            }

        </RadzenCard>
    </RadzenBody>
</RadzenLayout>

@code {
    [Parameter] public string Id { get; set; } = "";

    bool isEditing = false;
    bool isEditingHistorial = false;
    Mascota mascota = new Mascota();

    protected override void OnInitialized()
    {
        if (Id == "M1")
        {
            mascota = new Mascota
            {
                Nombre = "Toby",
                Especie = "Perro",
                Raza = "Labrador",
                Sexo = Sexo.Macho,
                FechaDeNacimiento = new DateTime(2021, 05, 20),
                Peso = 24,
                ChipIdentificatorio = "CHIP123456789",
                CualesEnfermedades = "Ninguna",
                CualesOperaciones = "Castrado",
                CualesVacunas = "Rabia, Parvovirus",
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow,
                Dueno = new Dueno { Id = "1", Name = "Juan Pérez", Email = "juan@email.com", Phone = "123456789" }
            };
        }
        else
        {
            mascota = new Mascota
            {
                Nombre = "Desconocida",
                Especie = "-",
                Raza = "-",
                Sexo = Sexo.Macho,
                FechaDeNacimiento = DateTime.Now,
                Peso = 0,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };
        }
    }

    void VerDueno() => Nav.NavigateTo($"/PerfilDueno/{mascota.Dueno?.Id}");

    void Guardar()
    {
        mascota.UpdatedAt = DateTime.UtcNow;
        isEditing = false;
    }

    void Cancelar() => isEditing = false;

    void GuardarHistorial()
    {
        // Aquí guardas en la base de datos si es necesario
        isEditingHistorial = false;
    }

    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;" />

            @if (!isEditing)
            {
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8">
                    <RadzenText Text="@valor" Style="font-size:18px; color:#333;" />
                    <RadzenIcon Icon="edit" Style="font-size:18px; color:#aaa;" />
                </RadzenStack>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor" Change="@(e => onChange(e.ToString()))" Style="width:100%; background:white; border-radius:10px;" />
            }
            else
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;" />
            }
        </RadzenStack>;
    };
}
