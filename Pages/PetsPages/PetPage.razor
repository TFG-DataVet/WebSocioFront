@page "/create-pet"
@page "/edit-pet/{Id}"
@using SocioWeb.ViewModels.Pets
@using SocioWeb.Domain.Entities
@inject NavigationManager Nav
@inject PetPageVM VM
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true"
                 Style="margin-bottom:1rem;" />
}

<!-- BREADCRUMB -->
<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6"
             Style="margin-bottom:1.5rem;">
    <RadzenLink Path="/Mascotas" Text="Mascotas" Style="color:#7F77DD; font-size:13px;" />
    <RadzenText Text="/" Style="font-size:13px;" />
    <RadzenText Text="@(IsEditing ? "Editar mascota" : "Nueva mascota")" Style="font-size:13px;" />
</RadzenStack>

<RadzenCard Style="border-radius:14px; overflow:hidden; width:100%;">

    <!-- HEADER -->
    <div style="background: linear-gradient(135deg, #1D9E75 0%, #0F6E56 100%);
                padding:1.75rem 2rem; color:white;">
        <RadzenText Text="@(IsEditing ? "✏️ Editar Mascota" : "🐾 Registrar Mascota")"
                    Style="font-size:20px; font-weight:700; color:white; margin:0;" />
        <RadzenText Text="@(IsEditing ? "Modifica los datos de la mascota" : "Completa la información para registrar una nueva mascota")"
                    Style="font-size:13px; opacity:0.85; color:white; margin-top:4px;" />
    </div>

    <div style="padding:2rem;">
        <RadzenTemplateForm TItem="PetPageVM.PetFormModel" Data="@VM.FormData" Submit="@OnSubmit">

            <!-- ── INFORMACIÓN GENERAL ──────────────────────────── -->
            <div style="margin-bottom:2rem;">
                @SectionBar("#1D9E75", "Información general")

                <RadzenRow Gap="20">

                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">
                                Nombre <span style="color:#E24B4A;">*</span>
                            </label>
                            <RadzenTextBox Name="Name" @bind-Value="VM.FormData.Name"
                                           Placeholder="Nombre de la mascota" Style="width:100%;" />
                            <RadzenRequiredValidator Component="Name" Text="El nombre es obligatorio." />
                        </div>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">
                                Especie <span style="color:#E24B4A;">*</span>
                            </label>
                            <RadzenDropDown Name="Species"
                                            Data="@VM.SpeciesOptions"
                                            @bind-Value="VM.FormData.Species"
                                            Change="@VM.OnSpeciesChanged"
                                            Placeholder="Selecciona una especie"
                                            Style="width:100%;" />
                            <RadzenRequiredValidator Component="Species" Text="La especie es obligatoria." />
                        </div>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">
                                Raza <span style="color:#E24B4A;">*</span>
                            </label>
                            <RadzenDropDown Name="Breed"
                                            Data="@VM.CurrentBreeds"
                                            @bind-Value="VM.FormData.Breed"
                                            Placeholder="Selecciona una raza"
                                            Style="width:100%;" />
                            <RadzenRequiredValidator Component="Breed" Text="La raza es obligatoria." />
                        </div>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">Sexo</label>
                            <RadzenDropDown TValue="Sex?"
                                            Data="@(Enum.GetValues(typeof(Sex)))"
                                            @bind-Value="VM.FormData.Sex"
                                            Placeholder="Selecciona el sexo"
                                            Style="width:100%;" />
                        </div>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">Fecha de nacimiento</label>
                            <RadzenDatePicker TValue="DateTime?"
                                              @bind-Value="VM.FormData.DateOfBirth"
                                              DateFormat="dd/MM/yyyy"
                                              Placeholder="dd/mm/aaaa"
                                              Style="width:100%;" />
                        </div>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">Número de chip</label>
                            <RadzenTextBox @bind-Value="VM.FormData.ChipNumber"
                                           Placeholder="Ej: 985112345678901"
                                           Style="width:100%;" />
                        </div>
                    </RadzenColumn>

                    <RadzenColumn Size="12">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">URL de avatar</label>
                            <RadzenTextBox @bind-Value="VM.FormData.AvatarUrl"
                                           Placeholder="https://ejemplo.com/imagen.jpg"
                                           Style="width:100%;" />
                        </div>
                    </RadzenColumn>

                </RadzenRow>
            </div>

            <!-- ── DUEÑO ─────────────────────────────────────────── -->
            <div style="margin-bottom:2rem;">
                @SectionBar("#7F77DD", "Dueño de la mascota")

                <RadzenRow Gap="20">

                    <!-- Buscador por nombre / DNI -->
                    <RadzenColumn Size="12">
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; font-weight:500;">
                                Buscar dueño <span style="color:#E24B4A;">*</span>
                            </label>
                            <RadzenDropDown TValue="string"
                                            Name="OwnerId"
                                            Data="@VM.Owners"
                                            Value="@VM.FormData.Owner.OwnerId"
                                            ValueChanged="@VM.OnOwnerSelected"
                                            ValueProperty="Id"
                                            TextProperty="SearchLabel"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            FilterOperator="StringFilterOperator.Contains"
                                            Placeholder="@(VM.LoadingOwners ? "Cargando dueños…" : "Busca por nombre o DNI…")"
                                            Disabled="@VM.LoadingOwners"
                                            Style="width:100%;">
                                <Template Context="o">
                                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10"
                                                 AlignItems="AlignItems.Center">
                                        <RadzenAvatar Text="@(o.Name.Length > 0 ? o.Name[..1] : "?")"
                                                      Style="background:#7F77DD; color:white;
                                                             width:32px; height:32px; font-size:14px;" />
                                        <RadzenStack Gap="0">
                                            <span style="font-weight:600; font-size:14px;">@o.FullName</span>
                                            <span style="font-size:12px; color:#888;">
                                                @(o.IdentificationNumber ?? "Sin DNI") · @(o.Phone ?? "—")
                                            </span>
                                        </RadzenStack>
                                    </RadzenStack>
                                </Template>
                            </RadzenDropDown>
                            <RadzenRequiredValidator Component="OwnerId" Text="Selecciona un dueño." />
                        </div>
                    </RadzenColumn>

                    <!-- Resumen del dueño seleccionado -->
                    @if (!string.IsNullOrEmpty(VM.FormData.Owner.OwnerId))
                    {
                        <RadzenColumn Size="12">
                            <div style="background:#f5f4ff; border:1px solid #d0cdff;
                                        border-radius:10px; padding:1rem;">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="12"
                                             AlignItems="AlignItems.Center">
                                    <RadzenAvatar Text="@(VM.FormData.Owner.OwnerName?.Length > 0 ? VM.FormData.Owner.OwnerName[..1] : "?")"
                                                  Style="background:#7F77DD; color:white;
                                                         width:40px; height:40px; font-size:18px;" />
                                    <RadzenStack Gap="2">
                                        <RadzenText Text="@($"{VM.FormData.Owner.OwnerName} {VM.FormData.Owner.OwnerLastName}")"
                                                    Style="font-weight:600; font-size:15px;" />
                                        <RadzenText Text="@(VM.FormData.Owner.OwnerPhone ?? "—")"
                                                    Style="font-size:13px; color:#666;" />
                                    </RadzenStack>
                                </RadzenStack>
                            </div>
                        </RadzenColumn>
                    }

                </RadzenRow>
            </div>

            <!-- ── BOTONES ────────────────────────────────────────── -->
            <div style="padding-top:1rem; border-top:0.5px solid rgba(29,158,117,0.15);
                        display:flex; justify-content:flex-end; gap:10px;">
                <RadzenButton Text="Cancelar" Icon="close"
                              ButtonStyle="ButtonStyle.Light"
                              Style="border-radius:9px;"
                              Type="ButtonType.Button"
                              Click="@(() => Nav.NavigateTo(IsEditing ? $"/PerfilMascota/{Id}" : "/Mascotas"))" />
                <RadzenButton Text="@(IsEditing ? "Guardar cambios" : "Registrar mascota")"
                              Icon="@(IsEditing ? "save" : "pets")"
                              ButtonStyle="ButtonStyle.Primary"
                              Style="border-radius:9px;"
                              Type="ButtonType.Submit"
                              Disabled="@VM.IsSaving" />
            </div>

        </RadzenTemplateForm>
    </div>
</RadzenCard>

@code {
    [Parameter] public string? Id { get; set; }

    bool IsEditing => !string.IsNullOrEmpty(Id);

    protected override async Task OnInitializedAsync()
    {
        if (IsEditing)
            await VM.LoadForEditAsync(Id!);
        else
            await VM.InitAsync();
    }

    async Task OnSubmit()
    {
        if (IsEditing)
            await VM.UpdateAsync(Id!);
        else
            await VM.CreateAsync();

        StateHasChanged();

        if (!VM.HasError)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary  = IsEditing ? "Actualizado" : "Registrado",
                Detail   = IsEditing
                    ? "Los datos de la mascota se actualizaron correctamente."
                    : "La mascota fue registrada correctamente.",
                Duration = 3500
            });
            Nav.NavigateTo(IsEditing ? $"/PerfilMascota/{Id}" : "/Mascotas");
        }
    }

    RenderFragment SectionBar(string color, string title) => __builder =>
    {
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:1.25rem;
                    padding-bottom:0.75rem; border-bottom:0.5px solid rgba(0,0,0,0.08);">
            <div style="@($"width:3px; height:18px; background:{color}; border-radius:2px;")"></div>
            <span style="@($"font-size:13px; font-weight:500; letter-spacing:0.05em; text-transform:uppercase; color:{color};")"
            >@title</span>
        </div>;
    };
}
