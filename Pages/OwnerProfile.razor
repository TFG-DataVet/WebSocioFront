@page "/PerfilDueno/{Id}"
@inject NavigationManager Nav

<RadzenCard>

    <!-- CABECERA -->
    <RadzenStack Orientation="Orientation.Horizontal"
                 Gap="25"
                 AlignItems="AlignItems.Center"
                 Style="margin-bottom:30px;">

        <RadzenCard Style="
            width:120px;
            height:120px;
            border-radius:50%;
            background:#d9d9d9;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:50px;
            color:#6c6c6c;">
            🐶
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@($"{dueno.Name} {dueno.LastName}")"
                        Style="font-size:24px; font-weight:600; color:#333;"/>
            <RadzenText Text="Dueño registrado"
                        Style="color:#777;"/>

            @if (!isEditing)
            {
                <RadzenButton Text="Editar perfil"
                              Icon="edit"
                              Style="border-radius:10px;"
                              Click="@(() => isEditing = true)"/>
            }
            else
            {
                <RadzenButton Text="Cancelar"
                              Icon="close"
                              ButtonStyle="ButtonStyle.Danger"
                              Style="border-radius:10px;"
                              Click="@Cancelar"/>
            }
        </RadzenStack>
    </RadzenStack>

    <!-- INFORMACIÓN PERSONAL -->
    <RadzenText
        Text="Información personal"
        Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>
    
    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre", dueno.Name, v => dueno.Name = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Apellido", dueno.LastName, v => dueno.LastName = v)</RadzenColumn>
        <RadzenColumn
            Size="6">@Campo("Número Identificación", dueno.IdentificationNumber, v => dueno.IdentificationNumber = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Email", dueno.Email, v => dueno.Email = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Teléfono", dueno.Phone, v => dueno.Phone = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Calle", dueno.Street, v => dueno.Street = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Código Postal", dueno.PostalCode, v => dueno.PostalCode = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Ciudad", dueno.City, v => dueno.City = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Estado de la app", dueno.StatusApp.ToString(), null)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Comentarios", dueno.Coments, v => dueno.Coments = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <!-- AUDITORÍA -->
    <RadzenText 
        Text="Registro del sistema"
        Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">
            @Campo("Creado el", dueno.CreatedAt.ToLocalTime().ToString(), null)
        </RadzenColumn>
        <RadzenColumn Size="6">
            @Campo("Última actualización", dueno.UpdatedAt?.ToLocalTime().ToString(), null)
        </RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <!-- MASCOTAS -->
    <RadzenText 
        Text="Mascotas"
        Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    @if (dueno.Pet != null && dueno.Pet.Any())
    {
        <RadzenCarousel Style="height:250px;">
            @foreach (var mascota in dueno.Pet)
            {
                <RadzenCard Style="width:220px; margin:10px; cursor:pointer;"
                            Click="@(() => Nav.NavigateTo($"/Mascota/{mascota.Id}"))">

                    <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png"
                                  Size="60px"
                                  Style="margin-bottom:10px;"/>

                    <RadzenText Text="@mascota.Name" Style="font-weight:600;"/>
                    <RadzenText Text="@($"Especie: {mascota.Specie}")"
                                Style="font-size:12px; opacity:0.8;"/>
                    <RadzenText Text="@($"Raza: {mascota.Breed}")"
                                Style="font-size:12px; opacity:0.8;"/>
                    <RadzenText Text="@($"{mascota.Age} años")"
                                Style="font-size:12px; opacity:0.8;"/>
                </RadzenCard>
            }
        </RadzenCarousel>
    }
    else
    {
        <RadzenText 
            Text="Sin mascotas registradas"
            Style="font-style:italic; color:#777;"/>
    }

    <RadzenDivider Style="margin:30px 0;"/>

    <!-- HISTORIAL -->
    <RadzenText 
        Text="Historial"
        Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    @if (dueno.Historic != null && dueno.Historic.Any())
    {
        <RadzenDataList Data="@dueno.Historic" TItem="LogEntry">
            <Template Context="log">
                <RadzenCard Style="margin-bottom:10px;">
                    <RadzenText Text="@($"{log.Date.ToLocalTime():g} - {log.Description}")"/>
                </RadzenCard>
            </Template>
        </RadzenDataList>
    }
    else
    {
        <RadzenText 
            Text="Sin historial registrado"
            Style="font-style:italic; color:#777;"/>
    }

    @if (isEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton 
                Text="Guardar cambios"
                Icon="save"
                ButtonStyle="ButtonStyle.Primary"
                Style="background:#4b3e48; color:white; border-radius:10px;"
                Click="@Guardar"/>
            
        </RadzenStack>
    }

</RadzenCard>



@code {

    [Parameter] public string Id { get; set; }
    bool isEditing = false;

    // Datos de prueba usando tipos del dominio
    Dueno dueno = new Dueno
    {
        Name = "Juan",
        LastName = "Pérez",
        IdentificationNumber = "12345678X",
        Email = "carlos@email.com",
        Phone = "555-123456",
        Street = "Calle Mayor 22",
        PostalCode = "28001",
        City = "Madrid",
        Coments = "",
        StatusApp = StatusApp.Active,
        CreatedAt = DateTime.UtcNow,
        UpdatedAt = DateTime.UtcNow,
        Pet = new List<Domain.Entities.Pet>
        {
            new Domain.Entities.Pet { Id = "1", Name = "Rocky", Specie = "Perro", Breed = "Labrador", Age = 3 },
            new Domain.Entities.Pet { Id = "2", Name = "Luna", Specie = "Gato", Breed = "Siames", Age = 2 }
        },
        Historic = new List<LogEntry>
        {
            new LogEntry { Date = DateTime.UtcNow.AddDays(-3), Description = "Creación de perfil" },
            new LogEntry { Date = DateTime.UtcNow.AddDays(-1), Description = "Actualización de email" }
        }
    };

    void Guardar()
    {
        dueno.UpdatedAt = DateTime.UtcNow;
        isEditing = false;
    }

    void Cancelar()
    {
        isEditing = false;
    }

    // Componente reutilizable para mostrar/editar campos
    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;"/>

            @if (!isEditing)
            {
                <RadzenText Text="@valor"
                            Style="font-size:18px; color:#333;"/>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))"
                               Style="width:100%; background:white; border-radius:10px;"/>
            }
            else
            {
                <RadzenText Text="@valor"
                            Style="font-size:18px; color:#333;"/>
            }
        </RadzenStack>
        ;
    };

}
