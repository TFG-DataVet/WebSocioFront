@page "/create-pet"
@page "/edit-pet/{Id}"
@using SocioWeb.ViewModels.Pets
@using SocioWeb.Domain.Entities
@inject NavigationManager Nav
@inject PetPageVM VM
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true"
                 Style="margin-bottom:1rem;" />
}

<!-- BREADCRUMB -->
<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6"
             Style="margin-bottom:1rem;">
    <RadzenLink Path="/Duenos" Text="Dueños" Style="color:#4facfe; font-size:13px;" />
    <RadzenText Text="/" Style="color:#ccc; font-size:13px;" />
    <RadzenText Text="@(IsEditing ? "Editar mascota" : "Nueva mascota")"
                Style="font-size:13px; color:#666;" />
</RadzenStack>

<RadzenCard Style="border-radius:14px; overflow:hidden; max-width:900px; margin:auto;">

    <!-- HEADER -->
    <div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
                padding:2rem; color:white;">
        <RadzenText Text="@(IsEditing ? "✏️ Editar Mascota" : "🐾 Registrar Mascota")"
                    Style="font-size:22px; font-weight:700; color:white; margin:0;" />
        <RadzenText Text="@(IsEditing ? "Modifica los datos de la mascota" : "Completa la información para registrar una nueva mascota")"
                    Style="font-size:13px; opacity:0.85; color:white; margin-top:4px;" />
    </div>

    <div style="padding:2rem;">
        <RadzenTemplateForm TItem="PetPageVM.PetFormModel" Data="@VM.FormData" Submit="@OnSubmit">

    <!-- ───── INFORMACIÓN GENERAL ───── -->
    <RadzenFieldset Text="Información general" Style="margin-bottom:1.5rem;">
        <RadzenRow Gap="20">

            <!-- Nombre -->
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Nombre *">
                    <RadzenTextBox Name="Name" @bind-Value="VM.FormData.Name" Style="width:100%;" />
                    <RadzenRequiredValidator Component="Name" Text="El nombre es obligatorio." />
                </RadzenFormField>
            </RadzenColumn>

            <!-- Especie -->
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Especie *">
                    <RadzenDropDown Name="Species"
                                    Data="@VM.SpeciesOptions"
                                    @bind-Value="VM.FormData.Species"
                                    Change="@VM.OnSpeciesChanged"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="Species" Text="La especie es obligatoria." />
                </RadzenFormField>
            </RadzenColumn>

            <!-- Raza -->
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Raza *">
                    <RadzenDropDown Name="Breed"
                                    Data="@VM.CurrentBreeds"
                                    @bind-Value="VM.FormData.Breed"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="Breed" Text="La raza es obligatoria." />
                </RadzenFormField>
            </RadzenColumn>

            <!-- Sexo -->
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Sexo *">
                    <RadzenDropDown TValue="Sex?"
                                    Data="@(Enum.GetValues(typeof(Sex)))"
                                    @bind-Value="VM.FormData.Sex"
                                    Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <!-- Fecha nacimiento -->
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Fecha de nacimiento">
                    <RadzenDatePicker TValue="DateTime?"
                                      @bind-Value="VM.FormData.DateOfBirth"
                                      Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <!-- Chip -->
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Número de chip">
                    <RadzenTextBox @bind-Value="VM.FormData.ChipNumber"
                                   Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <!-- Avatar -->
            <RadzenColumn Size="12">
                <RadzenFormField Text="URL Avatar">
                    <RadzenTextBox @bind-Value="VM.FormData.AvatarUrl"
                                   Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

        </RadzenRow>
    </RadzenFieldset>

    <!-- ───── OWNER ───── -->
    <RadzenFieldset Text="Datos del dueño">
        <RadzenRow Gap="20">

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="ID dueño *">
                    <RadzenTextBox Name="OwnerId" @bind-Value="VM.FormData.Owner.OwnerId" Style="width:100%;" />
                    <RadzenRequiredValidator Component="OwnerId" Text="Obligatorio." />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Nombre *">
                    <RadzenTextBox Name="OwnerName" @bind-Value="VM.FormData.Owner.OwnerName" Style="width:100%;" />
                    <RadzenRequiredValidator Component="OwnerName" Text="Obligatorio." />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Apellidos *">
                    <RadzenTextBox Name="OwnerLastName" @bind-Value="VM.FormData.Owner.OwnerLastName" Style="width:100%;" />
                    <RadzenRequiredValidator Component="OwnerLastName" Text="Obligatorio." />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Teléfono *">
                    <RadzenTextBox Name="OwnerPhone" @bind-Value="VM.FormData.Owner.OwnerPhone" Style="width:100%;" />
                    <RadzenRequiredValidator Component="OwnerPhone" Text="Obligatorio." />
                </RadzenFormField>
            </RadzenColumn>

        </RadzenRow>
    </RadzenFieldset>

    <!-- BOTONES -->
    <RadzenStack Orientation="Orientation.Horizontal"
                 JustifyContent="JustifyContent.End"
                 Gap="10"
                 Style="margin-top:1.5rem;">

        <RadzenButton Text="Cancelar"
                      ButtonStyle="ButtonStyle.Light"
                      Click="@(() => Nav.NavigateTo("/Duenos"))" />

        <RadzenButton Text="Registrar mascota"
                      ButtonStyle="ButtonStyle.Primary"
                      Type="ButtonType.Submit"
                      Disabled="@VM.IsSaving" />
    </RadzenStack>

</RadzenTemplateForm>
    </div>
</RadzenCard>

@code {
    [Parameter] public string? Id { get; set; }

    bool IsEditing => !string.IsNullOrEmpty(Id);

    protected override async Task OnInitializedAsync()
    {
        if (IsEditing)
            await VM.LoadForEditAsync(Id!);
    }

    async Task OnSubmit()
    {
        if (IsEditing)
            await VM.UpdateAsync(Id!);
        else
            await VM.CreateAsync();

        StateHasChanged();

        if (!VM.HasError)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = IsEditing ? "Actualizado" : "Registrado",
                Detail  = IsEditing
                    ? "Los datos de la mascota se actualizaron correctamente."
                    : "La mascota fue registrada correctamente.",
                Duration = 3500
            });

            Nav.NavigateTo(IsEditing ? $"/PerfilMascota/{Id}" : "/Duenos");
        }
    }
}