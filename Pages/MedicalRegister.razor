@page "/MedicalRegister"

@using Radzen
@using Radzen.Blazor

<RadzenRow Style="height:100%">

    <!-- Menú horizontal arriba -->
    <RadzenColumn Size="12" Style="background:#f5f5f5; padding:5px 0;">
        <RadzenPanelMenu Style="border:none; display:flex; justify-content:space-around;">
            <RadzenPanelMenuItem Text="Consulta" Icon="medical_services"
                                 Click="() => SelectCase(MedicalCase.Consultation)" Style="flex:1; text-align:center;"/>
            <RadzenPanelMenuItem Text="Vacuna" Icon="vaccines"
                                 Click="() => SelectCase(MedicalCase.Vaccine)" Style="flex:1; text-align:center;"/>
            <RadzenPanelMenuItem Text="Tratamiento" Icon="healing"
                                 Click="() => SelectCase(MedicalCase.Treatment)" Style="flex:1; text-align:center;"/>
            <RadzenPanelMenuItem Text="Cirugía" Icon="content_cut"
                                 Click="() => SelectCase(MedicalCase.Surgery)" Style="flex:1; text-align:center;"/>
            <RadzenPanelMenuItem Text="Peso" Icon="monitor_weight"
                                 Click="() => SelectCase(MedicalCase.Weight)" Style="flex:1; text-align:center;"/>
            <RadzenPanelMenuItem Text="Diagnóstico" Icon="fact_check"
                                 Click="() => SelectCase(MedicalCase.Diagnosis)" Style="flex:1; text-align:center;"/>
            <RadzenPanelMenuItem Text="Alergia" Icon="report_problem"
                                 Click="() => SelectCase(MedicalCase.Allergy)" Style="flex:1; text-align:center;"/>
            <RadzenPanelMenuItem Text="Documento" Icon="description"
                                 Click="() => SelectCase(MedicalCase.Document)" Style="flex:1; text-align:center;"/>
        </RadzenPanelMenu>
    </RadzenColumn>

    <!-- Contenido debajo del menú -->
    <RadzenColumn Size="12" Style="padding:30px">
        <RadzenCard Style="max-width:900px; margin:auto;">
            <RadzenText Text="@Title" TextStyle="TextStyle.H6" Style="margin-bottom:20px"/>

            @switch (SelectedCase)
            {
                case MedicalCase.Consultation:
                    @ConsultationForm()
                    break;
                case MedicalCase.Vaccine:
                    @VaccineForm()
                    break;
                case MedicalCase.Treatment:
                    @TreatmentForm()
                    break;
                case MedicalCase.Surgery:
                    @SurgeryForm()
                    break;
                case MedicalCase.Weight:
                    @WeightForm()
                    break;
                case MedicalCase.Diagnosis:
                    @DiagnosisForm()
                    break;
                case MedicalCase.Allergy:
                    @AllergyForm()
                    break;
                case MedicalCase.Document:
                    @DocumentForm()
                    break;
            }
        </RadzenCard>
    </RadzenColumn>

</RadzenRow>


@code {

    Consultation consultation = new();
    Vaccine vaccine = new();
    Treatment treatment = new();
    Surgery surgery = new();
    WeightRecord weight = new();
    Diagnosis diagnosis = new();
    Allergy allergy = new();
    DocumentRecord document = new();


    MedicalCase SelectedCase = MedicalCase.Consultation;

    string Title => SelectedCase switch
    {
        MedicalCase.Consultation => "Registro de Consulta",
        MedicalCase.Vaccine => "Registro de Vacunación",
        MedicalCase.Treatment => "Registro de Tratamiento",
        MedicalCase.Surgery => "Registro de Cirugía",
        MedicalCase.Weight => "Control de Peso",
        MedicalCase.Diagnosis => "Registro de Diagnóstico",
        MedicalCase.Allergy => "Registro de Alergias",
        MedicalCase.Document => "Documentos Clínicos",
        _ => "Registro Médico"
    };

    void SelectCase(MedicalCase medicalCase)
    {
        SelectedCase = medicalCase;
    }

    RenderFragment ConsultationForm() => @<RadzenTemplateForm TItem="Consultation" Data="@consultation">
        <RadzenFieldset Text="Datos de la Consulta">
            <RadzenTextBox @bind-Value="consultation.Reason" Placeholder="Motivo de la consulta" Style="width:100%"/>
            <RadzenTextArea @bind-Value="consultation.Symptoms" Placeholder="Síntomas observados" Style="width:100%"/>
            <RadzenTextArea @bind-Value="consultation.PhysicalExam" Placeholder="Examen físico" Style="width:100%"/>
            <RadzenTextArea @bind-Value="consultation.Notes" Placeholder="Observaciones del veterinario"
                            Style="width:100%"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;


    RenderFragment VaccineForm() => @<RadzenTemplateForm TItem="Vaccine" Data="@vaccine">
        <RadzenFieldset Text="Vacunación">
            <RadzenTextBox @bind-Value="vaccine.VaccineName" Placeholder="Nombre de la vacuna" Style="width:100%"/>

            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="vaccine.ApplicationDate"
                              Placeholder="Fecha de aplicación"
                              Style="width:100%"/>

            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="vaccine.NextDoseDate"
                              Placeholder="Próxima dosis"
                              Style="width:100%"/>

            <RadzenTextBox @bind-Value="vaccine.BatchNumber" Placeholder="Número de lote" Style="width:100%"/>
            <RadzenTextBox @bind-Value="vaccine.Manufacturer" Placeholder="Fabricante" Style="width:100%"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;


    RenderFragment TreatmentForm() => @<RadzenTemplateForm TItem="Treatment" Data="@treatment">
        <RadzenFieldset Text="Tratamiento">

            <RadzenTextBox @bind-Value="treatment.TreatmentName"
                           Placeholder="Nombre del tratamiento"
                           Style="width:100%"/>

            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="treatment.StartDate"
                              Placeholder="Inicio del tratamiento"
                              Style="width:100%"/>

            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="treatment.EndDate"
                              Placeholder="Fin del tratamiento"
                              Style="width:100%"/>

            <RadzenTextArea @bind-Value="treatment.Instructions"
                            Placeholder="Indicaciones"
                            Style="width:100%"/>


            <RadzenCheckBox TValue="bool"
                            Value="treatment.FollowUpRequired"
                            Change="@((bool value) => treatment.FollowUpRequired = value)"/>
            <RadzenLabel Text="¿Requiere seguimiento?" Style="margin-left:5px"/>


            <RadzenFieldset Text="Medicamentos">

                @foreach (var medication in treatment.Medications)
                {
                    <RadzenFieldset Text="Medicamento" Style="margin-bottom:10px">

                        <RadzenTextBox @bind-Value="medication.Name"
                                       Placeholder="Medicamento"
                                       Style="width:100%"/>

                        <RadzenTextBox @bind-Value="medication.Dosage"
                                       Placeholder="Dosis"
                                       Style="width:100%"/>

                        <RadzenTextBox @bind-Value="medication.Frequency"
                                       Placeholder="Frecuencia"
                                       Style="width:100%"/>

                        <RadzenNumeric TValue="int?"
                                       @bind-Value="medication.DurationInDays"
                                       Placeholder="Duración (días)"
                                       Style="width:100%"/>

                        <RadzenTextArea @bind-Value="medication.Notes"
                                        Placeholder="Notas"
                                        Style="width:100%"/>

                    </RadzenFieldset>
                }
                
                <RadzenButton Text="Agregar medicamento"
                              Icon="add"
                              Click="@AddMedication"
                              Style="margin-top:10px"/>

            </RadzenFieldset>

        </RadzenFieldset>
    </RadzenTemplateForm>;

    void AddMedication()
    {
        treatment.Medications ??= new List<TreatmentMedication>();
        treatment.Medications.Add(new TreatmentMedication());
    }


  RenderFragment SurgeryForm() => @<RadzenTemplateForm TItem="Surgery" Data="@surgery">
        <RadzenFieldset Text="Cirugía">

            <RadzenTextBox @bind-Value="surgery.SurgeryName"
                           Placeholder="Nombre de la cirugía"
                           Style="width:100%" />

            <RadzenDropDown TValue="SurgeryType"
                            @bind-Value="surgery.SurgeryType"
                            Data="@Enum.GetValues(typeof(SurgeryType))"
                            Placeholder="Tipo de cirugía"
                            Style="width:100%" />

            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="surgery.SurgeryDate"
                              Placeholder="Fecha de cirugía"
                              Style="width:100%" />

            <RadzenDropDown TValue="SurgeryOutcome"
                            @bind-Value="surgery.Outcome"
                            Data="@Enum.GetValues(typeof(SurgeryOutcome))"
                            Placeholder="Resultado"
                            Style="width:100%" />

            <RadzenTextBox @bind-Value="surgery.AnesthesiaType"
                           Placeholder="Tipo de anestesia"
                           Style="width:100%" />

            <RadzenCheckBox TValue="bool"
                            Value="surgery.HospitalizationRequired"
                            Change="@((bool value) => surgery.HospitalizationRequired = value)" />
            <RadzenLabel Text="¿Requiere hospitalización?" Style="margin-left:5px" />

            <RadzenNumeric TValue="int?"
                           @bind-Value="surgery.HospitalizationDays"
                           Placeholder="Días de hospitalización"
                           Style="width:100%"
                           Disabled="@(!surgery.HospitalizationRequired)" />

            <RadzenCheckBox TValue="bool"
                            Value="surgery.FollowUpRequired"
                            Change="@((bool value) => surgery.FollowUpRequired = value)" />
            <RadzenLabel Text="¿Requiere seguimiento?" Style="margin-left:5px" />

            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="surgery.FollowUpDate"
                              Placeholder="Fecha de seguimiento"
                              Style="width:100%"
                              Disabled="@(!surgery.FollowUpRequired)" />

            <!-- Procedimientos realizados -->
            <RadzenFieldset Text="Procedimientos realizados">
                @foreach (var procedure in surgery.Procedures)
                {
                    <RadzenFieldset Text="Procedimiento" Style="margin-bottom:10px">
                        <RadzenTextBox @bind-Value="procedure.name"
                                       Placeholder="Nombre del procedimiento"
                                       Style="width:100%" />
                    </RadzenFieldset>
                }

                <RadzenButton Text="Agregar procedimiento"
                              Icon="add"
                              Click="@AddProcedure"
                              Style="margin-top:10px" />
            </RadzenFieldset>

            <!-- Medicamentos postoperatorios -->
            <RadzenFieldset Text="Medicamentos postoperatorios">
                @foreach (var med in surgery.PostOpMedications)
                {
                    <RadzenFieldset Text="Medicamento" Style="margin-bottom:10px">
                        <RadzenTextBox @bind-Value="med.Name"
                                       Placeholder="Nombre"
                                       Style="width:100%" />

                        <RadzenTextBox @bind-Value="med.Dosage"
                                       Placeholder="Dosis"
                                       Style="width:100%" />

                        <RadzenTextBox @bind-Value="med.Frequency"
                                       Placeholder="Frecuencia"
                                       Style="width:100%" />

                        <RadzenNumeric TValue="int?"
                                        @bind-Value="med.DurationInDays"
                                        Placeholder="Duración (días)"
                                        Style="width:100%" />

                        <RadzenTextArea @bind-Value="med.Notes"
                                        Placeholder="Notas"
                                        Style="width:100%" />
                    </RadzenFieldset>
                }

                <RadzenButton Text="Agregar medicamento"
                              Icon="add"
                              Click="@AddPostOpMedication"
                              Style="margin-top:10px" />
            </RadzenFieldset>

        </RadzenFieldset>
    </RadzenTemplateForm>;
  
    void AddProcedure()
    {
        surgery.Procedures ??= new List<SurgeryProcedure>();
        surgery.Procedures.Add(new SurgeryProcedure());
    }

    void AddPostOpMedication()
    {
        surgery.PostOpMedications ??= new List<SurgeryMedication>();
        surgery.PostOpMedications.Add(new SurgeryMedication());
    }


    RenderFragment WeightForm() => @<RadzenTemplateForm TItem="WeightRecord" Data="@weight">
        <RadzenFieldset Text="Control de Peso">

            <RadzenNumeric TValue="decimal"
                           @bind-Value="weight.WeightKg"
                           Placeholder="Peso (kg)"
                           Style="width:100%"/>

            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="weight.Date"
                              Placeholder="Fecha de medición"
                              Style="width:100%"/>

            <RadzenTextArea @bind-Value="weight.Notes" Placeholder="Observaciones" Style="width:100%"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;


    RenderFragment DiagnosisForm() => @<RadzenTemplateForm TItem="Diagnosis" Data="@diagnosis">
    <RadzenFieldset Text="Diagnóstico">
        
        <RadzenTextBox @bind-Value="diagnosis.DiagnosisName"
                       Placeholder="Nombre del diagnóstico"
                       Style="width:100%" />

        <RadzenDropDown @bind-Value="diagnosis.Category"
                        Data="@Enum.GetValues(typeof(DiagnosisCategory))"
                        TextProperty="Name"
                        ValueProperty="Value"
                        Placeholder="Categoría"
                        Style="width:100%" />

        <RadzenTextArea @bind-Value="diagnosis.Description"
                        Placeholder="Descripción"
                        Style="width:100%" />

        <RadzenDropDown @bind-Value="diagnosis.Severity"
                        Data="@Enum.GetValues(typeof(DiagnosisSeverity))"
                        Placeholder="Severidad"
                        Style="width:100%" />

        <RadzenDatePicker @bind-Value="diagnosis.DiagnosedAt"
                           DateFormat="dd/MM/yyyy"
                           Placeholder="Fecha de diagnóstico"
                           Style="width:100%" />

        <RadzenCheckBox @bind-Value="diagnosis.Chronic" />
        <RadzenLabel Text="Crónico" />

        <RadzenCheckBox @bind-Value="diagnosis.Contagious" />
        <RadzenLabel Text="Contagioso" />

        <RadzenTextArea @bind-Value="symptomsText"
                        Placeholder="Síntomas (separados por comas)"
                        Style="width:100%" />

        <RadzenTextArea @bind-Value="recommendationsText"
                        Placeholder="Recomendaciones (separadas por comas)"
                        Style="width:100%" />

        <RadzenCheckBox @bind-Value="diagnosis.FollowUpRequired" />
        <RadzenLabel Text="Requiere seguimiento" />

        <RadzenDatePicker @bind-Value="diagnosis.FollowUpDate"
                           DateFormat="dd/MM/yyyy"
                           Placeholder="Fecha de seguimiento"
                           Style="width:100%"
                           Disabled="@(!diagnosis.FollowUpRequired)" />

    </RadzenFieldset>
</RadzenTemplateForm>;

    private string symptomsText
    {
        get => string.Join(", ", diagnosis.Symptoms ?? new List<string>());
        set => diagnosis.Symptoms = value?
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim())
            .ToList();
    }

    private string recommendationsText
    {
        get => string.Join(", ", diagnosis.Recommendations ?? new List<string>());
        set => diagnosis.Recommendations = value?
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(r => r.Trim())
            .ToList();
    }

    RenderFragment AllergyForm() => @<RadzenTemplateForm TItem="Allergy" Data="@allergy">
        <RadzenFieldset Text="Alergias">
            <RadzenTextBox @bind-Value="allergy.Substance" Placeholder="Sustancia" Style="width:100%"/>
            <RadzenTextArea @bind-Value="allergy.Reaction" Placeholder="Reacción" Style="width:100%"/>
            <RadzenTextArea @bind-Value="allergy.Notes" Placeholder="Notas adicionales" Style="width:100%"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;


    RenderFragment DocumentForm() => @<RadzenTemplateForm TItem="DocumentRecord" Data="@document">
        <RadzenFieldset Text="Documentos">
            <RadzenTextBox @bind-Value="document.Title" Placeholder="Título del documento" Style="width:100%"/>
            <RadzenUpload ChooseText="Subir archivo"/>
            <RadzenTextArea @bind-Value="document.Description" Placeholder="Descripción" Style="width:100%"/>
        </RadzenFieldset>
    </RadzenTemplateForm>;


    enum MedicalCase
    {
        Consultation,
        Vaccine,
        Treatment,
        Surgery,
        Weight,
        Diagnosis,
        Allergy,
        Document
    }

}
