@page "/PerfilMascota/{Id}"
@using SocioWeb.ViewModels
@inject NavigationManager Nav

<RadzenCard>

    <!-- CABECERA -->
    <RadzenStack Orientation="Orientation.Horizontal" Gap="25">

        <RadzenCard Style="width:120px; height:120px; border-radius:50%;
                           background:#d9d9d9; display:flex;
                           align-items:center; justify-content:center;">
            🐾
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@vm.Pet.Name" Style="font-size:24px; font-weight:600;" />
            <RadzenText Text="Mascota registrada" Style="color:#777;" />

            <RadzenStack Orientation="Orientation.Horizontal" Gap="10">

                @if (!vm.IsEditing)
                {
                    <RadzenButton Text="Editar perfil"
                                  Icon="edit"
                                  Click="@vm.ToggleEdit" />
                }
                else
                {
                    <RadzenButton Text="Cancelar"
                                  Icon="close"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Click="@vm.CancelEdit" />
                }

                <RadzenButton Text="Ver dueño"
                              Click="@SeeOwner" />

                <RadzenButton Text="Registro médico"
                              Click="@MedicalRegister" />

            </RadzenStack>
        </RadzenStack>
    </RadzenStack>

    <RadzenDivider Style="margin:20px 0;" />

    <!-- INFORMACIÓN -->
    <RadzenRow Gap="20">

        <RadzenColumn Size="6">
            @Campo("Nombre", vm.Pet.Name, v => vm.Pet.Name = v)
        </RadzenColumn>

        <RadzenColumn Size="6">
            @Campo("Especie", vm.Pet.Specie, v => vm.Pet.Specie = v)
        </RadzenColumn>

        <RadzenColumn Size="6">
            @Campo("Raza", vm.Pet.Breed, v => vm.Pet.Breed = v)
        </RadzenColumn>

        <RadzenColumn Size="6">
            <RadzenStack Gap="5">
                <RadzenText Text="Sexo" />

                @if (!vm.IsEditing)
                {
                    <RadzenText Text="@vm.Pet.Sex.ToString()" />
                }
                else
                {
                    <RadzenDropDown TValue="Sex"
                                    Data="@(Enum.GetValues(typeof(Sex)))"
                                    @bind-Value="vm.Pet.Sex" />
                }
            </RadzenStack>
        </RadzenColumn>

    </RadzenRow>

    @if (vm.IsEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:20px;">
            <RadzenButton Text="Guardar cambios"
                          Icon="save"
                          Click="@vm.Save" />
        </RadzenStack>
    }

</RadzenCard>

@code {

    [Parameter] public string Id { get; set; } = "";

    private PetProfileVM vm = new();

    protected override void OnInitialized()
    {
        vm.Load(Id);
    }

    void SeeOwner()
        => Nav.NavigateTo($"/PerfilDueno/{vm.Pet.Owner?.Id}");

    void MedicalRegister()
        => Nav.NavigateTo("/MedicalRegister");

    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" />

            @if (!vm.IsEditing)
            {
                <RadzenText Text="@valor" />
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))" />
            }
        </RadzenStack>;
    };
}