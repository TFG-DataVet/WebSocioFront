@page "/Productos"
@inject NavigationManager Nav
@inject ProductListViewModel VM
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                       Style="margin-bottom:1rem;" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true" />
}

<PageTitle>Productos</PageTitle>

<!-- HEADER -->
<RadzenCard Style="
    background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    color: white;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(67,233,123,0.35);
    margin-bottom: 1.5rem;
    padding: 1.5rem 2rem;">
    
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Wrap="FlexWrap.Wrap"
                 Gap="10">

        <RadzenStack Gap="2">
            <RadzenText Text="Gestión de Productos"
                        Style="font-size:28px; font-weight:700;" />
            <RadzenText Text="@($"{VM.FilteredProducts.Count} registros encontrados")"
                        Style="font-size:18px; opacity:0.85;" />
        </RadzenStack>

        <RadzenButton Text="Nuevo Producto"
                      Icon="inventory_2"
                      Style="background:white; color:#43e97b; font-weight:600; border-radius:10px;"
                      Click="@(() => Nav.NavigateTo("/create-product"))" />
    </RadzenStack>
</RadzenCard>

<!-- FILTROS -->
<RadzenCard Style="border-radius:12px; margin-bottom:1.5rem; padding:1.2rem 1.5rem;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.End"
                 Wrap="FlexWrap.Wrap"
                 Gap="12">

        <RadzenStack Gap="4">
            <RadzenLabel Text="Desde" Style="font-size:16px; font-weight:600;" />
            <RadzenDatePicker @bind-Value="VM.DateSince" Style="width:155px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Hasta" Style="font-size:16px; font-weight:600;" />
            <RadzenDatePicker @bind-Value="VM.DateTo" Style="width:155px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Categoría" Style="font-size:16px; font-weight:600;" />
            <RadzenTextBox @bind-Value="VM.CategoryFilter" Style="width:140px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Marca" Style="font-size:16px; font-weight:600;" />
            <RadzenTextBox @bind-Value="VM.BrandFilter" Style="width:140px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Stock mínimo" Style="font-size:16px; font-weight:600;" />
            <RadzenNumeric @bind-Value="VM.MinimumStock" Style="width:120px" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8">
            <RadzenButton Icon="filter_alt" Text="Filtrar"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@VM.ApplyFilters" />
            <RadzenButton Icon="clear" Text="Limpiar"
                          ButtonStyle="ButtonStyle.Light"
                          Click="@VM.ClearFilters" />
        </RadzenStack>
    </RadzenStack>
</RadzenCard>

<!-- TABLA -->
<RadzenCard Style="border-radius:12px; padding:0; overflow:hidden;">
    <RadzenDataGrid Data="@VM.FilteredProducts"
                    TItem="Product"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="10"
                    ShowPagingSummary="true"
                    PagingSummaryFormat="Página {0} de {1} — Total: {2}"
                    EmptyText="No se encontraron productos."
                    Style="border:none;">

        <Columns>
            <!-- Producto -->
            <RadzenDataGridColumn TItem="Product" Title="Producto" Width="220px">
                <Template Context="product">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10">
                        <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/679/679720.png" Size="38" />
                        <RadzenStack Gap="0">
                            <RadzenText Text="@product.Name" Style="font-weight:600;" />
                            <RadzenText Text="@product.Category" Style="font-size:12px; color:#888;" />
                        </RadzenStack>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <!-- Marca -->
            <RadzenDataGridColumn TItem="Product" Property="Brand" Title="Marca" Width="130px" />

            <!-- Stock -->
            <RadzenDataGridColumn TItem="Product" Property="Stock" Title="Stock" Width="100px">
                <Template Context="product">
                    <RadzenText Text="@product.Stock" />
                </Template>
            </RadzenDataGridColumn>

            <!-- Precio -->
            <RadzenDataGridColumn TItem="Product" Property="Price" Title="Precio" Width="130px">
                <Template Context="product">
                    <RadzenText Text="@($"{product.Price:C}")" />
                </Template>
            </RadzenDataGridColumn>

            <!-- Fecha creación -->
            <RadzenDataGridColumn TItem="Product" Property="CreatedAt" Title="Alta" Width="130px">
                <Template Context="product">
                    <RadzenText Text="@product.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")" 
                                Style="font-size:13px; color:#666;" />
                </Template>
            </RadzenDataGridColumn>

            <!-- Acciones -->
            <RadzenDataGridColumn TItem="Product" Title="Acciones" Width="140px" Sortable="false">
                <Template Context="product">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6">
                        <RadzenButton Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small"
                                      Click="@(() => Nav.NavigateTo($"/PerfilProducto/{product.Id}"))" />
                        <RadzenButton Icon="edit"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Small"
                                      Click="@(() => Nav.NavigateTo($"/EditarProducto/{product.Id}"))" />
                        <RadzenButton Icon="delete"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Small"
                                      Click="@(async () => await ConfirmDelete(product))" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {
    protected override async Task OnInitializedAsync()
        => await VM.LoadAsync();

    async Task ConfirmDelete(Product product)
    {
        var result = await DialogService.Confirm(
            $"¿Eliminar a {product.Name}? Esta acción no se puede deshacer.",
            "Confirmar eliminación",
            new ConfirmOptions { OkButtonText = "Eliminar", CancelButtonText = "Cancelar" });

        if (result == true)
        {
            await VM.DeleteAsync(product.Id);

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Eliminado",
                Detail = $"{product.Name} fue eliminado correctamente.",
                Duration = 3000
            });
        }
    }
}