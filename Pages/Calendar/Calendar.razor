@page "/Calendario"

@inject NavigationManager Nav

<RadzenStack Gap="10" Style="padding:20px">

    <!-- HEADER -->
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Style="
                    padding:20px;
                    background: linear-gradient(135deg, #f8ff29 0%, #fef200 100%);
                    color: black;
                    border-radius:16px;
                    box-shadow:0 4px 20px rgba(0,0,0,0.1);">
        <RadzenText Text="Calendario de Citas"
                    TextStyle="TextStyle.H4"
                    Style="font-weight:600"/>

        <RadzenButton Text="Nueva Cita"
                      Icon="add_circle"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@CreateAppointment"/>
    </RadzenStack>

    <!-- CALENDARIO -->
    

        <RadzenScheduler TItem="Appointment"
                         Data="@appointments"
                         StartProperty="Start"
                         EndProperty="End"
                         TextProperty="PetName"
                         SelectedIndex="0"   
            SlotSelect="@OnSlotSelect"
            AppointmentSelect="@OnAppointmentSelect"
            Style="height:800px"> <!-- Más altura -->

            <RadzenDayView />
            <RadzenWeekView />
            <RadzenMonthView />
            <RadzenYearView />

        </RadzenScheduler>

  


</RadzenStack>

@code {
    

    List<Appointment> appointments = new();

    protected override void OnInitialized()
    {
        appointments = new List<Appointment>
        {
            new Appointment
            {
                Id = "1",
                PetName = "Firulais",
                OwnerName = "Juan Pérez",
                Phone = "555-1234",
                Start = DateTime.Today.AddHours(10),
                End = DateTime.Today.AddHours(11),
                Reason = "Vacunación",
                Status = "Pendiente"
            },

            new Appointment
            {
                Id = "2",
                PetName = "Michi",
                OwnerName = "Ana López",
                Phone = "555-9876",
                Start = DateTime.Today.AddDays(1).AddHours(16),
                End = DateTime.Today.AddDays(1).AddHours(17),
                Reason = "Control general",
                Status = "Confirmada"
            }
        };
    }

    void OnSlotSelect(SchedulerSlotSelectEventArgs args)
    {
        // Ir a crear cita con fecha seleccionada
        Nav.NavigateTo($"/CreateAppointment?date={args.Start:O}");
    }

    void OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<Appointment> args)
    {
        Nav.NavigateTo($"/AppointmentProfile/{args.Data.Id}");
    }

    void CreateAppointment()
    {
        Nav.NavigateTo("/CreateAppointment");
    }

    public class Appointment
    {
        public string Id { get; set; }
        public string PetName { get; set; }
        public string OwnerName { get; set; }
        public string Phone { get; set; }

        public DateTime Start { get; set; }
        public DateTime End { get; set; }

        public string Reason { get; set; }
        public string Status { get; set; }
    }
}
