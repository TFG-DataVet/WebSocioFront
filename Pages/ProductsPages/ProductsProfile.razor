@page "/PerfilProducto/{Id}"
@inject NavigationManager Nav
@inject ProductProfileViewModel VM

<RadzenCard>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="25"
                 AlignItems="AlignItems.Center" Style="margin-bottom:30px;">

        <RadzenCard Style="width:120px; height:120px; border-radius:50%; background:#d9d9d9;
                           display:flex; align-items:center; justify-content:center; font-size:50px;">
            📦
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@VM.Product.Name"
                        Style="font-size:24px; font-weight:600; color:#333;"/>
            <RadzenText Text="Producto registrado" Style="color:#777;"/>

            @if (!VM.IsEditing)
            {
                <RadzenButton Text="Editar producto" Icon="edit"
                              Style="border-radius:10px;"
                              Click="@(() => VM.IsEditing = true)"/>
            }
            else
            {
                <RadzenButton Text="Cancelar" Icon="close"
                              ButtonStyle="ButtonStyle.Danger"
                              Style="border-radius:10px;"
                              Click="@VM.Cancel"/>
            }
        </RadzenStack>
    </RadzenStack>

    <RadzenText Text="Información del producto"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre",      VM.Product.Name,                    v => VM.Product.Name        = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Categoría",   VM.Product.Category,                v => VM.Product.Category    = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Marca",       VM.Product.Brand,                   v => VM.Product.Brand       = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Precio",      VM.Product.Price.ToString(),        v => VM.Product.Price       = decimal.Parse(v))</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Stock",       VM.Product.Stock.ToString(),        v => VM.Product.Stock       = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Estado",      VM.Product.Active ? "Activo" : "Inactivo", null)</RadzenColumn>
        <RadzenColumn Size="12">@Campo("Descripción", VM.Product.Description,            v => VM.Product.Description = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <RadzenText Text="Registro del sistema"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Creado el",            VM.Product.CreatedAt.ToLocalTime().ToString(),  null)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Última actualización", VM.Product.UpdatedAt?.ToLocalTime().ToString(), null)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <RadzenText Text="Historial"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    @if (VM.Product.Historical != null && VM.Product.Historical.Any())
    {
        <RadzenDataList Data="@VM.Product.Historical" TItem="LogEntry">
            <Template Context="log">
                <RadzenCard Style="margin-bottom:10px;">
                    <RadzenText Text="@($"{log.Date.ToLocalTime():g} - {log.Description}")"/>
                </RadzenCard>
            </Template>
        </RadzenDataList>
    }
    else
    {
        <RadzenText Text="Sin historial registrado" Style="font-style:italic; color:#777;"/>
    }

    @if (VM.IsEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios" Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="background:#4b3e48; color:white; border-radius:10px;"
                          Click="@(async () => await VM.SaveAsync())"/>
        </RadzenStack>
    }

</RadzenCard>

@code {
    [Parameter] public string Id { get; set; } = "";

    protected override async Task OnInitializedAsync() => await VM.LoadAsync(Id);

    RenderFragment Campo(string label, string? valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;"/>
            @if (!VM.IsEditing)
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))"
                               Style="width:100%; background:white; border-radius:10px;"/>
            }
            else
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
            }
        </RadzenStack>;
    };
}