@page "/PerfilProducto/{Id}"
@using SocioWeb.Domain.Entities
@using SocioWeb.ViewModels

@inject NavigationManager Nav

<RadzenCard>
    <!-- CABECERA -->
    <RadzenStack Orientation="Orientation.Horizontal" Gap="25" AlignItems="AlignItems.Center" Style="margin-bottom:30px;">
        <RadzenCard Style="width:120px; height:120px; border-radius:50%; background:#d9d9d9; display:flex; align-items:center; justify-content:center; font-size:50px; color:#6c6c6c;">
            📦
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@vm.Product.Name" Style="font-size:24px; font-weight:600; color:#333;" />
            <RadzenText Text="Producto registrado" Style="color:#777;" />

            <RadzenButton Text="Editar producto" Icon="edit" Style="border-radius:10px;" Click="@vm.ToggleEdit" Visible="!vm.IsEditing" />
            <RadzenButton Text="Cancelar" Icon="close" ButtonStyle="ButtonStyle.Danger" Style="border-radius:10px;" Click="@vm.CancelEdit" Visible="vm.IsEditing" />
        </RadzenStack>
    </RadzenStack>

    <!-- INFORMACIÓN DEL PRODUCTO -->
    <RadzenText Text="Información del producto" Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;" />

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre", vm.Product.Name, v => vm.Product.Name = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Categoría", vm.Product.Category, v => vm.Product.Category = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Marca", vm.Product.Brand, v => vm.Product.Brand = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Precio", vm.Product.Price.ToString("F2"), v => vm.Product.Price = decimal.Parse(v))</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Stock", vm.Product.Stock.ToString(), v => vm.Product.Stock = int.Parse(v))</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Estado", vm.Product.Active ? "Activo" : "Inactivo", null)</RadzenColumn>
        <RadzenColumn Size="12">@Campo("Descripción", vm.Product.Description, v => vm.Product.Description = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;" />

    <!-- AUDITORÍA -->
    <RadzenText Text="Registro del sistema" Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;" />
    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Creado el", vm.Product.CreatedAt.ToLocalTime().ToString(), null)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Última actualización", vm.Product.UpdatedAt?.ToLocalTime().ToString(), null)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;" />

    <!-- HISTORIAL -->
    <RadzenText Text="Historial" Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;" />
    @if (vm.Product.Historical != null && vm.Product.Historical.Any())
    {
        <RadzenDataList Data="@vm.Product.Historical" TItem="LogEntry">
            <Template Context="log">
                <RadzenCard Style="margin-bottom:10px;">
                    <RadzenText Text="@($"{log.Date.ToLocalTime():g} - {log.Description}")" />
                </RadzenCard>
            </Template>
        </RadzenDataList>
    }
    else
    {
        <RadzenText Text="Sin historial registrado" Style="font-style:italic; color:#777;" />
    }

    @if (vm.IsEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios" Icon="save" ButtonStyle="ButtonStyle.Primary"
                          Style="background:#4b3e48; color:white; border-radius:10px;" Click="@vm.Save" />
        </RadzenStack>
    }
</RadzenCard>

@code {
    [Parameter] public string Id { get; set; }

    private ProductProfileVM vm = new();

    protected override async Task OnInitializedAsync()
    {
        await vm.LoadAsync(Id);
    }

    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;" />
            @if (!vm.IsEditing)
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;" />
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor" Change="@(e => onChange(e.ToString()))" Style="width:100%; background:white; border-radius:10px;" />
            }
            else
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;" />
            }
        </RadzenStack>;
    };
}