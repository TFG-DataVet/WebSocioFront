@page "/PerfilMascota/{Id}"
@inject NavigationManager Nav
@inject PetProfileViewModel VM

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"/>
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage"/>
}

<RadzenCard>
    <RadzenStack Orientation="Orientation.Horizontal" Gap="25"
                 AlignItems="AlignItems.Center" Style="margin-bottom:30px;">

        <RadzenCard Style="width:120px; height:120px; border-radius:50%; background:#d9d9d9;
                           display:flex; align-items:center; justify-content:center; font-size:50px;">
            🐾
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@VM.Pet.Name" Style="font-size:24px; font-weight:600; color:#333;"/>
            <RadzenText Text="Mascota registrada" Style="color:#777;"/>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="10">
                @if (!VM.IsEditing)
                {
                    <RadzenButton Text="Editar perfil" Icon="edit"
                                  Style="border-radius:10px;"
                                  Click="@(() => VM.IsEditing = true)"/>
                }
                else
                {
                    <RadzenButton Text="Cancelar" Icon="close"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Style="border-radius:10px;"
                                  Click="@VM.Cancel"/>
                }
                <RadzenButton Text="Ver dueño" Icon="account_box"
                              ButtonStyle="ButtonStyle.Primary"
                              Style="border-radius:10px; background:#4b3e48; color:white;"
                              Click="@(() => Nav.NavigateTo($"/PerfilDueno/{VM.Pet.Owner?.Id}"))"/>
                <RadzenButton Text="Registro médico" Icon="medical_services"
                              ButtonStyle="ButtonStyle.Primary"
                              Style="border-radius:10px; background:#4b3e48; color:white;"
                              Click="@(() => Nav.NavigateTo("/MedicalRegister"))"/>
            </RadzenStack>
        </RadzenStack>
    </RadzenStack>

    <RadzenText Text="Información de la mascota"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre",   VM.Pet.Name,  v => VM.Pet.Name  = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Especie",  VM.Pet.Specie, v => VM.Pet.Specie = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Raza",     VM.Pet.Breed,  v => VM.Pet.Breed  = v)</RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenStack Gap="5">
                <RadzenText Text="Sexo" Style="color:#777;"/>
                @if (!VM.IsEditing)
                {
                    <RadzenText Text="@VM.Pet.Sex.ToString()" Style="font-size:18px; color:#333;"/>
                }
                else
                {
                    <RadzenDropDown TValue="Sex"
                                    Data="@(Enum.GetValues(typeof(Sex)))"
                                    @bind-Value="VM.Pet.Sex"
                                    Style="width:100%; border-radius:10px;"/>
                }
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="6">@Campo("Fecha nacimiento",
            VM.Pet.BirthDate.ToShortDateString(),
            v => VM.Pet.BirthDate = DateTime.Parse(v))</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Peso (kg)",
            VM.Pet.Weight.ToString(),
            v => VM.Pet.Weight = int.Parse(v))</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Número chip", VM.Pet.Chip, v => VM.Pet.Chip = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>
    <RadzenText Text="Registro del sistema"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>
    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Creado el", VM.Pet.CreatedAt.ToLocalTime().ToString(), null)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Última actualización", VM.Pet.UpdatedAt?.ToLocalTime().ToString(), null)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <RadzenCard Style="margin-top:20px; background:#f9f9f9; border-radius:12px; padding:20px;">
        <RadzenStack Orientation="Orientation.Horizontal"
                     JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center">
            <RadzenText Text="Historial médico" Style="font-size:18px; font-weight:600; color:#4b3e48;"/>
            @if (!VM.IsEditingHistorial)
            {
                <RadzenButton Text="Editar historial" Icon="edit"
                              ButtonStyle="ButtonStyle.Primary"
                              Style="border-radius:10px;"
                              Click="@(() => VM.IsEditingHistorial = true)"/>
            }
            else
            {
                <RadzenStack Orientation="Orientation.Horizontal" Gap="10">
                    <RadzenButton Text="Guardar" Icon="save"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Style="background:#4b3e48; color:white; border-radius:10px;"
                                  Click="@VM.SaveHistorical"/>
                    <RadzenButton Text="Cancelar" Icon="close"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Style="border-radius:10px;"
                                  Click="@(() => VM.IsEditingHistorial = false)"/>
                </RadzenStack>
            }
        </RadzenStack>

        <RadzenStack Gap="20" Style="margin-top:15px;">
            <RadzenStack Gap="5">
                <RadzenText Text="Operaciones" Style="font-weight:600; color:#4b3e48;"/>
                <div style="max-height:120px; overflow-y:auto; border:1px solid #ccc; padding:5px; border-radius:5px;">
                    @if (VM.IsEditingHistorial)
                    {
                        <RadzenTextBox @bind-Value="VM.Pet.WhichOperations"
                                       Style="width:100%; border:none; padding:2px;"
                                       Placeholder="Agregar operaciones..."/>
                    }
                    else
                    {
                        @foreach (var log in (VM.Pet.WhichOperations?.Split('\n') ?? Array.Empty<string>()))
                        {
                            <div style="margin-bottom:4px;">• @log</div>
                        }
                    }
                </div>
            </RadzenStack>

            <RadzenDivider/>

            <RadzenStack Gap="5">
                <RadzenText Text="Enfermedades" Style="font-weight:600; color:#4b3e48;"/>
                <div style="max-height:120px; overflow-y:auto; border:1px solid #ccc; padding:5px; border-radius:5px;">
                    @if (VM.IsEditingHistorial)
                    {
                        <RadzenTextBox @bind-Value="VM.Pet.WhichDiseases"
                                       Style="width:100%; border:none; padding:2px;"
                                       Placeholder="Agregar enfermedades..."/>
                    }
                    else
                    {
                        @foreach (var log in (VM.Pet.WhichDiseases?.Split('\n') ?? Array.Empty<string>()))
                        {
                            <div style="margin-bottom:4px;">• @log</div>
                        }
                    }
                </div>
            </RadzenStack>

            <RadzenDivider/>

            <RadzenStack Gap="5">
                <RadzenText Text="Vacunas" Style="font-weight:600; color:#4b3e48;"/>
                <div style="max-height:120px; overflow-y:auto; border:1px solid #ccc; padding:5px; border-radius:5px;">
                    @if (VM.IsEditingHistorial)
                    {
                        <RadzenTextBox @bind-Value="VM.Pet.WhichVacines"
                                       Style="width:100%; border:none; padding:2px;"
                                       Placeholder="Agregar vacunas..."/>
                    }
                    else
                    {
                        @foreach (var log in (VM.Pet.WhichVacines?.Split('\n') ?? Array.Empty<string>()))
                        {
                            <div style="margin-bottom:4px;">• @log</div>
                        }
                    }
                </div>
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>

    @if (VM.IsEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios" Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="background:#4b3e48; color:white; border-radius:10px;"
                          Click="@(async () => await VM.SaveAsync())"/>
        </RadzenStack>
    }
</RadzenCard>

@code {
    [Parameter] public string Id { get; set; } = "";


    protected override async Task OnInitializedAsync() => await VM.LoadAsync(Id);
        
    RenderFragment Campo(string label, string? valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;"/>

            @if (!VM.IsEditing)
            {
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8">
                    <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
                    <RadzenIcon Icon="edit" Style="font-size:18px; color:#aaa;"/>
                </RadzenStack>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))"
                               Style="width:100%; background:white; border-radius:10px;"/>
            }
            else
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
            }
        </RadzenStack>;
    };
}