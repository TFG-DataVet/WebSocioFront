@page "/Calendario"

@inject NavigationManager Nav

<RadzenStack Gap="10" Style="padding:20px">

    <!-- HEADER -->
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween">

        <RadzenText Text="Calendario de Citas"
                    TextStyle="TextStyle.H4"
                    Style="font-weight:600"/>

        <RadzenButton Text="Nueva Cita"
                      Icon="add_circle"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@CreateAppointment"/>
    </RadzenStack>

    <!-- CALENDARIO -->
    <RadzenCard Style="border-radius:16px;
                       box-shadow:0 4px 20px rgba(0,0,0,0.1);
                       padding:10px">

        <RadzenScheduler TItem="Appointment"
                         Data="@appointments"
                         StartProperty="Start"
                         EndProperty="End"
                         TextProperty="PetName"
                         CurrentDate="@DateTime.Today"
                         SelectedIndex="2" 
                         SlotSelect="@OnSlotSelect"
                         AppointmentSelect="@OnAppointmentSelect"
                         Style="height:750px">

            <!-- Orden recomendado -->
            <RadzenMonthView />
            <RadzenWeekView />
            <RadzenDayView />
            </RadzenScheduler>

    </RadzenCard>

</RadzenStack>

@code {
    List<Appointment> appointments = new();

    protected override void OnInitialized()
    {
        // Inicializamos citas con DateTimeKind.Local para evitar que MonthView no las pinte
        appointments = new List<Appointment>
        {
            new Appointment
            {
                Id = "1",
                PetName = "Firulais",
                OwnerName = "Juan Pérez",
                Phone = "555-1234",
                Start = DateTime.SpecifyKind(DateTime.Today.AddHours(10), DateTimeKind.Local),
                End = DateTime.SpecifyKind(DateTime.Today.AddHours(11), DateTimeKind.Local),
                Reason = "Vacunación",
                Status = "Pendiente"
            },

            new Appointment
            {
                Id = "2",
                PetName = "Michi",
                OwnerName = "Ana López",
                Phone = "555-9876",
                Start = DateTime.SpecifyKind(DateTime.Today.AddDays(1).AddHours(16), DateTimeKind.Local),
                End = DateTime.SpecifyKind(DateTime.Today.AddDays(1).AddHours(17), DateTimeKind.Local),
                Reason = "Control general",
                Status = "Confirmada"
            }
        };
    }

    // Click en un slot vacío del calendario
    void OnSlotSelect(SchedulerSlotSelectEventArgs args)
    {
        Nav.NavigateTo($"/CreateAppointment?date={args.Start:O}");
    }

    // Click en una cita existente
    void OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<Appointment> args)
    {
        Nav.NavigateTo($"/AppointmentProfile/{args.Data.Id}");
    }

    void CreateAppointment()
    {
        Nav.NavigateTo("/CreateAppointment");
    }

    public class Appointment
    {
        public string Id { get; set; }
        public string PetName { get; set; }
        public string OwnerName { get; set; }
        public string Phone { get; set; }
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public string Reason { get; set; }
        public string Status { get; set; }
    }
}
