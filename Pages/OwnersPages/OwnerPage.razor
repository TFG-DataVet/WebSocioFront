@page "/Duenos"
@inject NavigationManager Nav
@inject OwnerListViewModel VM
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                       Style="margin-bottom:1rem;" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true" />
}

<PageTitle>Dueños</PageTitle>

<!-- HEADER -->
<RadzenCard Style="
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    color: white;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(79,172,254,0.35);
    margin-bottom: 1.5rem;
    padding: 1.5rem 2rem;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Wrap="FlexWrap.Wrap"
                 Gap="10">
        <RadzenStack Gap="2">
            <RadzenText Text="Gestión de Dueños"
                        Style="font-size:28px; font-weight:700; color:white; margin:0;" />
            <RadzenText Text="@($"{VM.FilteredOwners.Count} registros encontrados")"
                        Style="font-size:13px; opacity:0.85; color:white;" />
        </RadzenStack>
        <RadzenButton Text="Nuevo Dueño"
                      Icon="person_add"
                      Style="background:white; color:#4facfe; font-weight:600; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,0.15);"
                      Click="@(() => Nav.NavigateTo("/DuenoFormulario"))" />
    </RadzenStack>
</RadzenCard>

<!-- FILTROS -->
<RadzenCard Style="border-radius:12px; margin-bottom:1.5rem; padding:1.2rem 1.5rem;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.End"
                 Wrap="FlexWrap.Wrap"
                 Gap="12">

        <RadzenStack Gap="4">
            <RadzenLabel Text="Desde" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenDatePicker @bind-Value="VM.DateSince" Placeholder="Fecha inicio" Style="width:155px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Hasta" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenDatePicker @bind-Value="VM.DateTo" Placeholder="Fecha fin" Style="width:155px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Ciudad" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenTextBox @bind-Value="VM.CityFilter" Placeholder="ej. Madrid" Style="width:140px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Código Postal" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenTextBox @bind-Value="VM.PostalCodeFilter" Placeholder="ej. 28001" Style="width:120px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Buscar" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenTextBox @bind-Value="VM.SearchFilter" Placeholder="Nombre o email..." Style="width:200px" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8">
            <RadzenButton Icon="filter_alt" Text="Filtrar"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="border-radius:8px;"
                          Click="@VM.ApplyFilters" />
            <RadzenButton Icon="clear" Text="Limpiar"
                          ButtonStyle="ButtonStyle.Light"
                          Style="border-radius:8px;"
                          Click="@VM.ClearFilters" />
        </RadzenStack>
    </RadzenStack>
</RadzenCard>

<!-- TABLA -->
<RadzenCard Style="border-radius:12px; padding:0; overflow:hidden;">
    <RadzenDataGrid Data="@VM.FilteredOwners"
                    TItem="Owner"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="10"
                    ShowPagingSummary="true"
                    PagingSummaryFormat="Página {0} de {1} — Total: {2}"
                    EmptyText="No se encontraron dueños con los filtros actuales."
                    Style="border:none;">
        <Columns>

            <RadzenDataGridColumn TItem="Owner" Title="Dueño" Width="220px">
                <Template Context="owner">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10">
                        <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/616/616408.png" Size="38px" />
                        <RadzenStack Gap="0">
                            <RadzenText Text="@($"{owner.Name} {owner.LastName}")"
                                        Style="font-weight:600; font-size:14px;" />
                            <RadzenText Text="@owner.Email"
                                        Style="font-size:12px; color:#888;" />
                        </RadzenStack>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Owner" Property="Phone" Title="Teléfono" Width="140px">
                <Template Context="owner">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6">
                        <RadzenIcon Icon="phone" Style="font-size:16px; color:#4facfe;" />
                        <RadzenText Text="@(owner.Phone ?? "—")" Style="font-size:13px;" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Owner" Title="Ubicación" Width="160px">
                <Template Context="owner">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="6">
                        <RadzenIcon Icon="location_on" Style="font-size:16px; color:#f6c23e;" />
                        <RadzenText Text="@($"{owner.City ?? "—"} {owner.PostalCode ?? ""}")"
                                    Style="font-size:13px;" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Owner" Title="Mascotas" Width="100px">
                <Template Context="owner">
                    <RadzenBadge BadgeStyle="BadgeStyle.Info"
                                 Text="@($"{owner.Pet?.Count ?? 0} mascota{(owner.Pet?.Count != 1 ? "s" : "")}")"
                                 Style="border-radius:8px; font-size:12px;" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Owner" Title="Estado" Width="110px">
                <Template Context="owner">
                    <RadzenBadge BadgeStyle="@(owner.StatusApp == StatusApp.Active ? BadgeStyle.Success : BadgeStyle.Danger)"
                                 Text="@owner.StatusApp.ToString()"
                                 Style="border-radius:8px; font-size:12px;" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Owner" Property="CreatedAt" Title="Registrado" Width="130px">
                <Template Context="owner">
                    <RadzenText Text="@owner.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")"
                                Style="font-size:13px; color:#666;" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Owner" Title="Acciones" Width="140px" Sortable="false">
                <Template Context="owner">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6">
                        <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small"
                                      Style="border-radius:7px;"
                                      Click="@(() => Nav.NavigateTo($"/PerfilDueno/{owner.Id}"))"
                                      title="Ver perfil" />
                        <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Small"
                                      Style="border-radius:7px;"
                                      Click="@(() => Nav.NavigateTo($"/EditarDueno/{owner.Id}"))"
                                      title="Editar" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Small"
                                      Style="border-radius:7px;"
                                      Click="@(async () => await ConfirmDelete(owner))"
                                      title="Eliminar" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {
    protected override async Task OnInitializedAsync() => await VM.LoadAsync();

    async Task ConfirmDelete(Owner owner)
    {
        Console.WriteLine("CLICK DELETE");
        
        var result = await DialogService.Confirm(
            $"¿Eliminar a {owner.Name} {owner.LastName}? Esta acción no se puede deshacer.",
            "Confirmar eliminación",
            new ConfirmOptions { OkButtonText = "Eliminar", CancelButtonText = "Cancelar" });
        
        if (result == true)
        {
            await VM.DeleteAsync(owner.Id);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Eliminado",
                Detail = $"{owner.Name} {owner.LastName} fue eliminado correctamente.",
                Duration = 3000
            });
        }
        Console.WriteLine($"RESULTADO: {result}");
    }
}
