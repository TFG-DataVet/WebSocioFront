@page "/create-pet"

@using SocioWeb.ViewModels
@inject PetPageVM Vm
@inject NavigationManager Nav

<PageTitle>Registrar Mascota</PageTitle>

<RadzenRow>
    <RadzenColumn Size="10" Offset="1">
        <RadzenCard class="rz-p-6">

            <RadzenTemplateForm TItem="PetPageVM.RegisterPetForm"
                                Data="@Vm.FormData"
                                Submit="@HandleSubmit">

                <RadzenRow class="rz-mb-4">

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Nombre">
                            <RadzenTextBox Name="NamePet"
                                           @bind-Value="Vm.FormData.NamePet"
                                           Style="width:100%" />
                            <RadzenRequiredValidator Component="NamePet"
                                                     Text="Nombre obligatorio" />
                        </RadzenFormField>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Fecha nacimiento">
                            <RadzenDatePicker Name="Birthday"
                                              @bind-Value="Vm.FormData.Birthday"
                                              DateFormat="yyyy-MM-dd"
                                              Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Peso (kg)">
                            <RadzenTextBox Name="Weight"
                                           @bind-Value="Vm.FormData.Weight"
                                           Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>

                </RadzenRow>

                <RadzenRow class="rz-mb-4">

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Especie">
                            <RadzenDropDown Name="Species"
                                            Data="@Vm.SpeciesOptions"
                                            @bind-Value="Vm.FormData.Species"
                                            Change="@Vm.OnSpeciesChanged"
                                            Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Raza">
                            <RadzenDropDown Name="Breed"
                                            Data="@Vm.CurrentBreeds"
                                            @bind-Value="Vm.FormData.Breed"
                                            Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenFormField Text="Sexo">
                            <RadzenDropDown Name="Sex"
                                            Data="@Vm.SexOptions"
                                            @bind-Value="Vm.FormData.Sex"
                                            Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>

                </RadzenRow>

                <RadzenRow class="rz-mb-4">
                    <RadzenColumn Size="12">
                        <RadzenFormField Text="Edad calculada">
                            <RadzenTextBox Value="@Vm.AgeCalculated"
                                           ReadOnly="true"
                                           Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow>
                    <RadzenColumn Size="12">
                        <RadzenButton ButtonStyle="ButtonStyle.Primary"
                                      Icon="save"
                                      Text="Registrar Mascota"
                                      Type="Submit"
                                      Style="width:200px; margin:auto; display:block" />
                    </RadzenColumn>
                </RadzenRow>

            </RadzenTemplateForm>

        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private async Task HandleSubmit()
    {
        await Vm.SaveAsync();
        Nav.NavigateTo("/Mascotas");
    }
}