@page "/AppointmentProfile/{id}"
@using SocioWeb.Services.AppointmentService

@inject AppointmentService AppointmentService
@inject NavigationManager Nav

<RadzenCard>
    <!-- CABECERA -->
    <RadzenStack Orientation="Orientation.Horizontal"
                 Gap="25"
                 AlignItems="AlignItems.Center"
                 Style="margin-bottom:30px;">

        <RadzenCard Style="
                    width:120px;
                    height:120px;
                    border-radius:50%;
                    background:#e0e7ff;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    font-size:50px;">
            🐶
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@_appointment.PetName"
                        Style="font-size:24px; font-weight:600; color:#333;"/>
            <RadzenText Text="Cita veterinaria"
                        Style="color:#777;"/>

            @if (!isEditing)
            {
                <RadzenButton Text="Editar cita"
                              Icon="edit"
                              Style="border-radius:10px;"
                              Click="@(() => isEditing = true)"/>
            }
            else
            {
                <RadzenButton Text="Cancelar"
                              Icon="close"
                              ButtonStyle="ButtonStyle.Danger"
                              Style="border-radius:10px;"
                              Click="@Cancel"/>
            }
            <RadzenButton Text="Eliminar cita"
                          Icon="delete"
                          ButtonStyle="ButtonStyle.Danger"
                          Style="border-radius:10px; margin-left:10px;"
                          Click="@Delete"/>

        </RadzenStack>
    </RadzenStack>

    <!-- INFORMACIÓN DE LA CITA -->
    <RadzenText Text="Información de la cita"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Mascota", _appointment.PetName, v => _appointment.PetName = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Dueño", _appointment.OwnerName, v => _appointment.OwnerName = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Teléfono", _appointment.Phone, v => _appointment.Phone = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Estado", _appointment.Status, v => _appointment.Status = v)</RadzenColumn>
        <RadzenColumn Size="6">
            @Campo("Fecha y hora",
                _appointment.Date.ToString("dd/MM/yyyy HH:mm"),
                v => _appointment.Date = DateTime.Parse(v))
        </RadzenColumn>
        <RadzenColumn Size="12">@Campo("Motivo", _appointment.Reason, v => _appointment.Reason = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <!-- AUDITORÍA -->
    <RadzenText Text="Registro del sistema"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">
            @Campo("Creado el", _appointment.CreatedAt.ToLocalTime().ToString(), null)
        </RadzenColumn>
        <RadzenColumn Size="6">
            @Campo("Última actualización", _appointment.UpdatedAt?.ToLocalTime().ToString(), null)
        </RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>
    
    @if (isEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios"
                          Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="background:#4b3e48; color:white; border-radius:10px;"
                          Click="@Save"/>
        </RadzenStack>
    }

</RadzenCard>

@code {
    
    void Delete()
    {
        // Buscar la cita por Id y eliminarla del servicio
        var cita = AppointmentService.Appointments.FirstOrDefault(a => a.Id == _appointment.Id);
        if (cita != null)
        {
            AppointmentService.Appointments.Remove(cita);
        }

        // Volver al calendario
        Nav.NavigateTo("/Calendario");
    }

    
    [Parameter] public string id { get; set; }

    protected override void OnInitialized()
    {
        if (id == "new")
        {
            // Crear cita nueva
            _appointment = new Appointment
            {
                Id = Guid.NewGuid().ToString(),
                Date = DateTime.Now,
                Status = "Pendiente",
                CreatedAt = DateTime.UtcNow
            };
            isEditing = true;
        }
    }
    
    bool isEditing = false;

    Appointment _appointment = new Appointment
    {
        Id = "1",
        PetName = "Firulais",
        OwnerName = "Juan Pérez",
        Phone = "555-1234",
        Date = DateTime.UtcNow.AddDays(1),
        Reason = "Vacunación anual",
        Status = "Pendiente",
        CreatedAt = DateTime.UtcNow.AddDays(-5),
        UpdatedAt = DateTime.UtcNow,
       
    };
    
    void Save()
    {
        _appointment.UpdatedAt = DateTime.UtcNow;
        isEditing = false;
    }

    void Cancel()
    {
        isEditing = false;
    }

    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;"/>

            @if (!isEditing)
            {
                <RadzenText Text="@valor"
                            Style="font-size:18px; color:#333;"/>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))"
                               Style="width:100%; background:white; border-radius:10px;"/>
            }
            else
            {
                <RadzenText Text="@valor"
                            Style="font-size:18px; color:#333;"/>
            }
        </RadzenStack>;
    };
}
