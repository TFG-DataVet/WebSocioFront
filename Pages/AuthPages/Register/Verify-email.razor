@page "/verify-email"
@attribute [AllowAnonymous]
@layout AuthLayout
@using SocioWeb.ViewModels.Auth
@using SocioWeb.Components
@inject VerifyEmailVM VM

<div class="login-page">
    <div class="login-card">

        @* Panel izquierdo: carrusel (solo tablet/desktop) *@
        <div class="login-image-panel">
            <ImageCarousel Images="@_carouselImages" AutoPlayIntervalMs="5000" />
        </div>

        @* Panel derecho: contenido con glassmorphism *@
        <div class="login-form-panel">

            <div class="login-logo">
                <img src="/Images/logos/cropped_task-design-a-premium-ultra-minimalist__2_-removebg-preview.png"
                     alt="DataVet" />
            </div>

            <div style="display: flex; justify-content: center;">
                <span class="verify-step-badge">Paso 2 de 3</span>
            </div>

            <h1 class="login-title">Verificando tu cuenta</h1>
            <p class="login-subtitle">Comprobando el enlace de tu correo...</p>

            @* ── Estado 1: Cargando ── *@
            @if (!VM.HasError && VM.IsLoading)
            {
                <div class="verify-loading-block">
                    <div class="heartbeatloader">
                        <svg class="svgdraw" viewBox="0 0 150 60" xmlns="http://www.w3.org/2000/svg">
                            <path class="path"
                                  d="M 0 30 l 25 0 l 5 -20 l 5 20 l 10 0 l 5 10 l 10 -50 l 10 70 l 5 -30 l 10 0 l 5 10 l 5 -10 l 55 0"
                                  fill="transparent"
                                  stroke-width="3"
                                  stroke="var(--color-primary, #88B6F2)" />
                        </svg>
                        <div class="innercircle"></div>
                        <div class="outercircle"></div>
                    </div>
                    <p class="verify-loading-text">Validando tu cuenta, por favor espera...</p>
                </div>
            }

            @* ── Estado 2: Error ── *@
            @if (VM.HasError)
            {
                <div class="verify-error-block">

                    <div class="verify-error-icon">
                        <img src="/Images/icons/error.png" alt="Error" />
                    </div>

                    @if (!string.IsNullOrEmpty(VM.ErrorMessage))
                    {
                        <div class="login-error" role="alert">@VM.ErrorMessage</div>
                    }
                    else
                    {
                        <div class="login-error" role="alert">
                            El enlace de verificación no es válido o ha expirado.
                        </div>
                    }

                    <div class="verify-resend-form">
                        <div class="login-field">
                            <label class="login-label" for="EmailToResend">Tu correo electrónico</label>
                            <RadzenTextBox Name="EmailToResend"
                                           @bind-Value="@VM.EmailToResend"
                                           Placeholder="tucorreo@ejemplo.com"
                                           Style="display: block; width: 100%;" />
                        </div>

                        <RadzenButton ButtonStyle="ButtonStyle.Primary"
                                      Text="Reenviar enlace"
                                      Click="@VM.ResendEmailAsync"
                                      Style="width: 100%; margin-top: 0.5rem;" />
                    </div>

                    <div class="login-links">
                        <RadzenLink Path="/registro" Text="&larr; Volver al registro" />
                    </div>

                </div>
            }

        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string token { get; set; }

    private readonly List<string> _carouselImages = new()
    {
        "/Images/carrusel/pexels-jonathanborba-11933172.jpg",
        "/Images/carrusel/pexels-rdne-7348941.jpg",
        "/Images/carrusel/pexels-viktoriia-kondratiuk-458099300-30617476.jpg",
        "/Images/carrusel/pexels-viktoriia-kondratiuk-458099300-30617487.jpg"
    };

    protected override async Task OnInitializedAsync()
    {
        await VM.InitializeAsync(token);
    }
}
