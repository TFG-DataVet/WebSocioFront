@page "/reset-password"
@attribute [AllowAnonymous]
@layout AuthLayout
@using SocioWeb.ViewModels.Auth
@using SocioWeb.Components
@inject ResetPasswordVM VM

<div class="login-page">
    <div class="login-card">

        @* Panel izquierdo: carrusel (solo tablet/desktop) *@
        <div class="login-image-panel">
            <ImageCarousel Images="@_carouselImages" AutoPlayIntervalMs="5000" />
        </div>

        @* Panel derecho: formulario con glassmorphism *@
        <div class="login-form-panel">

            <div class="login-logo">
                <img src="/Images/logos/cropped_task-design-a-premium-ultra-minimalist__2_-removebg-preview.png"
                     alt="DataVet" />
            </div>

            <h1 class="login-title">Nueva contraseña</h1>
            <p class="login-subtitle">Elige una contraseña segura</p>

            @if (VM.IsSuccess)
            {
                <div class="forgot-success-message">
                    <p>Tu contraseña se ha actualizado correctamente.</p>
                </div>

                <div class="login-links">
                    <RadzenLink Path="/login" Text="Ir al inicio de sesión" />
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(VM.ErrorMessage))
                {
                    <div class="login-error" role="alert">@VM.ErrorMessage</div>
                }

                <RadzenTemplateForm TItem="ResetPasswordVM" Data="@VM" Submit="@VM.OnSubmit">

                    <div class="login-field">
                        <RadzenLabel Text="Nueva contraseña" Component="NewPassword" class="login-label" />
                        <RadzenPassword Name="NewPassword"
                                        @bind-Value="@VM.NewPassword"
                                        Placeholder="••••••••"
                                        Style="display: block; width: 100%;" />
                        <RadzenRequiredValidator Component="NewPassword"
                                                Text="La contraseña es requerida."
                                                Style="display: block; margin-top: 0.25rem;" />
                    </div>

                    <div class="login-field">
                        <RadzenLabel Text="Confirmar contraseña" Component="ConfirmPassword" class="login-label" />
                        <RadzenPassword Name="ConfirmPassword"
                                        @bind-Value="@VM.ConfirmPassword"
                                        Placeholder="••••••••"
                                        Style="display: block; width: 100%;" />
                        <RadzenRequiredValidator Component="ConfirmPassword"
                                                Text="Confirma tu contraseña."
                                                Style="display: block; margin-top: 0.25rem;" />
                    </div>

                    <RadzenButton ButtonStyle="ButtonStyle.Primary"
                                  Text="Cambiar contraseña"
                                  ButtonType="ButtonType.Submit"
                                  IsBusy="@VM.IsLoading"
                                  Style="width: 100%; margin-top: 0.5rem;" />

                </RadzenTemplateForm>

                <div class="login-links">
                    <RadzenLink Path="/login" Text="← Volver al inicio de sesión" />
                </div>
            }

        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? token { get; set; }

    protected override void OnInitialized()
    {
        VM.Initialize(token);
    }

    private readonly List<string> _carouselImages = new()
    {
        "/Images/carrusel/pexels-jonathanborba-11933172.jpg",
        "/Images/carrusel/pexels-rdne-7348941.jpg",
        "/Images/carrusel/pexels-viktoriia-kondratiuk-458099300-30617476.jpg",
        "/Images/carrusel/pexels-viktoriia-kondratiuk-458099300-30617487.jpg"
    };
}
