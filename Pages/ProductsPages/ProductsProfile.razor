@page "/PerfilProducto/{Id}"
@inject NavigationManager Nav

<RadzenCard>

    <!-- CABECERA -->
    <RadzenStack Orientation="Orientation.Horizontal"
                 Gap="25"
                 AlignItems="AlignItems.Center"
                 Style="margin-bottom:30px;">

        <RadzenCard Style="
                    width:120px;
                    height:120px;
                    border-radius:50%;
                    background:#d9d9d9;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    font-size:50px;
                    color:#6c6c6c;">
            📦
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@_product.Name"
                        Style="font-size:24px; font-weight:600; color:#333;"/>
            <RadzenText Text="Producto registrado"
                        Style="color:#777;"/>

            @if (!isEditing)
            {
                <RadzenButton Text="Editar producto"
                              Icon="edit"
                              Style="border-radius:10px;"
                              Click="@(() => isEditing = true)"/>
            }
            else
            {
                <RadzenButton Text="Cancelar"
                              Icon="close"
                              ButtonStyle="ButtonStyle.Danger"
                              Style="border-radius:10px;"
                              Click="@Cancel"/>
            }
        </RadzenStack>
    </RadzenStack>

    <!-- INFORMACIÓN DEL PRODUCTO -->
    <RadzenText Text="Información del producto"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre", _product.Name, v => _product.Name = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Categoría", _product.Category, v => _product.Category = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Marca", _product.Brand, v => _product.Brand = v)</RadzenColumn>
        <RadzenColumn
            Size="6">@Campo("Precio", _product.Price.ToString(), v => _product.Price = decimal.Parse(v))</RadzenColumn>
        <RadzenColumn
            Size="6">@Campo("Stock", _product.Stock.ToString(), v => _product.Stock = int.Parse(v))</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Estado", _product.Active ? "Activo" : "Inactivo", null)</RadzenColumn>
        <RadzenColumn
            Size="12">@Campo("Descripción", _product.Description, v => _product.Description = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <!-- AUDITORÍA -->
    <RadzenText Text="Registro del sistema"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">
            @Campo("Creado el", _product.CreatedAt.ToLocalTime().ToString(), null)
        </RadzenColumn>
        <RadzenColumn Size="6">
            @Campo("Última actualización", _product.UpdatedAt?.ToLocalTime().ToString(), null)
        </RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <!-- HISTORIAL -->
    <RadzenText Text="Historial"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;"/>

    @if (_product.Historical != null && _product.Historical.Any())
    {
        <RadzenDataList Data="@_product.Historical" TItem="LogEntry">
            <Template Context="log">
                <RadzenCard Style="margin-bottom:10px;">
                    <RadzenText Text="@($"{log.Date.ToLocalTime():g} - {log.Description}")"/>
                </RadzenCard>
            </Template>
        </RadzenDataList>
    }
    else
    {
        <RadzenText Text="Sin historial registrado"
                    Style="font-style:italic; color:#777;"/>
    }

    @if (isEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios"
                          Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="background:#4b3e48; color:white; border-radius:10px;"
                          Click="@Save"/>
        </RadzenStack>
    }

</RadzenCard>

@code {

    [Parameter] public string Id { get; set; }

    bool isEditing = false;

    Product _product = new Product
    {
        Id = "1",
        Name = "Alimento Premium Perro",
        Category = "Alimentos",
        Brand = "DogPlus",
        Price = 29.99m,
        Stock = 15,
        Active = true,
        Description = "Bolsa 10kg alimento balanceado",
        CreatedAt = DateTime.UtcNow.AddMonths(-3),
        UpdatedAt = DateTime.UtcNow,
        Historical = new List<LogEntry>
        {
            new LogEntry { Date = DateTime.UtcNow.AddDays(-10), Description = "Producto creado" },
            new LogEntry { Date = DateTime.UtcNow.AddDays(-2), Description = "Actualización de stock" }
        }
    };

    void Save()
    {
        _product.UpdatedAt = DateTime.UtcNow;
        isEditing = false;
    }

    void Cancel()
    {
        isEditing = false;
    }

    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;"/>

            @if (!isEditing)
            {
                <RadzenText Text="@valor"
                            Style="font-size:18px; color:#333;"/>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))"
                               Style="width:100%; background:white; border-radius:10px;"/>
            }
            else
            {
                <RadzenText Text="@valor"
                            Style="font-size:18px; color:#333;"/>
            }
        </RadzenStack>
        ;
    };
}
