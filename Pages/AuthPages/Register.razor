@page "/registro"
@using SocioWeb.Entities.Dtos.AuthDto
@using SocioWeb.Infrastructure.Services.Auth

@inject IAuthService      AuthService
@inject NavigationManager Navigation

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem"
             JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center"
             Style="min-height: 100vh; padding: 2rem 1rem;">

    <RadzenText TextStyle="TextStyle.DisplayH1"
                Style="color: var(--color-primary); text-align:center; font-weight:bold;">
        DataVet
    </RadzenText>
    <h2 style="text-align:center;">Crea tu cuenta</h2>

    @if (_success)
    {
        <RadzenCard Style="max-width:450px; border-radius:12px; text-align:center; padding:2rem;">
            <RadzenText Text="✅ ¡Registro completado!"
                        Style="font-size:22px; font-weight:700; color:#1cc88a;"/>
            <RadzenText Text="Hemos enviado un email de verificación a tu correo. Haz clic en el enlace para activar tu cuenta."
                        Style="margin-top:1rem; color:#555;"/>
            <RadzenText Text="@_registeredEmail"
                        Style="font-weight:600; margin-top:0.5rem; color:#4e73df;"/>
        </RadzenCard>
    }
    else
    {
        <RadzenCard Style="max-width:450px; width:100%; border-radius:12px; padding:2rem;">
            @if (!string.IsNullOrEmpty(_error))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@_error" Style="margin-bottom:1rem;"/>
            }

            <RadzenStack Gap="14">

                <RadzenStack Gap="4">
                    <RadzenText Text="Nombre de la clínica *" Style="font-size:13px; font-weight:600;"/>
                    <input @bind="_dto.ClinicName" placeholder="Ej: Clínica PetCare"
                           style="width:100%; padding:8px; border-radius:6px; border:1px solid #ccc; box-sizing:border-box;"/>
                </RadzenStack>

                <RadzenRow>
                    <RadzenColumn Size="6">
                        <RadzenStack Gap="4">
                            <RadzenText Text="Nombre *" Style="font-size:13px; font-weight:600;"/>
                            <input @bind="_dto.FirstName" placeholder="Juan"
                                   style="width:100%; padding:8px; border-radius:6px; border:1px solid #ccc; box-sizing:border-box;"/>
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenStack Gap="4">
                            <RadzenText Text="Apellidos *" Style="font-size:13px; font-weight:600;"/>
                            <input @bind="_dto.LastName" placeholder="García"
                                   style="width:100%; padding:8px; border-radius:6px; border:1px solid #ccc; box-sizing:border-box;"/>
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenStack Gap="4">
                    <RadzenText Text="Email *" Style="font-size:13px; font-weight:600;"/>
                    <input type="email" @bind="_dto.Email" placeholder="tu@email.com"
                           style="width:100%; padding:8px; border-radius:6px; border:1px solid #ccc; box-sizing:border-box;"/>
                </RadzenStack>

                <RadzenStack Gap="4">
                    <RadzenText Text="Teléfono * (ej: +34 600 000 000)" Style="font-size:13px; font-weight:600;"/>
                    <input @bind="_dto.Phone" placeholder="+34 600 000 000"
                           style="width:100%; padding:8px; border-radius:6px; border:1px solid #ccc; box-sizing:border-box;"/>
                </RadzenStack>

                <RadzenStack Gap="4">
                    <RadzenText Text="Contraseña * (mínimo 8 caracteres)" Style="font-size:13px; font-weight:600;"/>
                    <input type="password" @bind="_dto.Password" placeholder="••••••••"
                           style="width:100%; padding:8px; border-radius:6px; border:1px solid #ccc; box-sizing:border-box;"/>
                </RadzenStack>

                <RadzenButton ButtonStyle="ButtonStyle.Primary"
                              Text="@(_loading ? "Registrando..." : "Crear cuenta")"
                              Style="width:100%; margin-top:0.5rem; border-radius:8px;"
                              Disabled="@_loading"
                              Click="RegisterUser"/>

                <RadzenText Style="text-align:center; font-size:13px;">
                    ¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
                </RadzenText>

            </RadzenStack>
        </RadzenCard>
    }

</RadzenStack>

@code {
    RegisterRequestDto _dto            = new();
    string             _error          = string.Empty;
    string             _registeredEmail = string.Empty;
    bool               _loading        = false;
    bool               _success        = false;

    async Task RegisterUser()
    {
        _error = string.Empty;

        if (string.IsNullOrWhiteSpace(_dto.ClinicName) || string.IsNullOrWhiteSpace(_dto.FirstName) ||
            string.IsNullOrWhiteSpace(_dto.LastName)   || string.IsNullOrWhiteSpace(_dto.Email) ||
            string.IsNullOrWhiteSpace(_dto.Phone)      || string.IsNullOrWhiteSpace(_dto.Password))
        {
            _error = "Por favor, completa todos los campos obligatorios.";
            return;
        }

        _loading = true;
        try
        {
            var result       = await AuthService.RegisterAsync(_dto);
            _registeredEmail = result.Email;
            _success         = true;
        }
        catch
        {
            _error = "Error al registrarse. Comprueba los datos e inténtalo de nuevo.";
        }
        finally
        {
            _loading = false;
        }
    }
}
