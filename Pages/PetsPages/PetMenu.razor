@page "/Mascotas"
@using SocioWeb.ViewModels
@inject PetsMenuVM Vm
@inject NavigationManager Nav

<!-- ================= FILTROS ================= -->

<RadzenStack Orientation="Orientation.Horizontal"
             AlignItems="AlignItems.Center"
             Gap="10"
             Style="padding:10px 20px">

    <RadzenText Text="Mascotas" TextStyle="TextStyle.H5"/>

    <RadzenTextBox @bind-Value="Vm.NameFilter"
                   Placeholder="Nombre mascota"
                   Style="width:180px"/>

    <RadzenTextBox @bind-Value="Vm.SpecieFilter"
                   Placeholder="Especie"
                   Style="width:150px"/>

    <RadzenButton Icon="filter_alt"
                  Text="Filtrar"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="@Vm.ApplyFilters"/>
</RadzenStack>


<!-- ================= LISTADO ================= -->
<RadzenRow>
    <RadzenColumn Size="12">

        @foreach (var mascota in Vm.FilteredPets)
        {
            <div style="cursor:pointer;"
                 @onclick="@(() => Nav.NavigateTo($"/PerfilMascota/{mascota.Id}"))">

                <RadzenCard Style="
                            margin-bottom:30px;
                            border-radius:16px;
                            box-shadow:0 4px 20px rgba(0,0,0,0.1);
                            overflow:hidden;">

                    <!-- HEADER -->
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 AlignItems="AlignItems.Center"
                                 JustifyContent="JustifyContent.SpaceBetween"
                                 Style="
                                    padding:20px;
                                    background:linear-gradient(135deg,#ff9a9e 0%,#fad0c4 100%);
                                    color:white;">

                        <RadzenStack Orientation="Orientation.Horizontal"
                                     AlignItems="AlignItems.Center"
                                     Gap="15">

                            <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png"
                                          Size="70px"
                                          Style="border:3px solid white;"/>

                            <RadzenStack Gap="2">
                                <RadzenText Text="@mascota.Name"
                                            Style="font-size:22px; font-weight:600;"/>
                                <RadzenText Text="@mascota.Specie"
                                            Style="opacity:0.9; font-size:13px;"/>
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenButton Icon="person"
                                      Text="Dueño"
                                      ButtonStyle="ButtonStyle.Light"
                                      Style="background:transparent; color:white;"
                                      Click="@(() => Vm.ToggleOwner(mascota.Id))"
                                      @onclick:stopPropagation="true"/>
                    </RadzenStack>

                    <!-- INFO -->
                    <RadzenStack Style="padding:20px;">
                        <RadzenRow>
                            <RadzenColumn Size="6">
                                <RadzenText Text="🐾 Raza"
                                            Style="font-weight:600;"/>
                                <RadzenText Text="@mascota.Breed"/>

                                <RadzenText Text="🎂 Edad"
                                            Style="font-weight:600; margin-top:10px;"/>
                                <RadzenText Text="@($"{mascota.Age} años")"/>
                            </RadzenColumn>

                            <RadzenColumn Size="6">
                                <RadzenText Text="⚖️ Peso"
                                            Style="font-weight:600;"/>
                                <RadzenText Text="@($"{mascota.Weight} kg")"/>
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenStack>

                    <!-- DUEÑO -->
                    @if (Vm.VisibleOwners.Contains(mascota.Id))
                    {
                        <RadzenCard Style="margin:20px; border-radius:16px;">

                            <RadzenStack Orientation="Orientation.Horizontal"
                                         AlignItems="AlignItems.Center"
                                         Gap="15"
                                         Style="
                                            padding:20px;
                                            background:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%);
                                            color:white;">

                                <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/616/616408.png"
                                              Size="60px"/>

                                <RadzenStack Gap="2">
                                    <RadzenLink Path="@($"/PerfilDueno/{mascota.Owner.Id}")"
                                                Style="text-decoration:none; color:white;">
                                        <RadzenText Text="@mascota.Owner.Name"
                                                    Style="font-size:18px; font-weight:600;"/>
                                    </RadzenLink>

                                    <RadzenText Text="@mascota.Owner.Email"
                                                Style="font-size:13px; opacity:0.9;"/>
                                </RadzenStack>
                            </RadzenStack>

                            <RadzenStack Style="padding:20px;">
                                <RadzenText Text="📞 Teléfono"
                                            Style="font-weight:600;"/>
                                <RadzenText Text="@mascota.Owner.Phone"/>

                                <RadzenText Text="🏠 Dirección"
                                            Style="font-weight:600; margin-top:10px;"/>
                                <RadzenText Text="@mascota.Owner.Street"/>
                            </RadzenStack>

                        </RadzenCard>
                    }

                </RadzenCard>
            </div>
        }

    </RadzenColumn>
</RadzenRow>

@code {

    protected override async Task OnInitializedAsync()
    {
        await Vm.LoadAsync();
    }

}

