@page "/AppointmentProfile/{id}"
@using SocioWeb.ViewModels.Appointments
@inject NavigationManager Nav
@inject AppointmentProfileViewModel VM

@if (VM.IsLoading)
                 {
                     <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"/>
                 }
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage"/>
}

<RadzenCard>
    <RadzenStack Orientation="Orientation.Horizontal" Gap="25"
                 AlignItems="AlignItems.Center" Style="margin-bottom:30px;">

        <RadzenCard Style="width:120px; height:120px; border-radius:50%; background:#e0e7ff;
                           display:flex; align-items:center; justify-content:center; font-size:50px;">
            🐶
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@VM.Appointment.PetName" TextStyle="TextStyle.H4"/>
            <RadzenText Text="Cita veterinaria" Style="color:#777;"/>

            @if (!VM.IsEditing)
            {
                <RadzenButton Text="Editar cita" Icon="edit"
                              Style="border-radius:10px;"
                              Click="@(() => VM.IsEditing = true)"/>
            }
            else
            {
                <RadzenButton Text="Cancelar" Icon="close"
                              ButtonStyle="ButtonStyle.Danger"
                              Style="border-radius:10px;"
                              Click="@VM.Cancel"/>
            }
            <RadzenButton Text="Eliminar cita" Icon="delete"
                          ButtonStyle="ButtonStyle.Danger"
                          Style="border-radius:10px; margin-left:10px;"
                          Click="@OnDelete"/>
        </RadzenStack>
    </RadzenStack>

    <RadzenText Text="Información de la cita" TextStyle="TextStyle.H5" Style="margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Mascota",   VM.Appointment.PetName,   v => VM.Appointment.PetName   = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Dueño",     VM.Appointment.OwnerName, v => VM.Appointment.OwnerName = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Teléfono",  VM.Appointment.Phone,     v => VM.Appointment.Phone     = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Estado",    VM.Appointment.Status,    v => VM.Appointment.Status    = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Fecha y hora",
            VM.Appointment.Date.ToString("dd/MM/yyyy HH:mm"),
            v => VM.Appointment.Date = DateTime.Parse(v))</RadzenColumn>
        <RadzenColumn Size="12">@Campo("Motivo", VM.Appointment.Reason, v => VM.Appointment.Reason = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;"/>

    <RadzenText Text="Registro del sistema" TextStyle="TextStyle.H5" Style="margin-bottom:20px;"/>
    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Creado el", VM.Appointment.CreatedAt.ToLocalTime().ToString(), null)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Última actualización", VM.Appointment.UpdatedAt?.ToLocalTime().ToString(), null)</RadzenColumn>
    </RadzenRow>

    @if (VM.IsEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios" Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Style="background:#4b3e48; color:white; border-radius:10px;"
                          Click="@(async () => await VM.SaveAsync())"/>
        </RadzenStack>
    }
</RadzenCard>

@code {
    [Parameter] public string id { get; set; } = "";

    protected override async Task OnInitializedAsync() => await VM.LoadAsync(id);

    async Task OnDelete()
    {
        if (await VM.DeleteAsync()) Nav.NavigateTo("/Citas");
    }

    RenderFragment Campo(string label, string? valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;"/>
            @if (!VM.IsEditing)
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e.ToString()))"
                               Style="width:100%; background:white; border-radius:10px;"/>
            }
            else
            {
                <RadzenText Text="@valor" Style="font-size:18px; color:#333;"/>
            }
        </RadzenStack>;
    };
}