@page "/PerfilProducto/{Id}"
@inject NavigationManager Nav
@inject ProductProfileViewModel VM

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                       Style="margin-bottom:1rem;" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true" />
}

<RadzenCard>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="25"
                 AlignItems="AlignItems.Center" Style="margin-bottom:30px;">

        <RadzenCard Style="width:120px; height:120px; border-radius:50%; background:#d9d9d9;
                           display:flex; align-items:center; justify-content:center; font-size:50px;">
            📦
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@VM.Product.Name"
                        Style="font-size:24px; font-weight:600; color:#333;" />
            <RadzenBadge BadgeStyle="@(VM.Product.IsActive ? BadgeStyle.Success : BadgeStyle.Secondary)"
                         Text="@(VM.Product.IsActive ? "Activo" : "Inactivo")" />
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8">
                <RadzenButton Text="Editar" Icon="edit"
                              ButtonStyle="ButtonStyle.Warning"
                              Style="border-radius:10px;"
                              Click="@(() => Nav.NavigateTo($"/EditarProducto/{Id}"))" />
                <RadzenButton Text="Volver" Icon="arrow_back"
                              ButtonStyle="ButtonStyle.Light"
                              Style="border-radius:10px;"
                              Click="@(() => Nav.NavigateTo("/Productos"))" />
            </RadzenStack>
        </RadzenStack>
    </RadzenStack>

    <RadzenText Text="Información del producto"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;" />

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre",         VM.Product.Name)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Categoría",      VM.Product.Category ?? "—")</RadzenColumn>
        <RadzenColumn Size="6">@Campo("SKU",            VM.Product.Sku ?? "—")</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Código barras",  VM.Product.Barcode ?? "—")</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Precio",         $"{VM.Product.Price:C}")</RadzenColumn>
        <RadzenColumn Size="6">@Campo("IVA (%)",        VM.Product.TaxRate.ToString("F2"))</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Stock",          VM.Product.Stock.ToString())</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Stock mínimo",   VM.Product.MinStock.ToString())</RadzenColumn>
        <RadzenColumn Size="12">@Campo("Descripción",   VM.Product.Description ?? "—")</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;" />

    <RadzenText Text="Registro del sistema"
                Style="color:#4b3e48; font-size:20px; font-weight:600; margin-bottom:20px;" />

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Creado el",             VM.Product.CreatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Última actualización",  VM.Product.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</RadzenColumn>
        <RadzenColumn Size="6">@Campo("ID clínica",            VM.Product.ClinicId)</RadzenColumn>
    </RadzenRow>

</RadzenCard>

@code {
    [Parameter] public string Id { get; set; } = "";

    protected override async Task OnInitializedAsync() => await VM.LoadAsync(Id);

    RenderFragment Campo(string label, string? valor) => __builder =>
    {
        <RadzenStack Gap="4">
            <RadzenText Text="@label" Style="color:#777; font-size:12px; font-weight:600; text-transform:uppercase;" />
            <RadzenText Text="@(valor ?? "—")" Style="font-size:17px; color:#333;" />
        </RadzenStack>;
    };
}
