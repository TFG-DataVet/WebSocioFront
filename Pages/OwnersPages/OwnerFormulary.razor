@page "/DuenoFormulario"
@using SocioWeb.ViewModels.OwnerVM
@inject OwnerFormularyVM Vm

<RadzenStack Gap="20px" Style="max-width:900px; margin:auto;">
    <RadzenText Text="¡Queremos conocerte!" TextStyle="TextStyle.H3"
                Style="color:#4b3e48; font-weight:bold;"/>
    <RadzenText Text="Cuéntanos un poco sobre ti." TextStyle="TextStyle.H5"
                Style="color:#6d5d66;"/>

    @if (!string.IsNullOrWhiteSpace(Vm.ErrorMessage))
    {
        <RadzenAlert Severity="AlertSeverity.Error">@Vm.ErrorMessage</RadzenAlert>
    }

    <EditForm Model="@Vm.Owner" OnValidSubmit="Vm.SaveAsync">
        <DataAnnotationsValidator/>

        <RadzenStack Gap="25px" Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap">

            <RadzenStack Gap="10px" Style="flex:1 1 45%;">
                <RadzenLabel Text="Nombre"/>
                <RadzenTextBox @bind-Value="Vm.Owner.Name" Placeholder="Tu nombre" Style="width:100%;"/>
                <RadzenRequiredValidator Component="Name" Text="Obligatorio"/>
            </RadzenStack>

            <RadzenStack Gap="10px" Style="flex:1 1 45%;">
                <RadzenLabel Text="Apellido"/>
                <RadzenTextBox @bind-Value="Vm.Owner.LastName" Placeholder="Tu apellido" Style="width:100%;"/>
                <RadzenRequiredValidator Component="LastName" Text="Obligatorio"/>
            </RadzenStack>

            <RadzenStack Gap="10px" Style="flex:1 1 45%;">
                <RadzenLabel Text="Número Identificación"/>
                <RadzenTextBox @bind-Value="Vm.Owner.IdentificationNumber" Placeholder="Tu número de identificación"
                               Style="width:100%;"/>
                <RadzenRequiredValidator Component="IdentificationNumber" Text="Obligatorio"/>
            </RadzenStack>

            <RadzenStack Gap="10px" Style="flex:1 1 45%;">
                <RadzenLabel Text="Teléfono"/>
                <RadzenTextBox @bind-Value="Vm.Owner.Phone" Placeholder="Tu teléfono" Style="width:100%;"/>
            </RadzenStack>

            <RadzenStack Gap="10px" Style="flex:1 1 45%;">
                <RadzenLabel Text="Email"/>
                <RadzenTextBox @bind-Value="Vm.Owner.Email" Placeholder="email@ejemplo.com" Style="width:100%;"/>
                <RadzenEmailValidator Component="Email" Text="Email inválido"/>
            </RadzenStack>

            <RadzenStack Gap="10px" Style="flex:1 1 45%;">
                <RadzenLabel Text="Calle"/>
                <RadzenTextBox @bind-Value="Vm.Owner.Street" Placeholder="Calle/Número..." Style="width:100%;"/>
            </RadzenStack>

            <RadzenStack Gap="10px" Style="flex:1 1 30%;">
                <RadzenLabel Text="Código Postal"/>
                <RadzenTextBox @bind-Value="Vm.Owner.PostalCode" Placeholder="Código postal" Style="width:100%;"/>
            </RadzenStack>

            <RadzenStack Gap="10px" Style="flex:1 1 30%;">
                <RadzenLabel Text="Ciudad"/>
                <RadzenTextBox @bind-Value="Vm.Owner.City" Placeholder="Ciudad" Style="width:100%;"/>
            </RadzenStack>

        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                     Style="margin-top:40px;">
            <RadzenButton Text="Guardar" Style="width:120px; border-radius:20px; background:white; color:#4b3e48;"
                          ButtonType="ButtonType.Submit" Disabled="@Vm.IsSaving"/>
            <RadzenButton Text="Añadir Mascota ➜"
                          Style="width:140px; border-radius:20px; background:#4b3e48; color:white;"
                          Click="@Vm.NavigateToNewPet"/>
        </RadzenStack>

    </EditForm>
</RadzenStack>