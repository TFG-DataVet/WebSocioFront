@page "/Mascotas"
@inject NavigationManager Nav

<!-- ================= FILTROS ================= -->

<RadzenStack Orientation="Orientation.Horizontal"
             AlignItems="AlignItems.Center"
             Gap="10"
             Style="padding:10px 20px">

    <RadzenText Text="Mascotas" TextStyle="TextStyle.H5"/>

    <RadzenTextBox @bind-Value="filtroNombre"
                   Placeholder="Nombre mascota"
                   Style="width:180px"/>

    <RadzenTextBox @bind-Value="filtroEspecie"
                   Placeholder="Especie"
                   Style="width:150px"/>

    <RadzenButton Icon="filter_alt"
                  Text="Filtrar"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="@AplicarFiltros"/>
</RadzenStack>


<!-- ================= TABLA ================= -->
<RadzenRow>
    <RadzenColumn Size="12">

        @foreach (var mascota in mascotasFiltradas)
        {
            <!-- DIV envolvente para capturar el click -->
            <div style="cursor:pointer;" @onclick="@(() => IrAPerfilMascota(mascota.Id))">

                <RadzenCard Style="
                            margin-bottom:30px;
                            border-radius:16px;
                            box-shadow:0 4px 20px rgba(0,0,0,0.1);
                            overflow:hidden;">

                    <!-- HEADER MASCOTA -->
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 AlignItems="AlignItems.Center"
                                 JustifyContent="JustifyContent.SpaceBetween"
                                 Style="
                                            padding:20px;
                                            background:linear-gradient(135deg,#ff9a9e 0%,#fad0c4 100%);
                                            color:white;">

                        <RadzenStack Orientation="Orientation.Horizontal"
                                     AlignItems="AlignItems.Center"
                                     Gap="15">

                            <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png"
                                          Size="70px"
                                          Style="border:3px solid white;"/>

                            <RadzenStack Gap="2">
                                <RadzenText 
                                    Text="@mascota.Name"
                                    Style="font-size:22px; font-weight:600;"/>
                                <RadzenText 
                                    Text="@mascota.Specie"
                                    Style="opacity:0.9; font-size:13px;"/>
                            </RadzenStack>
                        </RadzenStack>

                        <!-- BOTÓN DUEÑO -->
                        <RadzenButton 
                            Icon="person"
                            Text="Dueño"
                            ButtonStyle="ButtonStyle.Light"
                            Style="background:transparent; color:white;"
                            Click="@(() => ToggleDueno(mascota.Id))"
                            @onclick:stopPropagation="true"/>
                    </RadzenStack>

                    <!-- INFO MASCOTA -->
                    <RadzenStack Style="padding:20px;">
                        <RadzenRow>
                            <RadzenColumn Size="6">
                                <RadzenText 
                                    Text="🐾 Raza"
                                    Style="font-weight:600;"/>
                                <RadzenText 
                                    Text="@mascota.Breed"/>

                                <RadzenText 
                                    Text="🎂 Edad"
                                    Style="font-weight:600; margin-top:10px;"/>
                                <RadzenText 
                                    Text="@($"{mascota.Age} años")"/>
                            </RadzenColumn>

                            <RadzenColumn Size="6">
                                <RadzenText 
                                    Text="⚖️ Peso"
                                    Style="font-weight:600;"/>
                                
                                <RadzenText Text="@($"{mascota.Weight} kg")"/>
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenStack>

                    <!-- DUEÑO DESPLEGABLE -->
                    @if (duenosVisibles.Contains(mascota.Id))
                    {
                        <RadzenCard Style="
                                    margin:20px;
                                    border-radius:16px;
                                    overflow:hidden;">

                            <RadzenStack Orientation="Orientation.Horizontal"
                                         AlignItems="AlignItems.Center"
                                         Gap="15"
                                         Style="
                                                    padding:20px;
                                                    background:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%);
                                                    color:white;">

                                <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/616/616408.png"
                                              Size="60px"/>

                                <RadzenStack Gap="2">
                                    <RadzenLink Path="@($"/PerfilDueno/{mascota.Dueno.Id}")"
                                                Style="text-decoration:none; color:white;">
                                        <RadzenText Text="@mascota.Dueno.Name"
                                                    Style="font-size:18px; font-weight:600;"/>
                                    </RadzenLink>

                                    <RadzenText Text="@mascota.Dueno.Email"
                                                Style="font-size:13px; opacity:0.9;"/>
                                </RadzenStack>
                            </RadzenStack>

                            <RadzenStack Style="padding:20px;">
                                <RadzenText Text="📞 Teléfono"
                                            Style="font-weight:600;"/>
                                <RadzenText Text="@mascota.Dueno.Phone"/>

                                <RadzenText Text="🏠 Dirección"
                                            Style="font-weight:600; margin-top:10px;"/>
                                <RadzenText Text="@mascota.Dueno.Street"/>
                            </RadzenStack>

                        </RadzenCard>
                    }

                </RadzenCard>
            </div>
            <!-- fin div clickeable -->
        }

    </RadzenColumn>
</RadzenRow>
    
@code {

    List<Domain.Entities.Pet> mascotas = new();
    List<Domain.Entities.Pet> mascotasFiltradas = new();

    string filtroNombre = "";
    string filtroEspecie = "";

    HashSet<string> duenosVisibles = new();

    protected override void OnInitialized()
    {
        var dueno1 = new Dueno
        {
            Id = "1",
            Name = "Juan Pérez",
            Email = "juan@email.com",
            Phone = "123456789",
            Street = "Av. Siempre Viva 742"
        };

        var dueno2 = new Dueno
        {
            Id = "2",
            Name = "María López",
            Email = "maria@email.com",
            Phone = "987654321",
            Street = "Calle Falsa 123"
        };

        mascotas = new List<Domain.Entities.Pet>
        {
            new Domain.Entities.Pet
            {
                Id = "M1",
                Name = "Rocky",
                Specie = "Perro",
                Breed = "Labrador",
                Age = 5,
                Weight = 28,
                Dueno = dueno1
            },
            new Domain.Entities.Pet
            {
                Id = "M2",
                Name = "Michi",
                Specie = "Gato",
                Breed = "Siames",
                Age = 3,
                Weight = 6,
                Dueno = dueno2
            }
        };

        mascotasFiltradas = mascotas;
    }

    void AplicarFiltros()
    {
        mascotasFiltradas = mascotas
            .Where(m =>
                (string.IsNullOrEmpty(filtroNombre) ||
                 m.Name.Contains(filtroNombre, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrEmpty(filtroEspecie) ||
                 m.Specie.Contains(filtroEspecie, StringComparison.OrdinalIgnoreCase))
            )
            .ToList();
    }

    void ToggleDueno(string mascotaId)
    {
        if (duenosVisibles.Contains(mascotaId))
            duenosVisibles.Remove(mascotaId);
        else
            duenosVisibles.Add(mascotaId);
    }

    void IrAPerfilMascota(string idMascota)
    {
        Nav.NavigateTo($"/PerfilMascota/{idMascota}");
    }
}
