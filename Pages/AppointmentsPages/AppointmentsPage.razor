@page "/Citas"
@using SocioWeb.ViewModels.Appointments
@inject NavigationManager Nav
@inject AppointmentListViewModel VM

@if (VM.IsLoading)
                 {
                     <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"/>
                 }
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage"/>
}

<!-- ================= FILTROS ================= -->
<RadzenStack Orientation="Orientation.Horizontal"
             AlignItems="AlignItems.Center"
             Gap="10"
             Style="padding:10px 20px">

    <RadzenText Text="Citas Veterinarias" TextStyle="TextStyle.H5"/>

    <RadzenDatePicker @bind-Value="VM.DateSince" Placeholder="Desde" Style="width:160px"/>
    <RadzenDatePicker @bind-Value="VM.DateTo" Placeholder="Hasta" Style="width:160px"/>

    <RadzenDropDown Data="@VM.States"
                    @bind-Value="VM.StatusFilter"
                    Placeholder="Estado"
                    Style="width:150px"/>

    <RadzenTextBox @bind-Value="VM.SearchFilter"
                   Placeholder="Mascota o Dueño"
                   Style="width:200px"/>

    <RadzenButton Icon="event" Text="Filtrar"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="@VM.ApplyFilters"/>

    <RadzenButton Text="Crear cita" Icon="add_circle"
                  Click="@(() => Nav.NavigateTo("/CreateAppointment"))"/>
</RadzenStack>

<!-- ================= LISTA ================= -->
<RadzenRow>
    <RadzenColumn Size="12">
        @foreach (var cita in VM.FilteredAppointments)
        {
            <RadzenCard Style="margin-bottom:25px; border-radius:16px; box-shadow:0 4px 20px rgba(0,0,0,0.1); cursor:pointer;"
                        @onclick="@(() => Nav.NavigateTo($"/AppointmentProfile/{cita.Id}"))">

                <RadzenStack Orientation="Orientation.Horizontal"
                             JustifyContent="JustifyContent.SpaceBetween"
                             AlignItems="AlignItems.Center"
                             Style="padding:20px; background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); color:white;">
                    <RadzenStack>
                        <RadzenText Text="@cita.PetName" Style="font-size:22px; font-weight:600;"/>
                        <RadzenText Text="@($"Dueño: {cita.OwnerName}")" Style="opacity:0.9; font-size:13px;"/>
                    </RadzenStack>
                    <RadzenText Text="@cita.Status" Style="font-weight:600;"/>
                </RadzenStack>

                <RadzenStack Style="padding:20px;">
                    <RadzenRow>
                        <RadzenColumn Size="6">
                            <RadzenLabel Text="📅 Fecha y Hora" Style="font-weight:600;"/>
                            <RadzenText Text="@cita.Date.ToString("dd/MM/yyyy HH:mm")"/>
                            <RadzenLabel Text="📞 Contacto" Style="font-weight:600; margin-top:10px;"/>
                            <RadzenText Text="@cita.Phone"/>
                        </RadzenColumn>
                        <RadzenColumn Size="6">
                            <RadzenLabel Text="📝 Motivo" Style="font-weight:600;"/>
                            <RadzenText Text="@cita.Reason"/>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>

            </RadzenCard>
        }
    </RadzenColumn>
</RadzenRow>

@code {
    protected override async Task OnInitializedAsync() => await VM.LoadAsync();
}