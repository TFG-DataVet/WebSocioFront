@page "/Calendario"
@using SocioWeb.Domain.Entities
@inject AppointmentService AppointmentService
@inject NavigationManager Nav

<RadzenStack Gap="10" Style="padding:20px">
    
    <RadzenCard Style="
    background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
    color: white;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    margin-bottom: 1.5rem;
    padding: 1.5rem 2rem;">
    
        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween"
                     Wrap="FlexWrap.Wrap"
                     Gap="10">

            <RadzenStack Gap="2">
                <RadzenText Text="Calendario de Citas"
                            Style="font-size:28px; font-weight:700; color:white;" />
                <RadzenText Text="@($"{appointments.Count} citas registradas")"
                            Style="font-size:13px; opacity:0.85; color:white;" />
            </RadzenStack>

            <RadzenButton Text="Nueva Cita"
                          Icon="add_circle"
                          Style="background:white; color:#ff7e5f; font-weight:600; border-radius:10px;"
                          Click="@CreateAppointment" />
        </RadzenStack>
    </RadzenCard>

    <!-- CALENDARIO -->
    <RadzenScheduler TItem="Appointment"
                     Data="@appointments"
                     StartProperty="Start"
                     EndProperty="End"
                     TextProperty="PetName"
                     SlotSelect="@OnSlotSelect"
                     AppointmentSelect="@OnAppointmentSelect"
                     Style="height:800px">

        <RadzenDayView />
        <RadzenWeekView />
        <RadzenMonthView />
        <RadzenYearView />

    </RadzenScheduler>

</RadzenStack>

@code {

    List<Appointment> appointments = new();

    protected override void OnInitialized()
    {
        // Cargar citas desde el servicio
        appointments = AppointmentService.Appointments.ToList();
    }

    void OnSlotSelect(SchedulerSlotSelectEventArgs args)
    {
        Nav.NavigateTo($"/CreateAppointment?date={args.Start:O}");
    }

    void OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<Appointment> args)
    {
        Nav.NavigateTo($"/AppointmentProfile/{args.Data.Id}");
    }

    void CreateAppointment()
    {
        Nav.NavigateTo("/CreateAppointment");
    }
}