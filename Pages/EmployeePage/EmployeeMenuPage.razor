@page "/Employee"
@using SocioWeb.Entities.Models.Employee
@using SocioWeb.ViewModels.Employee
@inject NavigationManager Nav
@inject EmployeeListViewModel VM
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (VM.IsLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                       Style="margin-bottom:1rem;" />
}
@if (VM.HasError)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@VM.ErrorMessage" AllowClose="true" />
}

<PageTitle>Empleados</PageTitle>

<!-- HEADER -->
<RadzenCard Style="
    background: linear-gradient(135deg, #f8c30f 0%, #e6b800 100%);
    color: black;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.35);
    margin-bottom: 1.5rem;
    padding: 1.5rem 2rem;">
    
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Wrap="FlexWrap.Wrap"
                 Gap="10">

        <RadzenStack Gap="2">
            <RadzenText Text="Gestión de Empleados"
                        Style="font-size:28px; font-weight:700; color:black;" />
            <RadzenText Text="@($"{VM.FilteredEmployees.Count} registros encontrados")"
                        Style="font-size:13px; opacity:0.85;" />
        </RadzenStack>

        <RadzenButton Text="Nuevo Empleado"
                      Icon="person_add"
                      Style="background:black; color:#f8c30f; font-weight:600; border-radius:10px;"
                      Click="@(() => Nav.NavigateTo("/CreateEmployee"))" />
    </RadzenStack>
</RadzenCard>

<!-- FILTROS -->
<RadzenCard Style="border-radius:12px; margin-bottom:1.5rem; padding:1.2rem 1.5rem;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.End"
                 Wrap="FlexWrap.Wrap"
                 Gap="12">

        <RadzenStack Gap="4">
            <RadzenLabel Text="Desde" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenDatePicker @bind-Value="VM.DateSince" Style="width:155px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Hasta" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenDatePicker @bind-Value="VM.DateTo" Style="width:155px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Ciudad" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenTextBox @bind-Value="VM.CityFilter" Style="width:140px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Código Postal" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenTextBox @bind-Value="VM.PostalCodeFilter" Style="width:140px" />
        </RadzenStack>

        <RadzenStack Gap="4">
            <RadzenLabel Text="Nombre o Email" Style="font-size:12px; font-weight:600; color:#777;" />
            <RadzenTextBox @bind-Value="VM.SearchFilter" Style="width:180px" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8">
            <RadzenButton Icon="filter_alt" Text="Filtrar"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@VM.ApplyFilters" />
            <RadzenButton Icon="clear" Text="Limpiar"
                          ButtonStyle="ButtonStyle.Light"
                          Click="@VM.ClearFilters" />
        </RadzenStack>
    </RadzenStack>
</RadzenCard>

<!-- TABLA -->
<RadzenCard Style="border-radius:12px; padding:0; overflow:hidden;">
    <RadzenDataGrid Data="@VM.FilteredEmployees"
                    TItem="Employee"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="10"
                    ShowPagingSummary="true"
                    PagingSummaryFormat="Página {0} de {1} — Total: {2}"
                    EmptyText="No se encontraron empleados."
                    Style="border:none;">

        <Columns>

            <!-- Empleado -->
            <RadzenDataGridColumn TItem="Employee" Title="Empleado" Width="220px">
                <Template Context="employee">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10">
                        <RadzenAvatar Image="@(employee.AvatarUrl ?? "https://cdn-icons-png.flaticon.com/512/3135/3135715.png")" Size="38px" />
                        <RadzenStack Gap="0">
                            <RadzenText Text="@($"{employee.FirstName} {employee.LastName}")" Style="font-weight:600;" />
                            <RadzenText Text="@employee.Speciality" Style="font-size:12px; color:#888;" />
                        </RadzenStack>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <!-- Rol -->
            <RadzenDataGridColumn TItem="Employee" Property="Role" Title="Rol" Width="130px" />

            <!-- Teléfono -->
            <RadzenDataGridColumn TItem="Employee" Property="Phone" Title="Teléfono" Width="130px" />

            <!-- Email -->
            <RadzenDataGridColumn TItem="Employee" Property="Email" Title="Email" Width="180px" />

            <!-- Ciudad -->
            <RadzenDataGridColumn TItem="Employee" Property="City" Title="Ciudad" Width="130px" />

            <!-- Acciones -->
            <RadzenDataGridColumn TItem="Employee" Title="Acciones" Width="140px" Sortable="false">
                <Template Context="employee">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6">

                        <RadzenButton Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small"
                                      Click="@(() => Nav.NavigateTo($"/ProfileEmployee/{employee.Id}"))" />

                        <RadzenButton Icon="edit"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Small"
                                      Click="@(() => Nav.NavigateTo($"/EditEmployee/{employee.Id}"))" />

                        <RadzenButton Icon="delete"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Small"
                                      Click="@(async () => await ConfirmDelete(employee))" />

                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {

    protected override async Task OnInitializedAsync()
        => await VM.LoadAsync();

    async Task ConfirmDelete(Employee employee)
    {
        var result = await DialogService.Confirm(
            $"¿Eliminar a {employee.FirstName} {employee.LastName}? Esta acción no se puede deshacer.",
            "Confirmar eliminación",
            new ConfirmOptions { OkButtonText = "Eliminar", CancelButtonText = "Cancelar" });

        if (result == true)
        {
            await VM.DeleteAsync(employee.Id);

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Eliminado",
                Detail = $"{employee.FirstName} {employee.LastName} fue eliminado correctamente.",
                Duration = 3000
            });
        }
    }
}