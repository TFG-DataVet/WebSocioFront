@page "/Duenos"
@inject NavigationManager Nav

<PageTitle>Dueños</PageTitle>

<!-- ================= FILTROS ================= -->

<RadzenStack Orientation="Orientation.Horizontal"
             AlignItems="AlignItems.Center"
             Gap="10"
             Style="padding:10px 20px">

    <RadzenText Text="Dueños" TextStyle="TextStyle.H5"/>

    <RadzenDatePicker @bind-Value="fechaDesde"
                      Placeholder="Desde"
                      Style="width:160px"/>

    <RadzenDatePicker @bind-Value="fechaHasta"
                      Placeholder="Hasta"
                      Style="width:160px"/>

    <RadzenTextBox @bind-Value="filtroCiudad"
                   Placeholder="Ciudad"
                   Style="width:150px"/>

    <RadzenTextBox @bind-Value="filtroCodigoPostal"
                   Placeholder="Código Postal"
                   Style="width:120px"/>

    <RadzenButton Icon="filter_alt"
                  Text="Filtrar"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="AplicarFiltros"/>
</RadzenStack>

<!-- ================= BODY ================= -->

<RadzenRow>
    <RadzenColumn Size="12">

        @foreach (var dueno in duenosFiltrados)
        {
            <RadzenCard Style="
                        margin-bottom:30px;
                        border-radius:16px;
                        box-shadow:0 4px 20px rgba(0,0,0,0.1);
                        overflow:hidden;
                        cursor:pointer;"
                        Click="@(() => Nav.NavigateTo($"/PerfilDueno/{dueno.Id}"))">

                <!-- HEADER DUEÑO -->
                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween"
                             Style="
                                        padding:20px;
                                        background:linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
                                        color:white;">

                    <RadzenStack Orientation="Orientation.Horizontal"
                                 AlignItems="AlignItems.Center"
                                 Gap="15">

                        <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/616/616408.png"
                                      Size="70px"
                                      Style="border:3px solid white;"/>

                        <RadzenStack Gap="2">
                            <RadzenLink Path="@($"/PerfilDueno/{dueno.Id}")"
                                        Style="text-decoration:none; color:white;">
                                <RadzenText Text="@dueno.Name"
                                            Style="font-size:22px; font-weight:600;"/>
                            </RadzenLink>

                            <RadzenText Text="@($"Cliente desde {dueno.CreatedAt:yyyy}")"
                                        Style="opacity:0.9; font-size:13px;"/>
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenButton Icon="more_vert"
                                  ButtonStyle="ButtonStyle.Light"
                                  Style="background:transparent; color:white;"
                                  Click="@(() => ToggleMascotas(dueno.Id))"/>
                </RadzenStack>

                <!-- INFO DUEÑO -->
                <RadzenStack Gap="15" Style="padding:20px;">
                    <RadzenRow>
                        <RadzenColumn Size="6">
                            <RadzenText Text="📞 Teléfono" Style="font-weight:600;"/>
                            <RadzenText Text="@dueno.Phone"/>

                            <RadzenText Text="📧 Email" Style="font-weight:600; margin-top:10px;"/>
                            <RadzenText Text="@dueno.Email"/>
                        </RadzenColumn>

                        <RadzenColumn Size="6">
                            <RadzenText Text="🏠 Dirección" Style="font-weight:600;"/>
                            <RadzenText Text="@dueno.Street"/>

                            <RadzenText Text="📝 Notas" Style="font-weight:600; margin-top:10px;"/>
                            <RadzenText Text="@dueno.Coments"/>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>

                <!-- MASCOTAS -->
                @if (mascotasVisibles.Contains(dueno.Id))
                {
                    @foreach (var mascota in dueno.Pet)
                    {
                        <RadzenCard Style="
                                    margin:20px;
                                    border-radius:16px;
                                    overflow:hidden;">

                            <RadzenStack Orientation="Orientation.Horizontal"
                                         AlignItems="AlignItems.Center"
                                         Gap="15"
                                         Style="
                                                    padding:20px;
                                                    background:linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
                                                    color:white;">

                                <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png"
                                              Size="60px"/>

                                <RadzenStack Gap="2">
                                    <RadzenText Text="@mascota.Name"
                                                Style="font-size:20px; font-weight:600;"/>
                                    <RadzenText Text="@($"Mascota de {dueno.Name}")"
                                                Style="font-size:13px; opacity:0.9;"/>
                                </RadzenStack>
                            </RadzenStack>

                            <RadzenStack Style="padding:20px;">
                                <RadzenRow>
                                    <RadzenColumn Size="6">
                                        <RadzenText Text="🐾 Especie" Style="font-weight:600;"/>
                                        <RadzenText Text="@mascota.Specie"/>

                                        <RadzenText Text="🐶 Raza"
                                                    Style="font-weight:600; margin-top:10px;"/>
                                        <RadzenText Text="@mascota.Breed"/>
                                    </RadzenColumn>

                                    <RadzenColumn Size="6">
                                        <RadzenText Text="🎂 Edad" Style="font-weight:600;"/>
                                        <RadzenText Text="@($"{mascota.Age} años")"/>
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenStack>

                        </RadzenCard>
                    }
                }

            </RadzenCard>
        }
    </RadzenColumn>
</RadzenRow>

@code {

    List<Dueno> duenos = new();
    List<Dueno> duenosFiltrados = new();

    DateTime? fechaDesde;
    DateTime? fechaHasta;

    string filtroCiudad = "";
    string filtroCodigoPostal = "";

    HashSet<string> mascotasVisibles = new();

    protected override void OnInitialized()
    {
        var dueno1 = new Dueno
        {
            Id = "1",
            Name = "Juan Pérez",
            Email = "juan@email.com",
            Phone = "123456789",
            Street = "Av. Siempre Viva 742",
            City = "Madrid",
            PostalCode = "28001",
            Coments = "Cliente frecuente",
            CreatedAt = new DateTime(2020, 5, 10),
            Pet = new List<Domain.Entities.Pet>
            {
                new Domain.Entities.Pet
                {
                    Name = "Rocky",
                    Specie = "Perro",
                    Breed = "Labrador",
                    Age = 5
                },
                new Domain.Entities.Pet
                {
                    Name = "Luna",
                    Specie = "Gato",
                    Breed = "Siames",
                    Age = 3
                }
            }
        };

        var dueno2 = new Dueno
        {
            Id = "2",
            Name = "María López",
            Email = "maria@email.com",
            Phone = "987654321",
            Street = "Calle Falsa 123",
            City = "Barcelona",
            PostalCode = "08001",
            Coments = "Nueva cliente",
            CreatedAt = new DateTime(2022, 3, 15),
            Pet = new List<Domain.Entities.Pet>
            {
                new Domain.Entities.Pet
                {
                    Name = "Michi",
                    Specie = "Gato",
                    Breed = "Criollo",
                    Age = 2
                }
            }
        };

        duenos = new List<Dueno> { dueno1, dueno2 };

        // Orden inicial
        duenos = duenos.OrderBy(d => d.CreatedAt).ToList();
        duenosFiltrados = duenos;
    }

    void AplicarFiltros()
    {
        duenosFiltrados = duenos
            .Where(d =>
                (!fechaDesde.HasValue || d.CreatedAt >= fechaDesde) &&
                (!fechaHasta.HasValue || d.CreatedAt <= fechaHasta) &&
                (string.IsNullOrEmpty(filtroCiudad) ||
                 d.City.Contains(filtroCiudad, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrEmpty(filtroCodigoPostal) ||
                 d.PostalCode.Contains(filtroCodigoPostal, StringComparison.OrdinalIgnoreCase))
            )
            .ToList();
    }

    void ToggleMascotas(string duenoId)
    {
        if (mascotasVisibles.Contains(duenoId))
            mascotasVisibles.Remove(duenoId);
        else
            mascotasVisibles.Add(duenoId);
    }
}


