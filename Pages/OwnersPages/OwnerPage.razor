@page "/Duenos"
@using SocioWeb.ViewModels.OwnerVM
@inject OwnerPageVM Vm
@inject NavigationManager Nav

<PageTitle>Dueños</PageTitle>

@if (Vm.IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
}

@if (!string.IsNullOrWhiteSpace(Vm.ErrorMessage))
{
    <RadzenAlert Severity="AlertSeverity.Error">
        @Vm.ErrorMessage
    </RadzenAlert>
}

<!-- ================= FILTROS ================= -->
<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10" Style="padding:10px 20px">
    <RadzenText Text="Dueños" TextStyle="TextStyle.H5"/>

    <RadzenDatePicker @bind-Value="Vm.DateSince" Placeholder="Desde" Style="width:160px"/>
    <RadzenDatePicker @bind-Value="Vm.DateTo" Placeholder="Hasta" Style="width:160px"/>
    <RadzenTextBox @bind-Value="Vm.CityFilter" Placeholder="Ciudad" Style="width:150px"/>
    <RadzenTextBox @bind-Value="Vm.PostalCodeFilter" Placeholder="Código Postal" Style="width:120px"/>

    <RadzenButton Icon="filter_alt" Text="Filtrar" ButtonStyle="ButtonStyle.Primary" Click="@Vm.ApplyFilters"/>
</RadzenStack>

<!-- ================= LISTA DE DUEÑOS ================= -->
<RadzenRow>
    <RadzenColumn Size="12">
        @foreach (var dueno in Vm.FilteredOwners)
        {
            var url = $"/PerfilDueno/{dueno.Id}";
            <RadzenCard Style="margin-bottom:30px; border-radius:16px; box-shadow:0 4px 20px rgba(0,0,0,0.1); overflow:hidden;">
                <!-- HEADER -->
                
                <div @onclick="() => Nav.NavigateTo(url)" style="cursor:pointer;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="padding:20px; background:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%); color:white;">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="15">
                            <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/616/616408.png" Size="70px" Style="border:3px solid white;"/>
                            <RadzenStack Gap="2">
                                <RadzenText Text="@dueno.Name" Style="font-size:22px; font-weight:600;"/>
                                <RadzenText Text="@($"Cliente desde {dueno.CreatedAt:yyyy}")" Style="opacity:0.9; font-size:13px;"/>
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenStack>
                </div>

                <!-- INFO -->
                <RadzenStack Gap="15" Style="padding:20px;">
                    <RadzenRow>
                        <RadzenColumn Size="6">
                            <RadzenText Text="📞 Teléfono" Style="font-weight:600;"/>
                            <RadzenText Text="@dueno.Phone"/>
                            <RadzenText Text="📧 Email" Style="font-weight:600; margin-top:10px;"/>
                            <RadzenText Text="@dueno.Email"/>
                        </RadzenColumn>

                        <RadzenColumn Size="6">
                            <RadzenText Text="🏠 Dirección" Style="font-weight:600;"/>
                            <RadzenText Text="@dueno.Street"/>
                            <RadzenText Text="📝 Notas" Style="font-weight:600; margin-top:10px;"/>
                            <RadzenText Text="@dueno.Coments"/>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>

                <!-- MASCOTAS -->
                @if (dueno.Pet != null && dueno.Pet.Any())
                {
                    <RadzenStack Gap="10" Style="padding:10px 20px;">
                        <RadzenText Text="Mascotas" Style="font-weight:600; font-size:16px;"/>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="10" Wrap="FlexWrap.Wrap">
                            @foreach (var mascota in dueno.Pet)
                            {
                                var url = $"/Mascota/{mascota.Id}";
                                <RadzenCard Style="width:180px; cursor:pointer;" @onclick="() => Nav.NavigateTo(url)">
                                    <RadzenStack AlignItems="AlignItems.Center" Gap="5" Style="padding:10px;">
                                        <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png" Size="50px"/>
                                        <RadzenText Text="@mascota.Name" Style="font-weight:600; font-size:14px;"/>
                                        <RadzenText Text="@($"Especie: {mascota.Specie}")" Style="font-size:12px;"/>
                                        <RadzenText Text="@($"Raza: {mascota.Breed}")" Style="font-size:12px;"/>
                                        <RadzenText Text="@($"{mascota.Age} años")" Style="font-size:12px;"/>
                                    </RadzenStack>
                                </RadzenCard>
                            }
                        </RadzenStack>
                    </RadzenStack>
                }
            </RadzenCard>
        }
    </RadzenColumn>
</RadzenRow>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Vm.LoadAsync();
    }
}