@page "/PerfilDueno/{Id}"
@using SocioWeb.ViewModels.OwnerVM
@inject OwnerProfileVM Vm

@if (Vm.IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
}

@if (!string.IsNullOrWhiteSpace(Vm.ErrorMessage))
{
    <RadzenAlert Severity="AlertSeverity.Error">
        @Vm.ErrorMessage
    </RadzenAlert>
}

@if (Vm.Owner != null)
{
<RadzenCard>

    <!-- CABECERA -->
    <RadzenStack Orientation="Orientation.Horizontal"
                 Gap="25"
                 AlignItems="AlignItems.Center"
                 Style="margin-bottom:30px;">

        <RadzenCard Style="width:120px;height:120px;border-radius:50%;
                           background:#d9d9d9;display:flex;
                           align-items:center;justify-content:center;
                           font-size:50px;color:#6c6c6c;">
            🐶
        </RadzenCard>

        <RadzenStack Gap="5">
            <RadzenText Text="@($"{Vm.Owner.Name} {Vm.Owner.LastName}")"
                        Style="font-size:24px;font-weight:600;color:#333;"/>
            <RadzenText Text="Dueño registrado"
                        Style="color:#777;"/>

            @if (!Vm.IsEditing)
            {
                <RadzenButton Text="Editar perfil"
                              Icon="edit"
                              Click="@Vm.EnableEdit"/>
            }
            else
            {
                <RadzenButton Text="Cancelar"
                              Icon="close"
                              ButtonStyle="ButtonStyle.Danger"
                              Click="@Vm.CancelEdit"/>
            }
        </RadzenStack>
    </RadzenStack>

    <!-- INFORMACIÓN -->
    <RadzenText Text="Información personal"
                Style="font-size:20px;font-weight:600;margin-bottom:20px;"/>

    <RadzenRow Gap="25">
        <RadzenColumn Size="6">@Campo("Nombre", Vm.Owner.Name, v => Vm.Owner.Name = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Apellido", Vm.Owner.LastName, v => Vm.Owner.LastName = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Email", Vm.Owner.Email, v => Vm.Owner.Email = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Teléfono", Vm.Owner.Phone, v => Vm.Owner.Phone = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Calle", Vm.Owner.Street, v => Vm.Owner.Street = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Ciudad", Vm.Owner.City, v => Vm.Owner.City = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Código Postal", Vm.Owner.PostalCode, v => Vm.Owner.PostalCode = v)</RadzenColumn>
        <RadzenColumn Size="6">@Campo("Comentarios", Vm.Owner.Coments, v => Vm.Owner.Coments = v)</RadzenColumn>
    </RadzenRow>

    <RadzenDivider Style="margin:30px 0;" />

    <!-- MASCOTAS -->
    <RadzenText Text="Mascotas"
                Style="font-size:20px;font-weight:600;margin-bottom:20px;"/>

    @if (Vm.Owner.Pet != null && Vm.Owner.Pet.Any())
    {
        <RadzenCarousel Style="height:250px;">
            @foreach (var mascota in Vm.Owner.Pet)
            {
                <RadzenCard Style="width:220px;margin:10px;cursor:pointer;"
                            Click="@(() => Vm.GoToPet(mascota.Id))">

                    <RadzenAvatar Image="https://cdn-icons-png.flaticon.com/512/194/194279.png"
                                  Size="60px"
                                  Style="margin-bottom:10px;"/>

                    <RadzenText Text="@mascota.Name" Style="font-weight:600;" />
                    <RadzenText Text="@($"Especie: {mascota.Specie}")" Style="font-size:12px;" />
                    <RadzenText Text="@($"Raza: {mascota.Breed}")" Style="font-size:12px;" />
                    <RadzenText Text="@($"{mascota.Age} años")" Style="font-size:12px;" />
                </RadzenCard>
            }
        </RadzenCarousel>
    }
    else
    {
        <RadzenText Text="Sin mascotas registradas"
                    Style="font-style:italic;color:#777;" />
    }

    @if (Vm.IsEditing)
    {
        <RadzenStack AlignItems="AlignItems.End" Style="margin-top:30px;">
            <RadzenButton Text="Guardar cambios"
                          Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@Vm.SaveAsync" />
        </RadzenStack>
    }

</RadzenCard>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Vm.LoadAsync(Id);
    }

    RenderFragment Campo(string label, string valor, Action<string>? onChange) => __builder =>
    {
        <RadzenStack Gap="5">
            <RadzenText Text="@label" Style="color:#777;" />

            @if (!Vm.IsEditing)
            {
                <RadzenText Text="@valor" Style="font-size:18px;color:#333;" />
            }
            else if (onChange != null)
            {
                <RadzenTextBox Value="@valor"
                               Change="@(e => onChange(e?.ToString() ?? ""))"
                               Style="width:100%;" />
            }
        </RadzenStack>;
    };
}